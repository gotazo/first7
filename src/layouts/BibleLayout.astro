---
import BaseLayout from "./BaseLayout.astro";

const {
  currentBook,
  currentChapter,
  relatedProphecy = [],
  relatedDictionary = [],
  relatedTeachings = [],
} = Astro.props as {
  currentBook: string;
  currentChapter: number;

  relatedProphecy?: any[];
  relatedDictionary?: any[];
  relatedTeachings?: any[];
};

type BibleData = {
  book: string;
  chapters: Record<string, string[]>;
};

const bibleModules = import.meta.glob(
  "../data/bible/*.json",
  { eager: true }
) as Record<string, { default: BibleData }>;

const allBooks = Object.values(bibleModules).map(
  (m) => m.default
);

const books: Record<string, number[]> = {};

for (const bookData of allBooks) {

  const slug =
    bookData.book
      .toLowerCase()
      .replace(/\s+/g, "-");

  books[slug] =
    Object.keys(bookData.chapters)
      .map(Number)
      .sort((a, b) => a - b);

}

const chapters =
  books[currentBook] ?? [];

const currentIndex =
  chapters.indexOf(currentChapter);

const prevChapter =
  currentIndex > 0
    ? chapters[currentIndex - 1]
    : null;

const nextChapter =
  currentIndex < chapters.length - 1
    ? chapters[currentIndex + 1]
    : null;

function formatBook(book: string) {

  return book
    .replace(/-/g, " ")
    .replace(/\b\w/g, (l) =>
      l.toUpperCase()
    );

}
---

<BaseLayout
  title={`${formatBook(currentBook)} ${currentChapter}`}
  canonicalURL={`https://first7.org/bible/${currentBook}/${currentChapter}`}
>

  <div class="min-h-screen">

    <!-- 🔥 STICKY STUDY HEADER -->
    <header
      class="
        sticky top-0 z-40
        border-b border-[var(--color-border)]
        bg-[var(--color-bg)]/95
        backdrop-blur
      "
    >

      <!-- TOP BAR -->
      <div
        class="
          mx-auto flex max-w-7xl flex-col gap-4
          px-4 py-4
          lg:flex-row lg:items-center lg:justify-between
        "
      >

        <!-- LEFT -->
        <div
          class="
            flex flex-col gap-3
            lg:flex-row lg:items-center
          "
        >

          <!-- 📖 BOOK SELECT -->
          <div>

            <label
              class="
                mb-1 block text-xs uppercase
                tracking-[0.2em]
                text-[var(--color-muted)]
              "
            >
              Book
            </label>

            <select
              id="book-select"
              class="
                rounded-xl
                border border-[var(--color-border)]
                bg-[var(--color-bg)]
                px-4 py-3
                text-sm
                outline-none
              "
            >

              {Object.keys(books).map((slug) => (

                <option
                  value={slug}
                  selected={slug === currentBook}
                >

                  {formatBook(slug)}

                </option>

              ))}

            </select>

          </div>

          <!-- 🔢 CHAPTER SELECT -->
          <div>

            <label
              class="
                mb-1 block text-xs uppercase
                tracking-[0.2em]
                text-[var(--color-muted)]
              "
            >
              Chapter
            </label>

            <select
              id="chapter-select"
              class="
                rounded-xl
                border border-[var(--color-border)]
                bg-[var(--color-bg)]
                px-4 py-3
                text-sm
                outline-none
              "
            >

              {chapters.map((chapter) => (

                <option
                  value={chapter}
                  selected={
                    chapter === currentChapter
                  }
                >

                  {chapter}

                </option>

              ))}

            </select>

          </div>

          <!-- ⬅️➡️ NAV -->
          <div
            class="
              flex items-end gap-2
            "
          >

            {prevChapter ? (

              <a
                href={`/bible/${currentBook}/${prevChapter}`}
                class="
                  rounded-xl
                  border border-[var(--color-border)]
                  px-4 py-3
                  text-sm
                  transition
                  hover:border-[var(--color-primary)]
                "
              >

                ← Prev

              </a>

            ) : (

              <span
                class="
                  rounded-xl
                  border border-[var(--color-border)]
                  px-4 py-3
                  text-sm opacity-40
                "
              >

                ← Prev

              </span>

            )}

            {nextChapter ? (

              <a
                href={`/bible/${currentBook}/${nextChapter}`}
                class="
                  rounded-xl
                  border border-[var(--color-border)]
                  px-4 py-3
                  text-sm
                  transition
                  hover:border-[var(--color-primary)]
                "
              >

                Next →

              </a>

            ) : (

              <span
                class="
                  rounded-xl
                  border border-[var(--color-border)]
                  px-4 py-3
                  text-sm opacity-40
                "
              >

                Next →

              </span>

            )}

          </div>

        </div>

        <!-- 🔍 SEARCH -->
        <div class="w-full max-w-xl">

          <label
            class="
              mb-1 block text-xs uppercase
              tracking-[0.2em]
              text-[var(--color-muted)]
            "
          >
            Search
          </label>

          <div class="flex gap-2">

            <input
              id="bible-search"
              type="text"
              placeholder="Genesis 1:9, John 3:16, Psalm 23"
              class="
                w-full rounded-xl
                border border-[var(--color-border)]
                bg-transparent
                px-4 py-3
                text-sm
                outline-none
              "
            />

            <button
              id="search-btn"
              class="
                rounded-xl
                px-5 py-3
                text-sm
                btn
              "
            >
              Go
            </button>

          </div>

        </div>

      </div>

      <!-- 📚 SECOND ROW -->
      <div
        class="
          border-t border-[var(--color-border)]
        "
      >

        <div
          class="
            mx-auto flex max-w-7xl
            gap-3 overflow-x-auto
            px-4 py-3
          "
        >

          <a
            href="#related-prophecy"
            class="
              whitespace-nowrap rounded-full
              border border-[var(--color-border)]
              px-4 py-2 text-sm
              transition hover:border-[var(--color-primary)]
            "
          >
            Related Prophecy
          </a>

          <a
            href="#dictionary"
            class="
              whitespace-nowrap rounded-full
              border border-[var(--color-border)]
              px-4 py-2 text-sm
              transition hover:border-[var(--color-primary)]
            "
          >
            Dictionary
          </a>

          <a
            href="#teachings"
            class="
              whitespace-nowrap rounded-full
              border border-[var(--color-border)]
              px-4 py-2 text-sm
              transition hover:border-[var(--color-primary)]
            "
          >
            Teachings
          </a>

          <a
            href="#cross-references"
            class="
              whitespace-nowrap rounded-full
              border border-[var(--color-border)]
              px-4 py-2 text-sm
              transition hover:border-[var(--color-primary)]
            "
          >
            Cross References
          </a>

          <a
            href="#notes"
            class="
              whitespace-nowrap rounded-full
              border border-[var(--color-border)]
              px-4 py-2 text-sm
              transition hover:border-[var(--color-primary)]
            "
          >
            Notes
          </a>

        </div>

      </div>

    </header>

    <!-- 📖 MAIN CONTENT -->
    <main
      class="
        mx-auto max-w-4xl
        px-4 py-10
      "
    >

      <!-- 📜 CHAPTER HEADER -->
      <header class="mb-12">

        <slot name="header" />

      </header>

      <!-- ✨ SCRIPTURE -->
      <article
        class="
          prose prose-invert
          max-w-none
        "
      >

        <slot />

      </article>

      <!-- 🔮 RELATED PROPHECY -->
      <section
        id="related-prophecy"
        class="
          mt-24 scroll-mt-40
          border-t border-[var(--color-border)]
          pt-12
        "
      >

        <div class="space-y-4">

          <h2 class="text-2xl font-semibold">
            Related Prophecy
          </h2>

          {
            relatedProphecy.length > 0 ? (

              <div class="grid gap-4 md:grid-cols-2">

                {relatedProphecy.map((entry) => (

                  <a
                    href={`/prophecy/${entry.id}`}
                    class="
                      rounded-2xl
                      border border-[var(--color-border)]
                      p-5
                      transition
                      hover:border-[var(--color-primary)]
                    "
                  >

                    <div class="space-y-2">

                      <h3 class="font-semibold">

                        {entry.data.title}

                      </h3>

                      <p
                        class="
                          text-sm
                          text-[var(--color-muted)]
                        "
                      >

                        {entry.data.description}

                      </p>

                    </div>

                  </a>

                ))}

              </div>

            ) : (

              <p class="text-sm text-[var(--color-muted)]">

                No related prophecy topics yet.

              </p>

            )
          }

        </div>

      </section>

      <!-- 📘 DICTIONARY -->
      <section
        id="dictionary"
        class="
          mt-20 scroll-mt-40
          border-t border-[var(--color-border)]
          pt-12
        "
      >

        <div class="space-y-4">

          <h2 class="text-2xl font-semibold">
            Dictionary
          </h2>

          {
            relatedDictionary.length > 0 ? (

              <div class="flex flex-wrap gap-3">

                {relatedDictionary.map((entry) => (

                  <a
                    href={`/dictionary/${entry.id}`}
                    class="
                      rounded-full
                      border border-[var(--color-border)]
                      px-4 py-2
                      text-sm
                      transition
                      hover:border-[var(--color-primary)]
                    "
                  >

                    {entry.data.title}

                  </a>

                ))}

              </div>

            ) : (

              <p class="text-sm text-[var(--color-muted)]">

                No related dictionary terms yet.

              </p>

            )
          }

        </div>

      </section>

      <!-- 📖 TEACHINGS -->
      <section
        id="teachings"
        class="
          mt-20 scroll-mt-40
          border-t border-[var(--color-border)]
          pt-12
        "
      >

        <div class="space-y-4">

          <h2 class="text-2xl font-semibold">
            Teachings
          </h2>

          {
            relatedTeachings.length > 0 ? (

              <div class="grid gap-4">

                {relatedTeachings.map((entry) => (

                  <a
                    href={`/teachings/${entry.id}`}
                    class="
                      rounded-2xl
                      border border-[var(--color-border)]
                      p-5
                      transition
                      hover:border-[var(--color-primary)]
                    "
                  >

                    <div class="space-y-2">

                      <h3 class="font-semibold">

                        {entry.data.title}

                      </h3>

                      <p
                        class="
                          text-sm
                          text-[var(--color-muted)]
                        "
                      >

                        {entry.data.summary}

                      </p>

                    </div>

                  </a>

                ))}

              </div>

            ) : (

              <p class="text-sm text-[var(--color-muted)]">

                No related teachings yet.

              </p>

            )
          }

        </div>

      </section>

      <!-- 🔗 CROSS REFERENCES -->
      <section
        id="cross-references"
        class="
          mt-20 scroll-mt-40
          border-t border-[var(--color-border)]
          pt-12
        "
      >

        <div class="space-y-4">

          <h2 class="text-2xl font-semibold">
            Cross References
          </h2>

          <p class="text-sm text-[var(--color-muted)]">
            Connected Scripture references
            will appear here.
          </p>

        </div>

      </section>

      <!-- 📝 NOTES -->
      <section
        id="notes"
        class="
          mt-20 scroll-mt-40
          border-t border-[var(--color-border)]
          pt-12
        "
      >

        <div class="space-y-4">

          <h2 class="text-2xl font-semibold">
            Notes
          </h2>

          <p class="text-sm text-[var(--color-muted)]">
            Personal notes and future study tools
            will appear here.
          </p>

        </div>

      </section>

    </main>

  </div>

  <!-- 🚀 SCRIPT -->
  <script is:inline>

    const bookSelect =
      document.getElementById(
        "book-select"
      );

    const chapterSelect =
      document.getElementById(
        "chapter-select"
      );

    function navigateBible() {

      const book =
        bookSelect?.value;

      const chapter =
        chapterSelect?.value;

      if (book && chapter) {

        window.location.href =
          `/bible/${book}/${chapter}`;

      }

    }

    bookSelect?.addEventListener(
      "change",
      () => {

        window.location.href =
          `/bible/${bookSelect.value}/1`;

      }
    );

    chapterSelect?.addEventListener(
      "change",
      navigateBible
    );

    const searchBtn =
      document.getElementById(
        "search-btn"
      );

    const searchInput =
      document.getElementById(
        "bible-search"
      );

    /**
     * 📖 Normalize Bible reference
     */
    function normalizeBibleReference(
      input
    ) {

      const aliases = {

        "gen": "genesis",
        "exo": "exodus",
        "lev": "leviticus",
        "num": "numbers",
        "deut": "deuteronomy",

        "josh": "joshua",
        "judg": "judges",

        "1 sam": "1-samuel",
        "2 sam": "2-samuel",

        "1 kings": "1-kings",
        "2 kings": "2-kings",

        "1 chron": "1-chronicles",
        "1 chr": "1-chronicles",

        "2 chron": "2-chronicles",
        "2 chr": "2-chronicles",

        "psalm": "psalms",
        "psa": "psalms",

        "prov": "proverbs",

        "song": "song-of-solomon",
        "songs": "song-of-solomon",
        "sos": "song-of-solomon",
        "canticles": "song-of-solomon",

        "isa": "isaiah",
        "jer": "jeremiah",
        "ezek": "ezekiel",
        "dan": "daniel",

        "matt": "matthew",
        "rom": "romans",

        "1 cor": "1-corinthians",
        "2 cor": "2-corinthians",

        "1 thess": "1-thessalonians",
        "2 thess": "2-thessalonians",

        "1 tim": "1-timothy",
        "2 tim": "2-timothy",

        "1 pet": "1-peter",
        "2 pet": "2-peter",

        "1 john": "1-john",
        "2 john": "2-john",
        "3 john": "3-john",

        "rev": "revelation",

      };

      const normalized =
        input
          .trim()
          .toLowerCase()
          .replace(/\s+/g, " ");

      const match =
        normalized.match(
          /^(.+?)\s+(\d+)(?::(\d+))?$/
        );

      if (!match) {

        return null;

      }

      let book =
        match[1].trim();

      const chapter =
        Number(match[2]);

      if (!chapter) {

        return null;

      }

      const verse =
        match[3]
          ? Number(match[3])
          : undefined;

      if (match[3] && !verse) {

        return null;

      }

      book =
        aliases[book] || book;

      book =
        book.replace(/\s+/g, "-");

      return {
        path: verse
          ? `/bible/${book}/${chapter}/#v${verse}`
          : `/bible/${book}/${chapter}`
      };

    }

    /**
     * 🚀 Search
     */
    searchBtn?.addEventListener(
      "click",
      () => {

        const value =
          searchInput?.value?.trim();

        if (!value) return;

        const result =
          normalizeBibleReference(
            value
          );

        if (!result) {

          alert(
            "Could not recognize Bible reference."
          );

          return;

        }

        window.location.href =
          result.path;

      }
    );

    /**
     * ⌨️ Enter key
     */
    searchInput?.addEventListener(
      "keydown",
      (event) => {

        if (event.key === "Enter") {

          searchBtn?.click();

        }

      }
    );

  </script>

</BaseLayout>
