---
import BaseLayout from "./BaseLayout.astro";

const { currentBook, currentChapter } = Astro.props as {
  currentBook: string;
  currentChapter: number;
};

type BibleData = {
  book: string;
  chapters: Record<string, string[]>;
};

const bibleModules = import.meta.glob(
  "../data/bible/*.json",
  { eager: true }
) as Record<string, { default: BibleData }>;

const allBooks = Object.values(bibleModules).map((m) => m.default);

const books: Record<string, number[]> = {};

for (const bookData of allBooks) {
  const slug = bookData.book.toLowerCase().replace(/\s+/g, "-");

  books[slug] = Object.keys(bookData.chapters).map(Number);
  books[slug].sort((a, b) => a - b);
}

const chapters = books[currentBook] ?? [];
const index = chapters.indexOf(currentChapter);

const prev = index > 0 ? chapters[index - 1] : null;
const next = index < chapters.length - 1 ? chapters[index + 1] : null;
---

<BaseLayout title={`${currentBook} ${currentChapter}`}>

  <div class="flex gap-8">

    <!-- 📚 SIDEBAR -->
    <aside
      id="sidebar"
      class="fixed md:static top-0 left-0 z-50 h-full w-64 -translate-x-full md:translate-x-0 bg-[var(--color-bg)] border-r border-[var(--color-border)] p-4 overflow-y-auto transition-transform duration-300"
    >
      <p class="text-xs uppercase text-[var(--color-muted)] mb-4">Bible</p>

      <div class="space-y-6">
        {Object.entries(books).map(([slug, chapters]) => (
          <div>
            <a
              href={`/bible/${slug}/1`}
              class={`font-semibold block ${
                slug === currentBook ? "text-[var(--color-primary)]" : ""
              }`}
            >
              {slug.replace(/-/g, " ")}
            </a>

            {slug === currentBook && (
              <div class="flex flex-wrap gap-2 mt-2">
                {chapters.map((c: number) => (
                  <a
                    href={`/bible/${slug}/${c}`}
                    class={`px-2 py-1 text-sm rounded ${
                      c === currentChapter
                        ? "bg-[var(--color-primary)] text-white"
                        : "border border-[var(--color-border)]"
                    }`}
                  >
                    {c}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </aside>

    <!-- 🌫️ OVERLAY -->
    <div
      id="overlay"
      class="fixed inset-0 bg-black/40 hidden md:hidden z-40"
    ></div>

    <!-- 📖 CONTENT -->
    <main class="flex-1 max-w-2xl mx-auto p-6">

      <!-- 📱 MOBILE HEADER -->
      <div class="mb-4 flex items-center gap-3 md:hidden">
        <button id="menu-btn" class="px-3 py-2 border rounded text-sm">
          ☰ Bible
        </button>

        <span class="text-sm text-[var(--color-muted)]">
          {currentBook.replace(/-/g, " ")} {currentChapter}
        </span>
      </div>

      <!-- 🔍 SEARCH -->
      <div class="mb-6 relative">
        <div class="flex gap-2">
          <input
            id="bible-search"
            type="text"
            placeholder="Search (e.g. John 3)"
            class="flex-1 px-3 py-2 rounded border border-[var(--color-border)] text-sm"
          />

          <button
            id="search-btn"
            class="px-4 py-2 text-sm rounded bg-[var(--color-primary)] text-white"
          >
            Go
          </button>
        </div>

        <div
          id="search-results"
          class="absolute left-0 right-0 mt-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded shadow hidden z-50 max-h-60 overflow-y-auto"
        ></div>
      </div>

      <div class="mb-6">
        <slot name="header" />
      </div>

      <slot />

      <!-- 🔁 NAV -->
      <div class="mt-12 flex justify-between text-sm">
        {prev ? (
          <a href={`/bible/${currentBook}/${prev}`}>
            ← Previous
          </a>
        ) : <span />}

        {next ? (
          <a href={`/bible/${currentBook}/${next}`}>
            Next →
          </a>
        ) : <span />}
      </div>

    </main>
  </div>

  <!-- ✅ SAFE DATA -->
  <div
    id="bible-data"
    data-books={JSON.stringify(
      Object.keys(books).map((b) => b.replace(/-/g, " "))
    )}
    hidden
  ></div>

  <!-- 🚀 SCRIPT -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {

      const input = document.getElementById("bible-search");
      const button = document.getElementById("search-btn");
      const results = document.getElementById("search-results");

      const sidebar = document.getElementById("sidebar");
      const menuBtn = document.getElementById("menu-btn");
      const overlay = document.getElementById("overlay");

      // 📚 Sidebar
      menuBtn?.addEventListener("click", () => {
        sidebar?.classList.remove("-translate-x-full");
        overlay?.classList.remove("hidden");
      });

      overlay?.addEventListener("click", () => {
        sidebar?.classList.add("-translate-x-full");
        overlay?.classList.add("hidden");
      });

      // 📖 Data
      const dataEl = document.getElementById("bible-data");

      let bookList = [];

      try {
        if (dataEl) {
          bookList = JSON.parse(dataEl.dataset.books || "[]");
        }
      } catch {}

      const normalize = (str) =>
        String(str).toLowerCase().trim();

      const slugify = (str) =>
        normalize(str).replace(/\s+/g, "-");

      const goTo = (value) => {
        if (!value) return;

        const parts = normalize(value).split(" ");
        const last = parts[parts.length - 1];
        const chapter = parseInt(last);

        const book =
          Number.isNaN(chapter)
            ? value
            : parts.slice(0, -1).join(" ");

        if (!book) return;

        const slug = slugify(book);
        const finalChapter = Number.isNaN(chapter) ? 1 : chapter;

        window.location.href = `/bible/${slug}/${finalChapter}`;
      };

      const renderResults = (matches) => {
        if (!results) return;

        results.innerHTML = "";

        if (matches.length === 0) {
          results.classList.add("hidden");
          return;
        }

        matches.slice(0, 8).forEach((book) => {
          const div = document.createElement("div");

          div.className =
            "px-3 py-2 cursor-pointer hover:bg-[var(--color-primary)]/10";

          div.textContent = book;

          div.onclick = () => goTo(book);

          results.appendChild(div);
        });

        results.classList.remove("hidden");
      };

      // 🔍 INPUT
      if (input instanceof HTMLInputElement) {
        input.addEventListener("input", () => {
          const value = normalize(input.value);

          if (!value) {
            results?.classList.add("hidden");
            return;
          }

          const matches = bookList.filter((b) =>
            normalize(b).includes(value)
          );

          renderResults(matches);
        });

        input.addEventListener("keydown", (e) => {
          if (e.key === "Enter") {
            goTo(input.value);
          }
        });
      }

      // 🔘 BUTTON
      button?.addEventListener("click", () => {
        if (input instanceof HTMLInputElement) {
          goTo(input.value);
        }
      });

    });
  </script>

</BaseLayout>