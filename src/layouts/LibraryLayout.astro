---
const { topics = [], currentTopic } = Astro.props;
---

<div class="flex gap-10">

  <!-- Sidebar -->
  <aside class="w-56 shrink-0">

    <nav class="space-y-2">

      {topics.map((topic: string) => (

        <a
          href={`/teachings?topic=${encodeURIComponent(topic)}`}
          class={`block text-sm ${
            topic === currentTopic
              ? "font-medium text-white"
              : "text-[var(--color-muted)]"
          }`}
        >
          {topic}
        </a>

      ))}

    </nav>

  </aside>

  <!-- Content -->
  <main class="flex-1">
    <slot />
  </main>

</div>