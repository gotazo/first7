---
const { topics = [] } = Astro.props;
---

<div class="flex gap-10">

  <!-- Sidebar -->
  <aside class="w-56 shrink-0">

    <nav class="space-y-2">

      {topics.map((topic: string) => (

        <a
          href="/teachings"
          class="block text-sm text-[var(--color-muted)]"
        >
          {topic}
        </a>

      ))}

    </nav>

  </aside>

  <!-- Content -->
  <main class="flex-1">
    <slot />
  </main>

</div>
