---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const {
  title = "First7",
  description = "Build a daily habit of faith through Scripture, devotionals, and guided plans.",
  full = false
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />

    <!-- ✅ FIXED VIEWPORT -->
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f172a" />

    <link rel="icon" href="/favicon.svg" />

    <!-- ✅ SAFE THEME INIT (no crash) -->
    <script>
      try {
        if (localStorage.getItem('theme') === 'dark') {
          document.documentElement.classList.add('dark');
        }
      } catch {}
    </script>

    <!-- ✅ CRITICAL CSS -->
    <style>
  body {
    margin: 0;
    font-family: system-ui, -apple-system, sans-serif;
    background: #fafaf7;
    color: #1c1c1c;
    font-size-adjust: 0.5;
  }
</style>

  </head>

  <body class="bg-[var(--color-bg)] text-[var(--color-text)] min-h-screen flex flex-col">

    <Navbar />

    <main class="flex-1 w-full">
      {full ? (
        <div class="w-full px-4 py-8 md:px-8">
          <slot />
        </div>
      ) : (
        <div class="max-w-4xl mx-auto px-5 py-10 md:py-12">
          <slot />
        </div>
      )}
    </main>

    <Footer />

  </body>
</html>