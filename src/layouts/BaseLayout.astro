---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const {
  title = "First7",
  description = "Build a daily habit of faith through Scripture, devotionals, and guided plans.",
  full = false // ✅ NEW
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" href="/favicon.svg" />
  </head>

  <body class="bg-[var(--color-bg)] text-[var(--color-text)] min-h-screen flex flex-col">

    <Navbar />

    <main class="flex-1 w-full">

      {full ? (
        <!-- ✅ FULL WIDTH MODE -->
        <div class="w-full px-4 py-8 md:px-8">
          <slot />
        </div>
      ) : (
        <!-- ✅ DEFAULT MODE -->
        <div class="max-w-4xl mx-auto px-5 py-10 md:py-12">
          <slot />
        </div>
      )}

    </main>

    <Footer />

  </body>
</html>