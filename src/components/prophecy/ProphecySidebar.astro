---
import { getCollection } from "astro:content";

const { currentSlug } = Astro.props;

const entries = await getCollection("prophecy");

const grouped = {
  symbols: entries.filter((e) => e.data.category === "symbols"),
  people: entries.filter((e) => e.data.category === "people"),
  nations: entries.filter((e) => e.data.category === "nations"),
  timeline: entries.filter((e) => e.data.category === "timeline"),
};
---

<aside class="w-full lg:w-72 shrink-0">

  <div class="sticky top-24 space-y-8">

    {Object.entries(grouped).map(([group, items]) => (

      <section class="space-y-3">

        <h2 class="text-sm uppercase tracking-wider text-[var(--color-muted)]">
          {group}
        </h2>

        <nav class="space-y-2">

          {items.map((item) => {

            const active = item.id === currentSlug;

            return (
              <a
                href={`/prophecy/${item.id}`}
                class:list={[
                  "block rounded-xl px-3 py-2 text-sm border transition-all duration-200",

                  active
                    ? `
                      bg-[var(--color-primary)]/20
                      border-[var(--color-primary)]
                      text-white
                      backdrop-blur-sm
                      shadow-[0_0_0_1px_rgba(143,175,151,0.15)]
                    `
                    : `
                      border-transparent
                      text-[var(--color-muted)]
                      hover:bg-[var(--color-bg-soft)]
                      hover:border-[var(--color-border)]
                      hover:text-[var(--color-text)]
                    `,
                ]}
              >
                {item.data.title}
              </a>
            );
          })}

        </nav>

      </section>

    ))}

  </div>

</aside>
