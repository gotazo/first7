---
interface Props {
  topics: any[];
}

const { topics } = Astro.props;
---

<section class="space-y-5">

  <h2 class="text-2xl font-semibold">
    Related Topics
  </h2>

  <div class="grid gap-4 md:grid-cols-2">

    {topics.map((topic) => (

      <a
        href={`/prophecy/${topic.id}`}
        class="rounded-2xl border border-[var(--color-border)] p-5 transition hover:border-[var(--color-primary)]"
      >

        <div class="space-y-2">

          <p class="text-sm uppercase tracking-wide text-[var(--color-muted)]">
            {topic.data.category}
          </p>

          <h3 class="text-lg font-medium">
            {topic.data.title}
          </h3>

          <p class="text-sm leading-relaxed text-[var(--color-muted)]">
            {topic.data.description}
          </p>

        </div>

      </a>

    ))}

  </div>

</section>
