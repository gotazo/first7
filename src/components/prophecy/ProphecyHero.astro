---
const {
  category,
  title,
  description
} = Astro.props;
---

<section
  class="
    mb-10
    rounded-3xl
    border
    border-[var(--color-border)]
    p-6
    md:p-8
  "
>

  <div class="space-y-4">

    <div
      class="
        text-sm
        uppercase
        tracking-wide
        text-[var(--color-muted)]
      "
    >
      {category}
    </div>

    <h1
      class="
        text-3xl
        md:text-4xl
        font-semibold
      "
    >
      {title}
    </h1>

    <p
      class="
        text-lg
        text-[var(--color-muted)]
      "
    >
      {description}
    </p>

    <input
      type="search"
      placeholder="Search prophecy..."
      class="
        w-full
        rounded-xl
        border
        border-[var(--color-border)]
        px-4
        py-3
      "
    />

  </div>

</section>
