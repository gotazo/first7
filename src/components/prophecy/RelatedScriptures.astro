---
interface Props {
  scriptures: string[];
}

const { scriptures } = Astro.props;

/**
 * Converts:
 * "Revelation 13"
 * -> { book: "revelation", chapter: "13" }
 */
function parseScripture(scripture: string) {

  const parts =
    scripture.trim().split(" ");

  const chapter =
    parts.pop();

  const book =
    parts.join(" ")
      .toLowerCase()
      .replace(/\s+/g, "-");

  return {
    book,
    chapter,
  };

}
---

<section class="space-y-5">

  <h2 class="text-2xl font-semibold">
    Related Scriptures
  </h2>

  <div class="flex flex-wrap gap-3">

    {scriptures.map((scripture) => {

      const parsed =
        parseScripture(scripture);

      return (

        <a
          href={`/bible/${parsed.book}/${parsed.chapter}`}
          class="rounded-full border border-[var(--color-border)] px-4 py-2 text-sm transition hover:border-[var(--color-primary)] hover:bg-[var(--color-primary)]/5"
        >

          {scripture}

        </a>

      );

    })}

  </div>

</section>
