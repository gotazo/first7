---
const topics = [
  "Israel",
  "Babylon",
  "Daniel",
  "Revelation",
  "Beast",
  "Antichrist",
  "Kingdom"
];
---

<div
  class="
    mb-10
    flex
    flex-wrap
    gap-3
  "
>

  {topics.map(topic => (

    <a
      href={`/prophecy/search?q=${topic}`}
      class="
        rounded-full
        border
        border-[var(--color-border)]
        px-4
        py-2
        text-sm
      "
    >

      {topic}

    </a>

  ))}

</div>
