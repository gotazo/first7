---
interface Props {
  terms: any[];
}

const { terms } = Astro.props;
---

<section class="space-y-5">

  <h2 class="text-2xl font-semibold">
    Study Terms
  </h2>

  <div class="grid gap-4 md:grid-cols-2">

    {terms.map((term) => (

      <a
      href={`/dictionary/${term.id}`}
        class="rounded-2xl border border-[var(--color-border)] p-5 transition hover:border-[var(--color-primary)]"
      >

        <div class="space-y-2">

          <h3 class="text-lg font-medium">
            {term.data.title}
          </h3>

          <p class="text-sm leading-relaxed text-[var(--color-muted)]">
            {term.data.shortMeaning}
          </p>

        </div>

      </a>

    ))}

  </div>

</section>
