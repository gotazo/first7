---
interface Props {
  verse: string; // "Genesis 1:3"
}

const { verse } = Astro.props;

const match =
  verse
    .trim()
    .match(/^(.+?)\s+(\d+)(?::(\d+))?$/);

const book =
  match?.[1]
    .trim()
    .toLowerCase()
    .replace(/\s+/g, "-");

const chapter =
  match?.[2];

const verseNum =
  match?.[3];

const url =
  book && chapter
    ? `/bible/${book}/${chapter}${verseNum ? `#v${verseNum}` : ""}`
    : "/bible";
---

<a href={url} class="bible-link">
  {verse}
</a>
