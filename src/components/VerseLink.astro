---
interface Props {
  verse: string; // "Genesis 1:3"
}

const { verse } = Astro.props;

const [reference, verseNum] = verse.split(':');

const parts = reference.trim().split(' ');
const chapter = parts.pop();
const book = parts
  .join(' ')
  .toLowerCase()
  .replace(/\s+/g, '-');

const url = `/bible/${book}/${chapter}${verseNum ? `#verse-${verseNum}` : ''}`;
---

<a href={url} class="bible-link">
  {verse}
</a>