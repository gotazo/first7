---
const { verse } = Astro.props;
---

<div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 p-6">
  <p class="text-xs uppercase tracking-wide text-[var(--color-muted)]">
    Key Verse
  </p>

  <p class="mt-3 text-xl leading-relaxed font-medium">
    {verse}
  </p>
</div>