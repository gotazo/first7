---
import type { StudyNavigationItem } from "@/types/study";

interface Props {
  previous?: StudyNavigationItem;
  next?: StudyNavigationItem;
}

const {
  previous,
  next,
} = Astro.props;
---

<nav
  aria-label="Study navigation"
  class="mt-12"
>

  <div
    class="
      grid
      gap-4
      md:grid-cols-2
    "
  >

    <div>

      {previous && (

        <a
          href={previous.href}
          class="
            block
            rounded-2xl
            border
            border-[var(--color-border)]
            bg-[var(--color-surface)]
            p-5
            transition-all
            hover:border-[var(--color-primary)]
          "
        >

          <p
            class="
              mb-2
              text-sm
              text-[var(--color-muted)]
            "
          >
            ← Previous
          </p>

          <h3
            class="
              font-semibold
            "
          >
            {previous.title}
          </h3>

        </a>

      )}

    </div>

    <div>

      {next && (

        <a
          href={next.href}
          class="
            block
            rounded-2xl
            border
            border-[var(--color-border)]
            bg-[var(--color-surface)]
            p-5
            text-right
            transition-all
            hover:border-[var(--color-primary)]
          "
        >

          <p
            class="
              mb-2
              text-sm
              text-[var(--color-muted)]
            "
          >
            Next →
          </p>

          <h3
            class="
              font-semibold
            "
          >
            {next.title}
          </h3>

        </a>

      )}

    </div>

  </div>

</nav>