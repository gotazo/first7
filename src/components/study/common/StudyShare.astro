---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<button
  type="button"
  class="
    share-button
    inline-flex
    items-center
    gap-2
    rounded-full
    border
    px-3
    py-1.5
    text-sm
    text-[var(--color-muted)]
    transition
  "
  data-teaching-share
  aria-label={`Share ${title}`}
>

  <svg
    aria-hidden="true"
    class="h-4 w-4"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="18" cy="5" r="3"></circle>
    <circle cx="6" cy="12" r="3"></circle>
    <circle cx="18" cy="19" r="3"></circle>

    <path d="m8.6 13.5 6.8 4"></path>
    <path d="m15.4 6.5-6.8 4"></path>
  </svg>

  <span data-share-label>
    Share
  </span>

</button>