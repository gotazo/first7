---
export interface QuickReferenceItem {
  label: string;
  value: string;
  href?: string;
  icon?: ComponentType;
}

interface Props {
  title?: string;
  items: QuickReferenceItem[];
}

const {
  title = "Quick Reference",
  items,
} = Astro.props;
---

<section
  aria-labelledby="quick-reference-title"
  class="
    rounded-2xl
    border
    border-[var(--color-border)]
    bg-[var(--color-surface)]
    p-6
    md:p-8
  "
>

  <div class="space-y-6">

    <header>

      <h2
        id="quick-reference-title"
        class="
          text-xl
          font-semibold
          tracking-tight
        "
      >
        {title}
      </h2>

    </header>

    <dl
      class="
        grid
        gap-6
        sm:grid-cols-2
        lg:grid-cols-3
      "
    >

      {items.map((item) => (

        <div
          class="
            rounded-xl
            border
            border-[var(--color-border)]
            bg-[var(--color-bg)]
            p-4
          "
        >

          <dt
            class="
              mb-1
              text-sm
              font-medium
              text-[var(--color-muted)]
            "
          >
            {item.label}
          </dt>

          <dd
            class="
              text-base
              font-medium
              break-words
            "
          >

            {item.href ? (

              <a
                href={item.href}
                class="
                  text-[var(--color-primary)]
                  transition-colors
                  hover:underline
                "
              >
                {item.value}
              </a>

            ) : (

              item.value

            )}

          </dd>

        </div>

      ))}

    </dl>

  </div>

</section>