---
import VerseLink from "./VerseLink.astro";

const {
  plan = "anxiety",
} = Astro.props;

// 📖 Verse list
const verses = [
  "Matthew 6:33",
  "Proverbs 3:5",
  "Philippians 4:6",
  "Psalm 46:10",
  "Romans 8:28",
  "Isaiah 41:10",
  "John 14:27",
  "2 Corinthians 5:17",
  "Galatians 2:20",
  "Psalm 23:1"
];

// 📅 Get today's index
const today = new Date();
const startOfYear = new Date(today.getFullYear(), 0, 0);

const dayOfYear = Math.floor(
  (today.getTime() - startOfYear.getTime()) / 86400000
);

// 🔁 Rotate
const verse = verses[dayOfYear % verses.length];
---

<aside class="space-y-6">

  <!-- 🙏 TODAY'S WORD -->
  <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 p-5">
    <p class="text-xs text-[var(--color-muted)]">
      Today’s Word
    </p>

    <p class="mt-2 text-lg font-medium leading-snug">
      <VerseLink verse={verse} />
    </p>
  </div>

  <!-- 🔁 CONTINUE JOURNEY -->
  <div
    id="continue-box"
    class="hidden rounded-2xl border border-[var(--color-border)] p-5"
  >
    <p class="text-xs text-[var(--color-muted)]">
      Continue your journey
    </p>

    <a
      id="continue-link"
      class="mt-2 block text-lg font-medium text-[var(--color-primary)]"
    >
      Resume →
    </a>
  </div>

  <!-- ✍️ REFLECTION PROMPT -->
  <div class="rounded-2xl border border-[var(--color-border)] p-5">
    <p class="text-sm font-medium">
      Reflect
    </p>

    <p class="mt-2 text-sm text-[var(--color-muted)] leading-relaxed">
      What is God showing you through this today?
    </p>
  </div>

  <!-- 📖 RELATED ACTION -->
  <div class="rounded-2xl border border-[var(--color-border)] p-5">
    <p class="text-xs text-[var(--color-muted)]">
      Take a step
    </p>

    <a
      href={`/plans/${plan}/day-1`}
      class="mt-2 block text-lg font-medium text-[var(--color-primary)]"
    >
      Start a 7-day journey →
    </a>
  </div>

  <!-- 🤝 SUPPORT -->
  <div class="rounded-2xl border border-[var(--color-border)] p-5 text-center">
    <p class="text-sm text-[var(--color-muted)] leading-relaxed">
      This platform exists to help people grow in faith.
    </p>

    <a
      href="/support"
      class="mt-3 inline-block text-sm font-medium text-[var(--color-primary)]"
    >
      Support the mission →
    </a>
  </div>

</aside>

<script is:inline define:vars={{ plan }}>
  const storageKey = `first7-${plan}`;
  let saved = [];

  try {
    saved = JSON.parse(localStorage.getItem(storageKey) || "[]");
  } catch {}

  const continueBox = document.getElementById("continue-box");
  const continueLink = document.getElementById("continue-link");

  if (continueBox && continueLink && saved.length > 0) {
    const lastDay = Math.max(...saved);

    continueBox.classList.remove("hidden");
    continueLink.href = `/plans/${plan}/day-${lastDay + 1}`;
    continueLink.textContent = `Resume Day ${lastDay + 1} →`;
  }
</script>