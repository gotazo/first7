---
import {
  BookOpen,
  BookOpenText,
  CalendarDays,
  Compass,
  Hash,
  Heart,
  Library,
  ScrollText,
} from "../../lib/icons";

import { SEARCH_COLLECTIONS } from "./collections";

const icons = {
  "book-open": BookOpen,
  "book-text": BookOpenText,
  "scroll-text": ScrollText,
  "calendar-days": CalendarDays,
  library: Library,
  compass: Compass,
  heart: Heart,
  hash: Hash,
} as const;
---

<nav
  aria-label="Browse First7 collections"
  class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4"
>
  {
    SEARCH_COLLECTIONS.map((collection) => {
      const Icon =
        icons[collection.icon as keyof typeof icons];

      return (
        <a
          href={collection.href}
          title={collection.description}
          class="
            group
            flex
            flex-col
            items-center
            rounded-3xl
            border
            border-[var(--color-border)]
            bg-[var(--color-bg-soft)]
            p-8
            text-center
            transition-all
            duration-300
            hover:-translate-y-1
            hover:border-[var(--color-primary)]
            hover:bg-[var(--color-bg-elevated)]
            hover:shadow-xl
          "
        >
          <div
            class="
              mb-6
              flex
              h-20
              w-20
              items-center
              justify-center
              rounded-3xl
              border
              border-[var(--color-border)]
              bg-[var(--color-bg)]
              transition-all
              duration-300
              group-hover:border-[var(--color-primary)]
              group-hover:bg-[var(--color-bg-soft)]
            "
          >
<Icon
  class:list={[
    "h-12 w-12 transition-transform duration-300 group-hover:scale-110",
    collection.color,
  ]}
/>
          </div>

          <h3
            class="
              text-lg
              font-semibold
            "
          >
            {collection.title}
          </h3>

          <p
            class="
              mt-3
              text-sm
              leading-6
              text-[var(--color-muted)]
            "
          >
            {collection.description}
          </p>
        </a>
      );
    })
  }
</nav>