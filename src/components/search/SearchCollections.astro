---
import {
  BookOpen,
  BookOpenText,
  CalendarDays,
  Compass,
  Heart,
  Library,
  ScrollText,
 } from "../../lib/icons";

import { SEARCH_COLLECTIONS } from "./collections";

const icons = {
  "book-open": BookOpen,
  "book-text": BookOpenText,
  "scroll-text": ScrollText,
  "calendar-days": CalendarDays,
  library: Library,
  compass: Compass,
  heart: Heart,
} as const;
---

<nav
  aria-label="Browse First7 collections"
  class="grid gap-6 md:grid-cols-2 xl:grid-cols-3"
>
  {
    SEARCH_COLLECTIONS.map((collection) => {
      const Icon =
        icons[collection.icon as keyof typeof icons];

      return (
        <a
          href={collection.href}
          title={collection.description}
          class="
            group
            flex
            items-center
            gap-6
            rounded-3xl
            border
            border-[var(--color-border)]
            bg-[var(--color-bg-soft)]
            p-6
            transition-all
            duration-300
            hover:-translate-y-1
            hover:border-[var(--color-primary)]
            hover:shadow-xl
          "
        >
          <div
            class="
              flex
              h-20
              w-20
              shrink-0
              items-center
              justify-center
              rounded-2xl
              border
              border-[var(--color-border)]
              bg-[var(--color-bg)]
              transition-all
              duration-300
              group-hover:border-[var(--color-primary)]
            "
          >
            <Icon
              class="
                h-10
                w-10
                text-[var(--color-primary)]
                transition-transform
                duration-300
                group-hover:scale-110
              "
            />
          </div>

          <div class="min-w-0 flex-1">

            <h3
              class="
                text-xl
                font-semibold
              "
            >
              {collection.title}
            </h3>

            <p
              class="
                mt-2
                text-sm
                leading-7
                text-[var(--color-muted)]
              "
            >
              {collection.description}
            </p>

          </div>


        </a>
      );
    })
  }
</nav>