---
interface Props {
  title: string;
  description: string;
  href: string;
  type: string;
}

const { title, description, href, type } = Astro.props;
---

<a
  href={href}
  class="block rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-soft)] p-6 transition hover:border-[var(--color-primary)]"
>

  <p class="text-xs uppercase tracking-[0.15em] text-[var(--color-primary)]">
    {type}
  </p>

  <h3 class="mt-2 text-xl font-semibold">
    {title}
  </h3>

  <p class="mt-3 text-[var(--color-muted)]">
    {description}
  </p>

</a>