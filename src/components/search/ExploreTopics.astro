---
import {
  BookOpen,
  Gift,
  HandHelping,
  Heart,
  HeartHandshake,
  Leaf,
  Lightbulb,
  ShieldCheck,
  ShieldPlus,
  Sunrise,
} from "../../lib/icons";

import { EXPLORE_TOPICS } from "./exploreTopics";

const icons = {
  "book-open": BookOpen,
  "shield-check": ShieldCheck,
  "hand-helping": HandHelping,
  sunrise: Sunrise,
  heart: Heart,
  gift: Gift,
  leaf: Leaf,
  "heart-handshake": HeartHandshake,
  lightbulb: Lightbulb,
  "shield-plus": ShieldPlus,
} as const;
---

<section
  aria-labelledby="explore-topics-heading"
  class="space-y-6"
>
  <div
    class="
      grid
      gap-6
      sm:grid-cols-2
      lg:grid-cols-5
    "
  >
    {
      EXPLORE_TOPICS.map((topic) => {
        const Icon =
          icons[topic.icon as keyof typeof icons];

        return (
          <a
            href={`/search?q=${encodeURIComponent(topic.query)}`}
            class="
              group
              flex
              flex-col
              items-center
              rounded-3xl
              border
              border-[var(--color-border)]
              bg-[var(--color-bg-soft)]
              p-6
              text-center
              transition-all
              duration-300
              hover:-translate-y-1
              hover:border-[var(--color-primary)]
              hover:bg-[var(--color-bg-elevated)]
              hover:shadow-xl
            "
          >
            <div
  class:list={[
    "mb-5 flex h-16 w-16 items-center justify-center rounded-2xl border border-[var(--color-border)] transition-all duration-300 group-hover:border-[var(--color-primary)]",
    topic.bgColor,
  ]}
>
              <Icon
                class:list={[
                  "h-8 w-8 transition-transform duration-300 group-hover:scale-110",
                  topic.color,
                ]}
              />
            </div>

            <span
              class="
                text-base
                font-semibold
              "
            >
              {topic.title}
            </span>
          </a>
        );
      })
    }
  </div>
</section>