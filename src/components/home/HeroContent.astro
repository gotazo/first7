---
import Button from "../ui/Button.astro";
import HeroTrustBar from "./HeroTrustBar.astro";
---

<div class="max-w-2xl">

  <!-- Eyebrow -->

  <p
    class="mb-4 text-sm font-semibold uppercase tracking-[0.25em] text-[var(--color-primary)]"
  >
    Begin Your Journey
  </p>

  <!-- Main Heading -->

  <h1
    class="text-5xl font-bold leading-tight tracking-tight md:text-6xl"
  >
    Grow in God's Word,

    <span class="mt-2 block text-[var(--color-primary)]">
      one step at a time.
    </span>
  </h1>

  <!-- Mission Statement -->

  <div class="mt-8 space-y-2 text-xl font-medium leading-relaxed">

    <p>Read Scripture.</p>

    <p>Grow in faith.</p>

    <p>Walk with God.</p>

  </div>

  <!-- Description -->

  <p
    class="mt-8 max-w-xl text-lg leading-8 text-[var(--color-text-muted)]"
  >
    Explore Bible verses, teachings, journals, and practical
    resources—all rooted in the King James Bible and designed to
    help you take one step closer to Christ each day.
  </p>

  <!-- Actions -->

  <div class="mt-10 flex flex-wrap gap-4">

    <Button href="/verse-jar">
      Explore Bible Verses →
    </Button>

    <Button
      href="/start"
      variant="secondary"
    >
      Start a 7-Day Plan
    </Button>

  </div>

  <!-- Trust Bar -->

  <HeroTrustBar />

</div>