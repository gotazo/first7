---
interface TrustItem {
  label: string;
}

const items: TrustItem[] = [
  {
    label: "Free to Read",
  },
  {
    label: "King James Bible",
  },
  {
    label: "No Sign-up Required",
  },
];
---

<div
  class="
    mt-10
    flex
    flex-wrap
    items-center
    gap-x-6
    gap-y-3
    text-sm
    text-[var(--color-text-muted)]
  "
>

  {
    items.map((item) => (

      <div
        class="flex items-center gap-2"
      >

        <span
          class="
            flex
            h-5
            w-5
            items-center
            justify-center
            rounded-full
            bg-[color-mix(in_srgb,var(--color-primary)_12%,transparent)]
            text-[var(--color-primary)]
            text-xs
            font-bold
          "
        >
          ✓
        </span>

        <span>
          {item.label}
        </span>

      </div>

    ))
  }

</div>