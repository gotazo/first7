---
import Card from "../ui/Card.astro";

interface Props {
  title: string;
  description: string;
  href: string;
  icon: any;
}

const {
  title,
  description,
  href,
  icon: Icon,
} = Astro.props;
---

<Card
  href={href}
  class="group h-full"
>
  <div class="flex h-full flex-col">

    <!-- Icon -->

    <div
      class="
        mb-6
        inline-flex
        h-14
        w-14
        items-center
        justify-center
        rounded-xl
        bg-[color-mix(in_srgb,var(--color-primary)_12%,transparent)]
        text-[var(--color-primary)]
      "
    >
      <Icon class="h-7 w-7" />
    </div>

    <!-- Title -->

    <h3
      class="
        text-xl
        font-semibold
        tracking-tight
        text-[var(--color-text)]
      "
    >
      {title}
    </h3>

    <!-- Description -->

    <p
      class="
        mt-3
        flex-1
        leading-7
        text-[var(--color-text-muted)]
      "
    >
      {description}
    </p>

    <!-- CTA -->

    <span
      class="
        mt-6
        inline-flex
        items-center
        gap-2
        font-medium
        text-[var(--color-primary)]
        transition-all
        duration-200
        group-hover:translate-x-1
      "
    >
      Explore Collection →
    </span>

  </div>
</Card>