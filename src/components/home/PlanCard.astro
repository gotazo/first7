---
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";
import { CalendarDays } from "../../lib/icons";

import type { PlanSummary } from "../../lib/start-plans";
import { titleCase } from "../../lib/format";

interface Props {
  plan: PlanSummary;
}

const { plan } = Astro.props;

const firstDay = plan.entries[0];

const totalDays = plan.entries.length;

const title = titleCase(plan.plan);

const description =
  firstDay?.data.description ??
  "Start your journey.";

const href = `/plans/${plan.plan}`;
---

<Card
  class="
    group
    h-full
    transition-all
    duration-300
    hover:-translate-y-1
    hover:shadow-xl
  "
>

  <div class="flex h-full flex-col">

    <div class="space-y-6">

      <div class="flex">
        <span class="plan-days">
        <CalendarDays class="h-5 w-5 shrink-0" />
        <span>{totalDays} Days</span>
        </span>
      </div>

      <div class="space-y-3">

        <h3 class="text-2xl font-semibold">
          {title}
        </h3>

        <p
          class="
            leading-7
            text-[var(--color-muted)]
          "
        >
          {description}
        </p>

      </div>

    </div>

    <div class="mt-8">
      <Button
        href={href}
        variant="ghost"
      >
        Start Reading →
      </Button>
    </div>

  </div>

</Card>

<style>
.plan-days {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;

  padding: 0.5rem 1rem;

  border-radius: 999px;
  border: 1px solid var(--color-border);
  background: var(--color-bg-soft);

  color: var(--color-primary);

  font-size: 0.875rem;
  font-weight: 600;
  line-height: 1;
}
</style>