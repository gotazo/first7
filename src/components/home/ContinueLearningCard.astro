---
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";
import Badge from "../ui/Badge.astro";

import type { CollectionEntry } from "astro:content";

interface Props {
  teaching: CollectionEntry<"teachings">;
}

const { teaching } = Astro.props;

const href = `/teachings/${teaching.id}`;
---

<Card class="h-full">

  <div class="flex h-full flex-col">

    <!-- Scripture -->

    <p
      class="
        text-xs
        uppercase
        tracking-[0.18em]
        text-[var(--color-primary)]
      "
    >
      {teaching.data.scripture.ref}
    </p>

    <!-- Title -->

    <h3
      class="
        mt-3
        text-2xl
        font-semibold
      "
    >
      {teaching.data.title}
    </h3>

    <!-- Summary -->

    <p
      class="
        mt-3
        flex-1
        text-[var(--color-muted)]
      "
    >
      {teaching.data.summary}
    </p>

    <!-- Topics -->

    <div
      class="
        mt-6
        flex
        flex-wrap
        gap-2
      "
    >

      {
        teaching.data.topics
          .slice(0, 3)
          .map((topic) => (

            <Badge>
              {topic}
            </Badge>

          ))
      }

    </div>

    <!-- CTA -->

    <div class="mt-8">

      <Button
        href={href}
        variant="ghost"
      >
        Read Teaching →
      </Button>

    </div>

  </div>

</Card>