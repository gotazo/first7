---
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";
import Badge from "../ui/Badge.astro";

import { BookOpen } from "../../lib/icons";

import type { CollectionEntry } from "astro:content";

interface Props {
  teaching: CollectionEntry<"teachings">;
}

const { teaching } = Astro.props;

const href = `/teachings/${teaching.id}`;
---

<Card
  class="
    group
    h-full
    transition-all
    duration-300
    hover:-translate-y-1
    hover:shadow-xl
  "
>

  <div class="flex h-full flex-col">

    <div class="flex">

      <span class="scripture-badge">

        <BookOpen class="h-4 w-4 shrink-0" />

        <span>
          {teaching.data.scripture.ref}
        </span>

      </span>

    </div>

    <h3
      class="
        mt-5
        text-2xl
        font-semibold
      "
    >
      {teaching.data.title}
    </h3>

    <p
      class="
        mt-4
        flex-1
        leading-7
        text-[var(--color-muted)]
      "
    >
      {teaching.data.summary}
    </p>

    <div
      class="
        mt-6
        flex
        flex-wrap
        gap-2
      "
    >

      {
        teaching.data.topics
          .slice(0, 3)
          .map((topic) => (

            <Badge>
              {topic}
            </Badge>

          ))
      }

    </div>

    <div class="mt-auto pt-8">

      <Button
        href={href}
        variant="ghost"
      >
        Read Teaching →
      </Button>

    </div>

  </div>

</Card>

<style>
.scripture-badge {
  display: inline-flex;
  align-items: center;
  gap: .5rem;

  padding: .5rem 1rem;

  border-radius: 999px;

  border: 1px solid var(--color-border);

  background: var(--color-bg-soft);

  color: var(--color-primary);

  font-size: .875rem;

  font-weight: 600;

  line-height: 1;
}
</style>