---
import type { CollectionEntry } from "astro:content";
import Card from "../ui/Card.astro";

interface Props {
  verse: CollectionEntry<"verseJar">;
}

const { verse } = Astro.props;

const length = verse.data.verse.length;

const verseSize =
  length > 240
    ? "text-lg lg:text-xl"
    : length > 160
      ? "text-xl lg:text-2xl"
      : "text-2xl lg:text-3xl";
---

<Card
  href={`/verse-jar/${verse.id}`}
  padding="lg"
  class="
    group
    relative
    border-[rgba(214,179,106,.25)]
    transition-all
    hover:border-[var(--color-primary)]
  "
>

  <div
    class="
      absolute
      inset-0
      bg-gradient-to-br
      from-[rgba(214,179,106,.08)]
      via-transparent
      to-transparent
      pointer-events-none
    "
  />

  <div class="relative z-10 flex flex-col">

    <div class="flex items-start justify-between">

      <div>

        <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-primary)]">
          Today's Scripture
        </p>

        <p class="mt-2 text-sm text-[var(--color-text-muted)]">
          Verse of the Day
        </p>

      </div>

      <span
        class="
          text-5xl
          text-[var(--color-primary)]
          opacity-40
        "
      >
        ❝
      </span>

    </div>

    <blockquote
      class:list={[
        "mt-8 font-serif italic leading-relaxed text-[var(--color-text)] break-words",
        verseSize,
      ]}
    >
      {verse.data.verse}
    </blockquote>

    <div class="mt-8 border-t border-[var(--color-border)] pt-6">

      <footer
        class="
          flex
          flex-col
          gap-4
          sm:flex-row
          sm:items-center
          sm:justify-between
        "
      >

        <div>

          <p class="font-semibold text-[var(--color-primary)]">
            {verse.data.reference}
          </p>

          <p class="mt-1 text-sm capitalize text-[var(--color-text-muted)]">
            {verse.data.category.replaceAll("-", " ")}
          </p>

        </div>

        <span
          class="
            text-sm
            font-medium
            text-[var(--color-primary)]
            group-hover:translate-x-1
            transition-transform
          "
        >
          Read Verse →
        </span>

      </footer>

    </div>

  </div>

</Card>