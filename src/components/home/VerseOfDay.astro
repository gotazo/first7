---
import { getCollection } from "astro:content";

import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
import VerseLink from "../VerseLink.astro";

const verses = await getCollection("verseJar");

// Ready for daily GitHub builds
const dayNumber = Math.floor(Date.now() / 86400000);

const verse =
  verses[dayNumber % verses.length];
---

<Section
  eyebrow="Daily Scripture"
  title="Verse of the Day"
  description="Spend a few quiet moments reading and reflecting on God's Word."
>

  <div
    class="
      mx-auto
      max-w-3xl
      rounded-3xl
      border
      border-[var(--color-border)]
      bg-[var(--color-bg-soft)]
      px-8
      py-12
      text-center
    "
  >

    <p
      class="
        font-serif
        text-2xl
        leading-relaxed
        md:text-3xl
      "
    >
      “{verse.data.verse}”
    </p>

    <div class="mt-8">

      <p
        class="
          text-lg
          font-medium
          text-[var(--color-primary)]
        "
      >
        <VerseLink verse={verse.data.reference} />
      </p>

      <p
        class="
          mt-2
          text-sm
          uppercase
          tracking-[0.2em]
          text-[var(--color-muted)]
        "
      >
        {verse.data.category.replace("-", " ")}
      </p>

    </div>

    <div
      class="
        mt-10
        flex
        flex-wrap
        justify-center
        gap-4
      "
    >

      <Button
        href={`/verse-jar/${verse.id}`}
      >
        Read Full Verse →
      </Button>

      <Button
        href="/verse-jar"
        variant="ghost"
      >
        Browse Verse Jar
      </Button>

    </div>

  </div>

</Section>