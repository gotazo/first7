---
import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
import PlanCard from "./PlanCard.astro";

import {
  getStartPlanSummaries,
} from "../../lib/start-plans";

const plans = await getStartPlanSummaries();

const featuredPlans = plans.slice(0, 3);
---

<Section
  eyebrow="Start Growing"
  title="7-Day Bible Plans"
  description="Build lasting habits through short, practical Bible reading plans rooted in Scripture."
  centered
>

  <div
    class="
      grid
      gap-6
      md:grid-cols-2
      lg:grid-cols-3
    "
  >
    {
      featuredPlans.map((plan) => (
        <PlanCard plan={plan} />
      ))
    }
  </div>

  <div class="mt-10 flex justify-center">
    <Button
      href="/plans"
      variant="secondary"
      size="lg"
    >
      Explore All Bible Plans
    </Button>
  </div>

</Section>