---
import { getCollection } from "astro:content";

const teachings = await getCollection("teachings");

const topics = Array.from(new Set(teachings.flatMap((t) => t.data.topics))).sort();
const currentPath = Astro.url.pathname.replace(/\/$/, "");

const topicLinks = topics
  .map((topic) => {
    const firstTeaching = teachings
      .filter((t) => t.data.topics.includes(topic))
      .sort((a, b) => a.data.title.localeCompare(b.data.title))[0];

    return {
      topic,
      href: firstTeaching ? `/teachings/${firstTeaching.id}` : "/teachings",
    };
  })
  .filter((link) => link.href !== "/teachings");
---

<aside class="hidden lg:block w-56 shrink-0 sticky top-24 self-start">

  <p class="text-sm font-medium mb-4">
    Topics
  </p>

  <nav class="space-y-2">

    <a
      href="/teachings"
      class={`block text-sm ${
        currentPath === "/teachings"
          ? "text-white font-medium"
          : "text-[var(--color-muted)]"
      }`}
    >
      All Teachings
    </a>

    {topicLinks.map(({ topic, href }) => (
      <a
        href={href}
        class={`block text-sm ${
          currentPath === href
            ? "text-white font-medium"
            : "text-[var(--color-muted)]"
        }`}
      >
        {topic}
      </a>
    ))}

  </nav>

</aside>
