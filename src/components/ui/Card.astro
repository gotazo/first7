---
interface Props {
  as?: keyof HTMLElementTagNameMap;
  href?: string;
  padding?: "none" | "sm" | "md" | "lg";
  hover?: boolean;
  class?: string;
}

const {
  as,
  href,
  padding = "md",
  hover = true,
  class: className = "",
} = Astro.props;

const Component = href ? "a" : as ?? "article";

const paddingClasses = {
  none: "",
  sm: "p-4",
  md: "p-6",
  lg: "p-8",
} as const;
---

<Component
  href={href}
  class:list={[
    "group block rounded-2xl",
    "border border-[var(--color-border)]",
    "bg-[var(--color-bg-soft)]",
    "transition-all duration-300",
    hover && [
      "hover:-translate-y-1",
      "hover:border-[var(--color-primary)]",
      "hover:shadow-lg",
    ],
    paddingClasses,
    className,
  ]}
>
  <slot />
</Component>