---
interface Props {
  variant?: "default" | "success" | "warning";
  class?: string;
}

const {
  variant = "default",
  class: className = "",
} = Astro.props;

const variants = {
  default: [
    "bg-[var(--color-bg-elevated)]",
    "text-[var(--color-text)]",
  ],
  success: [
    "bg-green-900/20",
    "text-green-400",
  ],
  warning: [
    "bg-amber-900/20",
    "text-amber-400",
  ],
};
---

<span
  class:list={[
    "inline-flex items-center",
    "rounded-full",
    "px-3 py-1",
    "text-xs",
    "font-semibold",
    "tracking-wide",
    variants[variant],
    className,
  ]}
>
  <slot />
</span>