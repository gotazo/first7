---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const {
  eyebrow,
  title,
  description,
  align = "center",
} = Astro.props;

const alignment = {
  left: "text-left",
  center: "text-center",
};
---

<header
  class:list={[
    "mx-auto max-w-3xl space-y-4",
    alignment[align],
  ]}
>
  {
    eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--color-primary)]">
        {eyebrow}
      </p>
    )
  }

  <h2 class="text-3xl font-bold tracking-tight md:text-5xl">
    {title}
  </h2>

  {
    description && (
      <p class="text-lg text-[var(--color-muted)]">
        {description}
      </p>
    )
  }
</header>