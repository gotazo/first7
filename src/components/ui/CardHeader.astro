---
import Badge from "./Badge.astro";

interface Props {
  eyebrow?: string;
  badge?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  class?: string;
}

const {
  eyebrow,
  badge,
  title,
  description,
  align = "left",
  class: className = "",
} = Astro.props;
---

<div
  class:list={[
    "space-y-3",
    align === "center" && "text-center",
    className,
  ]}
>
  {(eyebrow || badge) && (
    <div
      class:list={[
        "flex items-center gap-2",
        align === "center" && "justify-center",
      ]}
    >
      {eyebrow && (
        <span
          class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-primary)]"
        >
          {eyebrow}
        </span>
      )}

      {badge && (
        <Badge>{badge}</Badge>
      )}
    </div>
  )}

  <h3
    class="text-xl font-semibold tracking-tight text-[var(--color-text)]"
  >
    {title}
  </h3>

  {description && (
    <p
      class="leading-7 text-[var(--color-text-muted)]"
    >
      {description}
    </p>
  )}

  <slot />
</div>