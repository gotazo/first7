<div class="mx-auto w-full max-w-[720px] px-4 sm:px-6 space-y-8">

  <div class="p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 text-sm text-[var(--color-muted)]">
    <strong>Quick guide:</strong><br />
    Enter your income. Review the amounts. Click “Save Month” to add to your funds.
  </div>

  <div class="rounded-2xl border border-[var(--color-border)] p-5 text-sm text-[var(--color-muted)] space-y-2">
    <p class="font-medium text-[var(--color-text)]">How to use</p>
    <p>1. Enter your monthly income.</p>
    <p>2. Review how your money is divided.</p>
    <p>3. Click “Save Month” to add to your funds.</p>
    <p class="pt-2">Saving/Investment is optional. You can turn it on or off.</p>
  </div>

  <div class="rounded-2xl border border-[var(--color-border)] p-5 space-y-4">
    <label class="block text-sm font-medium">Monthly Income</label>

    <input id="income" type="number" placeholder="Enter your income"
      class="w-full px-4 py-4 text-base rounded-xl border border-[var(--color-border)] bg-transparent" />

    <div class="flex justify-between items-center text-sm">
      <span class="text-[var(--color-muted)]">Saving/Investment (10%)</span>
      <button id="futureToggle"
        class="w-14 h-7 bg-[var(--color-border)] rounded-full relative transition-colors duration-200">
        <span id="toggleDot"
          class="absolute top-1 left-1 w-5 h-5 bg-white rounded-full transition-transform duration-200"></span>
      </button>
    </div>
  </div>

  <div class="rounded-2xl border border-[var(--color-border)] p-5 space-y-1">
    <div class="flex justify-between text-base py-1"><span>Tithe</span><span id="tithe">₹0</span></div>
    <div class="flex justify-between text-base py-1"><span>Giving</span><span id="help">₹0</span></div>
    <div class="flex justify-between text-base py-1"><span>Emergency</span><span id="emergency">₹0</span></div>
    <div class="flex justify-between text-base py-1"><span>Savings/Investment</span><span id="future">₹0</span></div>
    <div class="flex justify-between font-semibold border-t pt-2 text-base">
      <span>Living</span><span id="living">₹0</span>
    </div>
  </div>

  <div class="flex flex-col sm:flex-row gap-3">
    <button id="saveBtn" class="btn flex-1 py-3 text-base rounded-xl">
      Save Month
    </button>
    <button id="resetBtn" class="btn-secondary px-4 py-3 text-base rounded-xl">
      Reset
    </button>
  </div>

  <div class="rounded-2xl border p-5 space-y-2">
    <div class="flex justify-between"><span>Giving Fund</span><span id="helpFund">₹0</span></div>
    <p class="text-xs text-[var(--color-muted)]">+₹<span id="helpPending">0</span> pending</p>
  </div>

  <div class="rounded-2xl border p-5 space-y-2">
    <div class="flex justify-between"><span>Emergency Fund</span><span id="emergencyFund">₹0</span></div>
    <p class="text-xs text-[var(--color-muted)]">+₹<span id="emergencyPending">0</span> pending</p>
  </div>

  <div class="rounded-2xl border border-[var(--color-border)] p-5 space-y-4">
    <p class="font-medium text-base">Emergency Fund Goal</p>

    <input id="goalInput" type="number" placeholder="Enter your goal amount"
      class="w-full px-4 py-3 text-base rounded-lg border border-[var(--color-border)] bg-transparent" />

    <div class="w-full h-3 bg-[var(--color-border)] rounded-full overflow-hidden">
      <div id="goalBar" class="h-full bg-[var(--color-primary)] w-0 transition-all duration-300"></div>
    </div>

    <p class="text-sm text-[var(--color-muted)]">
      <span id="goalCurrent">₹0</span> of <span id="goalTarget">₹0</span>
    </p>
  </div>

  <div class="rounded-2xl border border-[var(--color-border)] p-5 space-y-4">
    <h3 class="font-medium">Monthly History</h3>
    <div id="historyList" class="space-y-2 text-sm"></div>
  </div>

  <div class="rounded-2xl border border-[var(--color-border)] p-5 space-y-3">
    <p class="text-sm font-medium">Backup</p>

    <div class="flex gap-3 flex-wrap">
      <button id="exportBtn" class="btn px-4 py-2 rounded-lg text-sm">
        Export Data
      </button>

      <label class="btn-secondary px-4 py-2 rounded-lg text-sm cursor-pointer">
        Import Data
        <input type="file" id="importInput" class="hidden" />
      </label>
    </div>

    <p class="text-xs text-[var(--color-muted)]">
      Your data is stored locally. Export regularly.
    </p>
  </div>

</div>


<script>

document.addEventListener("DOMContentLoaded", () => {

  type FinanceData = {
    funds: {
      help: number;
      emergency: number;
    };
    history: Record<string, any>;
    settings: {
      includeFuture?: boolean;
      goal?: number;
      lastIncome?: number;
    };
  };

  function loadData(): FinanceData {
    return JSON.parse(
      localStorage.getItem("finance-data") ||
      '{"funds":{"help":0,"emergency":0},"history":{},"settings":{}}'
    );
  }

  function saveData(data: FinanceData) {
    localStorage.setItem("finance-data", JSON.stringify(data));
  }

  function resetData() {
    localStorage.removeItem("finance-data");
  }

  function calculate(
    income: number,
    includeFuture: boolean
  ) {

    const tithe = income * 0.10;
    const help = income * 0.05;
    const emergency = income * 0.05;
    const future = includeFuture ? income * 0.10 : 0;

    const living =
      income - (tithe + help + emergency + future);

    return {
      income,
      tithe,
      help,
      emergency,
      future,
      living
    };

  }

  let data = loadData();

  /* ELEMENTS */

  const incomeEl =
    document.getElementById("income") as HTMLInputElement;

  const toggleEl =
    document.getElementById("futureToggle") as HTMLButtonElement;

  const dot =
    document.getElementById("toggleDot") as HTMLElement;

  const titheEl =
    document.getElementById("tithe") as HTMLElement;

  const helpEl =
    document.getElementById("help") as HTMLElement;

  const emergencyEl =
    document.getElementById("emergency") as HTMLElement;

  const futureEl =
    document.getElementById("future") as HTMLElement;

  const livingEl =
    document.getElementById("living") as HTMLElement;

  const helpPendingEl =
    document.getElementById("helpPending") as HTMLElement;

  const emergencyPendingEl =
    document.getElementById("emergencyPending") as HTMLElement;

  const helpFundEl =
    document.getElementById("helpFund") as HTMLElement;

  const emergencyFundEl =
    document.getElementById("emergencyFund") as HTMLElement;

  const saveBtn =
    document.getElementById("saveBtn") as HTMLButtonElement;

  const resetBtn =
    document.getElementById("resetBtn") as HTMLButtonElement;

  const exportBtn =
    document.getElementById("exportBtn") as HTMLButtonElement;

  const importInput =
    document.getElementById("importInput") as HTMLInputElement;

  const historyList =
    document.getElementById("historyList") as HTMLElement;

  const goalInput =
    document.getElementById("goalInput") as HTMLInputElement;

  const goalBar =
    document.getElementById("goalBar") as HTMLElement;

  const goalCurrent =
    document.getElementById("goalCurrent") as HTMLElement;

  const goalTarget =
    document.getElementById("goalTarget") as HTMLElement;

  /* SAFETY */

  if (
    !incomeEl || !toggleEl || !dot ||
    !titheEl || !helpEl || !emergencyEl ||
    !futureEl || !livingEl ||
    !helpPendingEl || !emergencyPendingEl ||
    !helpFundEl || !emergencyFundEl ||
    !saveBtn || !resetBtn ||
    !exportBtn || !importInput ||
    !historyList ||
    !goalInput || !goalBar ||
    !goalCurrent || !goalTarget
  ) return;

  /* SETTINGS */

  let includeFuture =
    data.settings.includeFuture ?? false;

  let goal =
    data.settings.goal || 0;

  incomeEl.value =
    String(data.settings.lastIncome || "");

  goalInput.value =
    String(goal || "");

  function format(v: number) {
    return "₹" + Math.round(v || 0);
  }

  function updateToggle() {

    if (includeFuture) {

      toggleEl.classList.add(
        "bg-[var(--color-primary)]"
      );

      toggleEl.classList.remove(
        "bg-[var(--color-border)]"
      );

      dot.style.transform =
        "translateX(24px)";

    } else {

      toggleEl.classList.add(
        "bg-[var(--color-border)]"
      );

      toggleEl.classList.remove(
        "bg-[var(--color-primary)]"
      );

      dot.style.transform =
        "translateX(0)";
    }

  }

  toggleEl.addEventListener("click", () => {

    includeFuture = !includeFuture;

    data.settings.includeFuture =
      includeFuture;

    updateToggle();

    runCalc();

  });

  function runCalc() {

    const income =
      Number(incomeEl.value || 0);

    const r = calculate(
      income,
      includeFuture
    );

    titheEl.innerText =
      format(r.tithe);

    helpEl.innerText =
      format(r.help);

    emergencyEl.innerText =
      format(r.emergency);

    futureEl.innerText =
      format(r.future);

    livingEl.innerText =
      format(r.living);

    helpPendingEl.innerText =
      String(Math.round(r.help));

    emergencyPendingEl.innerText =
      String(Math.round(r.emergency));

    return r;

  }

  function updateFunds() {

    helpFundEl.innerText =
      format(data.funds.help);

    emergencyFundEl.innerText =
      format(data.funds.emergency);

  }

  function updateGoal() {

    goal =
      Number(goalInput.value || 0);

    data.settings.goal = goal;

    const current =
      data.funds.emergency;

    goalCurrent.innerText =
      format(current);

    goalTarget.innerText =
      format(goal);

    const percent = goal
      ? Math.min((current / goal) * 100, 100)
      : 0;

    goalBar.style.width =
      percent + "%";

    saveData(data);

  }

  function renderHistory() {

    historyList.innerHTML = "";

    Object.entries(data.history || {})
      .reverse()
      .forEach(([month, val]) => {

        const entry = val as any;

        const div =
          document.createElement("div");

        div.className =
          "flex justify-between border-b pb-1";

        div.innerHTML = `
          <span>${month}</span>
          <span>${format(entry.income)}</span>
        `;

        historyList.appendChild(div);

      });

  }

  incomeEl.addEventListener(
    "input",
    runCalc
  );

  goalInput.addEventListener(
    "input",
    updateGoal
  );

  saveBtn.addEventListener("click", () => {

    const r = runCalc();

    const month =
      new Date()
        .toISOString()
        .slice(0, 7);

    data.settings.lastIncome =
      r.income;

    data.funds.help +=
      r.help;

    data.funds.emergency +=
      r.emergency;

    data.history[month] = r;

    saveData(data);

    updateFunds();
    updateGoal();
    renderHistory();

  });

  resetBtn.addEventListener("click", () => {

    if (confirm("Reset all data?")) {

      resetData();

      location.reload();

    }

  });

  exportBtn.addEventListener("click", () => {

    const blob = new Blob(
      [JSON.stringify(data)],
      { type: "application/json" }
    );

    const url =
      URL.createObjectURL(blob);

    const a =
      document.createElement("a");

    a.href = url;

    a.download =
      "finance-data.json";

    a.click();

    URL.revokeObjectURL(url);

  });

  importInput.addEventListener(
    "change",
    (e: Event) => {

      const target =
        e.target as HTMLInputElement;

      const file =
        target.files?.[0];

      if (!file) return;

      const reader =
        new FileReader();

      reader.onload = (ev) => {

        const result =
          ev.target?.result as string;

        data =
          JSON.parse(result);

        saveData(data);

        location.reload();

      };

      reader.readAsText(file);

    }
  );

  updateToggle();
  updateFunds();
  updateGoal();
  renderHistory();
  runCalc();

});

</script>
