---
import ToolShare from "../shared/ToolShare.astro";

import { biblicalNames } from "./names";

import { prefixes } from "./data/prefixes";
import { roots } from "./data/roots";
import { suffixes } from "./data/suffixes";

import { meaningParts }
from "./data/meaningParts";
---

<div class="mx-auto w-full max-w-[720px] px-4 sm:px-6 space-y-8">

  <!-- CONTROLS -->
  <div class="card p-5 space-y-5">

    <!-- MODE -->
    <div class="space-y-2">

      <label
        for="modeFilter"
        class="block text-sm font-medium"
      >
        Generation Mode
      </label>

      <div class="relative">

        <select
          id="modeFilter"
          class="w-full appearance-none rounded-xl border border-[var(--color-border)]
          bg-[var(--color-bg-soft)]
          text-[var(--color-text)]
          px-4 py-4 pr-12 text-base
          shadow-sm
          transition
          focus:outline-none
          focus:ring-2
          focus:ring-[var(--color-primary)]
          focus:border-[var(--color-primary)]"
        >
          <option value="real">
            Real Biblical Names
          </option>

          <option value="style">
            Biblical-Style Names
          </option>

        </select>

        <!-- ARROW -->
        <div
          class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-[var(--color-muted)]"
        >

          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >

            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 9l-7 7-7-7"
            />

          </svg>

        </div>

      </div>

    </div>

    <!-- GENDER -->
    <div
      id="genderWrapper"
      class="space-y-2"
    >

      <label
        for="genderFilter"
        class="block text-sm font-medium"
      >
        Gender
      </label>

      <div class="relative">

        <select
          id="genderFilter"
          class="w-full appearance-none rounded-xl border border-[var(--color-border)]
          bg-[var(--color-bg-soft)]
          text-[var(--color-text)]
          px-4 py-4 pr-12 text-base
          shadow-sm
          transition
          focus:outline-none
          focus:ring-2
          focus:ring-[var(--color-primary)]
          focus:border-[var(--color-primary)]"
        >

          <option value="all">
            All
          </option>

          <option value="male">
            Male
          </option>

          <option value="female">
            Female
          </option>

        </select>

        <!-- ARROW -->
        <div
          class="pointer-events-none absolute inset-y-0 right-4 flex items-center text-[var(--color-muted)]"
        >

          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >

            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 9l-7 7-7-7"
            />

          </svg>

        </div>

      </div>

    </div>

    <!-- BUTTON -->
    <button
      id="generateBtn"
      class="btn w-full py-4 rounded-xl font-medium"
    >
      Generate Name
    </button>

  </div>

  <!-- RESULT -->
  <div
    id="resultCard"
    class="card p-8 text-center space-y-5"
  >

    <!-- BADGE -->
    <div
      id="modeBadge"
      class="inline-flex mx-auto px-3 py-1 rounded-full text-xs font-medium
      bg-[var(--color-primary)]/10
      text-[var(--color-primary)]"
    >
      Real Biblical Name
    </div>

    <!-- NAME -->
    <div>

      <p class="text-sm text-[var(--color-muted)]">
        Generated Name
      </p>

      <h2
        id="name"
        class="text-4xl font-semibold mt-3 tracking-tight"
      >
        Elijah
      </h2>

    </div>

    <!-- DETAILS -->
    <div class="space-y-2">

      <p
        id="meaning"
        class="text-lg"
      >
        My God is Yahweh
      </p>

      <p
        id="verse"
        class="text-sm text-[var(--color-muted)]"
      >
        1 Kings 17:1
      </p>

    </div>

  </div>

  <!-- ACTIONS -->
  <div class="flex flex-wrap gap-3">

    <button
      id="copyBtn"
      class="btn-secondary px-4 py-3 rounded-xl text-sm"
    >
      Copy Name
    </button>

    <ToolShare
      title="Biblical Name Generator"
    />

  </div>

</div>

<script define:vars={{
  biblicalNames,
  prefixes,
  roots,
  suffixes,
  meaningParts
}}>

document.addEventListener(
  "DOMContentLoaded",
  () => {

    const generateBtn =
      document.getElementById("generateBtn");

    const copyBtn =
      document.getElementById("copyBtn");

    const genderFilter =
      document.getElementById("genderFilter");

    const modeFilter =
      document.getElementById("modeFilter");

    const genderWrapper =
      document.getElementById("genderWrapper");

    const nameEl =
      document.getElementById("name");

    const meaningEl =
      document.getElementById("meaning");

    const verseEl =
      document.getElementById("verse");

    const modeBadge =
      document.getElementById("modeBadge");

    if (
      !generateBtn ||
      !copyBtn ||
      !genderFilter ||
      !modeFilter ||
      !genderWrapper ||
      !nameEl ||
      !meaningEl ||
      !verseEl ||
      !modeBadge
    ) return;

    function random(arr = []) {

      return arr[
        Math.floor(
          Math.random() * arr.length
        )
      ];

    }

    function updateModeUI() {

      const mode =
        modeFilter?.value || "real";

      if (mode === "style") {

        genderWrapper.classList.add(
          "hidden"
        );

      } else {

        genderWrapper.classList.remove(
          "hidden"
        );

      }

    }

    function generate() {

      const mode =
        modeFilter?.value || "real";

      // STYLE MODE
      if (mode === "style") {

        const prefix =
          random(prefixes);

        const root =
          random(roots);

        const suffix =
          random(suffixes);

        const generated =
          `${prefix}${root}${suffix}`;

        const partsMeaning = [

          meaningParts[prefix],
          meaningParts[root],
          meaningParts[suffix]

        ].filter(Boolean);

        nameEl.textContent =
          generated;

        meaningEl.textContent =
          partsMeaning.join(" • ");

        verseEl.textContent =
          "Biblical-style generated name";

        modeBadge.textContent =
          "Biblical-Style Name";

        return;

      }

      // REAL MODE
      const gender =
        genderFilter?.value || "all";

      let filtered =
        biblicalNames;

      if (gender !== "all") {

        filtered =
          filtered.filter(
            (n) => n.gender === gender
          );

      }

      const randomName =
        filtered[
          Math.floor(
            Math.random() *
            filtered.length
          )
        ];

      nameEl.textContent =
        randomName.name;

      meaningEl.textContent =
        randomName.meaning;

      verseEl.textContent =
        randomName.verse;

      modeBadge.textContent =
        "Real Biblical Name";

    }

    modeFilter.addEventListener(
      "change",
      updateModeUI
    );

    generateBtn.addEventListener(
      "click",
      generate
    );

    copyBtn.addEventListener(
      "click",
      async () => {

        await navigator.clipboard.writeText(
          nameEl.textContent || ""
        );

        const original =
          copyBtn.textContent;

        copyBtn.textContent =
          "Copied!";

        setTimeout(() => {

          copyBtn.textContent =
            original;

        }, 1500);

      }
    );

    updateModeUI();

  }
);

</script>