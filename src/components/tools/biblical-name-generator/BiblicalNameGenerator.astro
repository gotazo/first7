---
import ToolShare from "../shared/ToolShare.astro";

import { biblicalNames } from "./names";

import { prefixes } from "./data/prefixes";
import { roots } from "./data/roots";
import { suffixes } from "./data/suffixes";

---

<div class="mx-auto w-full max-w-[720px] px-4 sm:px-6 space-y-8">

  <!-- CONTROLS -->
  <div class="card p-5 space-y-5">

    <!-- MODE -->
    <div class="space-y-2">

      <label
        for="modeFilter"
        class="block text-sm font-medium"
      >
        Generation Mode
      </label>

      <div class="relative">

        <select
          id="modeFilter"
          class="tool-select"
        >

          <option value="real">
            Real Biblical Names
          </option>

          <option value="style">
            Biblical-Style Names
          </option>

        </select>

      </div>

    </div>

    <!-- GENDER -->
    <div
      id="genderWrapper"
      class="space-y-2"
    >

      <label
        for="genderFilter"
        class="block text-sm font-medium"
      >
        Gender
      </label>

      <select
        id="genderFilter"
        class="tool-select"
      >

        <option value="all">
          All
        </option>

        <option value="male">
          Male
        </option>

        <option value="female">
          Female
        </option>

      </select>

    </div>

    <!-- THEME -->
    <div class="space-y-2">

      <label
        for="themeFilter"
        class="block text-sm font-medium"
      >
        Theme
      </label>

      <select
        id="themeFilter"
        class="tool-select"
      >

        <option value="all">
          All Themes
        </option>

        <option value="warrior">
          Warrior
        </option>

        <option value="peace">
          Peace
        </option>

        <option value="wisdom">
          Wisdom
        </option>

        <option value="faith">
          Faith
        </option>

        <option value="leadership">
          Leadership
        </option>

        <option value="grace">
          Grace
        </option>

      </select>

    </div>

    <!-- BUTTON -->
    <button
      id="generateBtn"
      class="btn w-full py-4 rounded-xl font-medium"
    >
      Generate Name
    </button>

  </div>

  <!-- RESULT -->
  <div
    class="card p-8 text-center space-y-5"
  >

    <div
      id="modeBadge"
      class="inline-flex mx-auto px-3 py-1 rounded-full text-xs font-medium
      bg-[var(--color-primary)]/10
      text-[var(--color-primary)]"
    >
      Real Biblical Name
    </div>

    <div>

      <p class="text-sm text-[var(--color-muted)]">
        Generated Name
      </p>

      <h2
        id="name"
        class="text-4xl font-semibold mt-3 tracking-tight"
      >
        Elijah
      </h2>

    </div>

    <div class="space-y-2">

      <p
        id="meaning"
        class="text-lg"
      >
        My God is Yahweh
      </p>

      <p
        id="verse"
        class="text-sm text-[var(--color-muted)]"
      >
        1 Kings 17:1
      </p>

    </div>

  </div>

  <!-- ACTIONS -->
  <div class="flex flex-wrap gap-3">

    <button
      id="copyBtn"
      class="btn-secondary px-4 py-3 rounded-xl text-sm"
    >
      Copy Name
    </button>

    <ToolShare
      title="Biblical Name Generator"
    />

  </div>

</div>

<script is:inline define:vars={{
  biblicalNames,
  prefixes,
  roots,
  suffixes
}}>

document.addEventListener(
  "DOMContentLoaded",
  () => {

    const generateBtn =
      document.getElementById("generateBtn");

    const copyBtn =
      document.getElementById("copyBtn");

    const genderFilter =
      document.getElementById("genderFilter");

    const modeFilter =
      document.getElementById("modeFilter");

    const themeFilter =
      document.getElementById("themeFilter");

    const genderWrapper =
      document.getElementById("genderWrapper");

    const nameEl =
      document.getElementById("name");

    const meaningEl =
      document.getElementById("meaning");

    const verseEl =
      document.getElementById("verse");

    const modeBadge =
      document.getElementById("modeBadge");

    if (
      !generateBtn ||
      !copyBtn ||
      !genderFilter ||
      !modeFilter ||
      !themeFilter ||
      !genderWrapper ||
      !nameEl ||
      !meaningEl ||
      !verseEl ||
      !modeBadge
    ) return;

    function random(arr = []) {

      return arr[
        Math.floor(
          Math.random() * arr.length
        )
      ];

    }

    function updateModeUI() {

      const mode =
        modeFilter.value;

      if (mode === "style") {

        genderWrapper.classList.add(
          "hidden"
        );

      } else {

        genderWrapper.classList.remove(
          "hidden"
        );

      }

    }

    function generate() {

      const mode =
        modeFilter.value;

      const theme =
        themeFilter.value;

      // STYLE MODE
      if (mode === "style") {

        const prefix =
  random(prefixes);

const root =
  random(roots);

const suffix =
  random(suffixes);

const generated =
  `${prefix.part}${root.part}${suffix.part}`;

const generatedMeaning = [

  prefix.meaning,
  root.meaning,
  suffix.meaning

].filter(Boolean);

nameEl.textContent =
  generated;

meaningEl.textContent =
  generatedMeaning.join(" • ");

verseEl.textContent =
  "Biblical-style generated name";

        modeBadge.textContent =
          "Biblical-Style Name";

        return;

      }

      // REAL MODE
      const gender =
        genderFilter.value;

      let filtered =
        biblicalNames;

      if (gender !== "all") {

        filtered =
          filtered.filter(
            (n) => n.gender === gender
          );

      }

      if (theme !== "all") {

        filtered =
          filtered.filter(
            (n) =>
              n.categories?.includes(theme)
          );

      }

      if (!filtered.length) {

        filtered =
          biblicalNames;

      }

      const randomName =
        filtered[
          Math.floor(
            Math.random() *
            filtered.length
          )
        ];

      nameEl.textContent =
        randomName.name;

      meaningEl.textContent =
        randomName.meaning;

      verseEl.textContent =
        randomName.verse;

      modeBadge.textContent =
        "Real Biblical Name";

    }

    modeFilter.addEventListener(
      "change",
      updateModeUI
    );

    generateBtn.addEventListener(
      "click",
      generate
    );

    copyBtn.addEventListener(
      "click",
      async () => {

        await navigator.clipboard.writeText(
          nameEl.textContent || ""
        );

        const original =
          copyBtn.textContent;

        copyBtn.textContent =
          "Copied!";

        setTimeout(() => {

          copyBtn.textContent =
            original;

        }, 1500);

      }
    );

    updateModeUI();

  }
);

</script>

<style>
  .tool-select {
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-soft);
    color: var(--color-text);
    padding: 1rem;
    font-size: 1rem;
  }
</style>
