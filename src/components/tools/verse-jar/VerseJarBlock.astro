---
interface Props {
  category?: string;
  reference: string;
  verse: string;
}

const {
  reference,
  verse,
} = Astro.props;
---

<section class="verse-jar-block">

  <blockquote class="verse-text">
    {verse}
  </blockquote>

  <footer class="verse-reference">
    {reference}
  </footer>

</section>

<style>

.verse-jar-block {

  border-left:
    4px solid
    var(--color-primary);

  border-radius:
    0
    1rem
    1rem
    0;

  background:
    linear-gradient(
      to right,
      color-mix(
        in srgb,
        var(--color-primary) 8%,
        transparent
      ),
      transparent
    );

  padding:
    1.5rem
    1.5rem
    1.5rem
    1.25rem;

}

.verse-text {

  margin: 0;

  font-size: clamp(
    1.25rem,
    2vw,
    2rem
  );

  line-height: 1.8;

  font-style: italic;

  font-weight: 400;

}

.verse-reference {

  margin-top: 1.25rem;

  font-size: 1.1rem;

  color:
    var(--color-muted);

  font-style: italic;

}

</style>