---
interface Props {
  idle?: boolean;
}

const { idle = true } = Astro.props;
---

<div
  id="scriptureCard"
  class:list={[
    "card-wrapper",
    { idle }
  ]}
  role="button"
  tabindex="0"
>
  <div class="card-stack" aria-hidden="true">

    <div class="card back back-2"></div>
    <div class="card back back-1"></div>

    <div class="card front">

      <div class="card-inner">

        <div class="brand">
          <span>FIRST7</span>
        </div>

        <div class="icon-wrap">

          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              d="M3 4h13a2 2 0 0 1 2 2v16l-3-2-3 2-3-2-3 2V6a2 2 0 0 1 2-2Z"
            />
            <path d="M9 8h5" />
            <path d="M11.5 6v5" />
          </svg>

        </div>

        <div class="ready">
          READY TO DRAW?
        </div>

        <h2 class="title">
          Draw a Verse
        </h2>

        <p class="subtitle">
            Pull a Scripture card and meditate on God's Word.
        </p>

      </div>

    </div>

  </div>
</div>

<style>
  .card-wrapper {
    width: 100%;
    max-width: 620px;
    margin: 0 auto 1.5rem;
    cursor: pointer;
    perspective: 1000px;
  }

  .card-stack {
    position: relative;
    height: 260px;
  }

  .card {
    position: absolute;
    inset: 0;
    border-radius: 24px;
  }

  .back {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

.back-1 {
  transform: translate(8px, 6px);
}

.back-2 {
  transform: translate(16px, 12px);
}

  .front {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow:
      0 20px 50px rgba(0,0,0,.08);
  }

  .card-inner {
    height: 100%;
    padding: 2rem;

    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;

    text-align: center;
  }

  .brand {
    font-size: .8rem;
    letter-spacing: .35em;
    color: var(--color-primary);
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .brand {
    font-size: .8rem;
    letter-spacing: .35em;
    color: var(--color-primary);
    margin-bottom: 1rem;
    font-weight: 700;
  }

.icon-wrap {
  width: 56px;
  height: 56px;
  margin-bottom: .75rem;
}

.icon-wrap svg {
  width: 56px;
  height: 56px;
}

  .ready {
    font-size: .7rem;
    letter-spacing: .25em;
    color: var(--color-muted);
    margin-bottom: .5rem;
  }

.title {
  font-size: 1.75rem;
  line-height: 1.2;
  text-align: center;
  margin: 0;
}

  .idle .card-stack {
    animation:
      float 5s ease-in-out infinite;
  }

  .card-wrapper:hover .front {
    transform:
      translateY(-8px)
      rotate(-1deg);

    transition: .25s ease;
  }
.card-draw .front {
  animation: drawCard .6s ease;
}

.subtitle {
  margin-top: .75rem;
  max-width: 26rem;

  font-size: .95rem;
  line-height: 1.6;

  color: var(--color-muted);
}

@keyframes drawCard {

  0% {
    transform:
      translateY(0)
      rotate(0deg);
  }

  30% {
    transform:
      translateY(-25px)
      rotate(-2deg);
  }

  60% {
    transform:
      translateY(-10px)
      rotate(2deg);
  }

  100% {
    transform:
      translateY(0)
      rotate(0deg);
  }

}

  @keyframes float {

    0% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-10px);
    }

    100% {
      transform: translateY(0);
    }

  }
</style>