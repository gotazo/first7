---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<button
  id="shareTool"
  type="button"
  class="btn-secondary rounded-xl px-4 py-3 text-sm"
>
  Share
</button>

<script
  is:inline
  define:vars={{ title }}
>

  const btn =
    document.getElementById(
      "shareTool"
    );

  if (btn) {

    btn.addEventListener(
      "click",
      async () => {

        const shareData = {
          title,
          text: `Check out ${title}`,
          url: window.location.href,
        };

        try {

          if (navigator.share) {

            await navigator.share(
              shareData
            );

          } else {

            await navigator.clipboard.writeText(
              window.location.href
            );

            btn.textContent =
              "Copied!";

            setTimeout(() => {

              btn.textContent =
                "Share";

            }, 2000);

          }

        } catch {

          btn.textContent =
            "Failed";

          setTimeout(() => {

            btn.textContent =
              "Share";

            }, 2000);

        }

      }
    );

  }

</script>
