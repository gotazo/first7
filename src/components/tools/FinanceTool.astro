<div class="space-y-8">

  <!-- ✅ QUICK GUIDE -->
  <div class="p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 text-sm text-[var(--color-muted)]">
    <strong>Quick guide:</strong><br />
    Enter your income → review allocation → click “Save Month” to build your funds.
  </div>

  <!-- 💰 INPUT -->
  <div class="rounded-2xl border border-[var(--color-border)] p-5 space-y-4">

    <label class="block text-sm font-medium">Monthly Income</label>

    <input id="income" type="number" placeholder="Enter your income"
      class="w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-transparent" />

    <!-- SWITCH -->
    <div class="flex justify-between items-center text-sm">
      <span class="text-[var(--color-muted)]">Future Savings (10%)</span>
      <button id="futureToggle"
  class="w-12 h-6 bg-[var(--color-border)] rounded-full relative transition-colors duration-200">
  
  <span id="toggleDot"
    class="absolute top-1 left-1 w-4 h-4 bg-white rounded-full transition-transform duration-200">
  </span>

</button>
    </div>

  </div>

  <!-- 📊 BREAKDOWN -->
  <div class="rounded-2xl border border-[var(--color-border)] p-5 space-y-2">
    <div class="flex justify-between"><span>Church</span><span id="church">₹0</span></div>
    <div class="flex justify-between"><span>Help</span><span id="help">₹0</span></div>
    <div class="flex justify-between"><span>Emergency</span><span id="emergency">₹0</span></div>
    <div class="flex justify-between"><span>Future</span><span id="future">₹0</span></div>
    <div class="flex justify-between font-semibold border-t pt-2">
      <span>Living</span><span id="living">₹0</span>
    </div>
  </div>

  <!-- ⚙️ ACTIONS -->
  <div class="flex gap-3">
    <button id="saveBtn" class="flex-1 bg-[var(--color-primary)] text-white py-2 rounded-xl">
      Save Month
    </button>
    <button id="resetBtn" class="border px-4 py-2 rounded-xl">
      Reset
    </button>
  </div>

  <!-- 💰 FUNDS -->
  <div class="rounded-2xl border p-5 space-y-2">
    <div class="flex justify-between">
      <span>Help Fund</span><span id="helpFund">₹0</span>
    </div>
    <p class="text-xs text-[var(--color-muted)]">
      +₹<span id="helpPending">0</span> pending
    </p>
  </div>

  <div class="rounded-2xl border p-5 space-y-2">
    <div class="flex justify-between">
      <span>Emergency Fund</span><span id="emergencyFund">₹0</span>
    </div>
    <p class="text-xs text-[var(--color-muted)]">
      +₹<span id="emergencyPending">0</span> pending
    </p>
  </div>

  <!-- 📊 MONTHLY HISTORY -->
  <div class="rounded-2xl border border-[var(--color-border)] p-5 space-y-4">
    <h3 class="font-medium">Monthly History</h3>
    <div id="historyList" class="space-y-2 text-sm"></div>
  </div>

  <!-- 📦 BACKUP (IMPROVED) -->
  <div class="rounded-2xl border border-[var(--color-border)] p-5 space-y-3">

    <p class="text-sm font-medium">Backup</p>

    <div class="flex gap-3 flex-wrap">

      <button id="exportBtn"
        class="px-4 py-2 rounded-lg bg-[var(--color-primary)] text-white text-sm">
        Export Data
      </button>

      <label
        class="px-4 py-2 rounded-lg border border-[var(--color-border)] text-sm cursor-pointer hover:bg-[var(--color-primary)]/5">
        Import Data
        <input type="file" id="importInput" class="hidden" />
      </label>

    </div>

    <p class="text-xs text-[var(--color-muted)]">
      Your data is stored locally. Export regularly to avoid loss.
    </p>

  </div>

  <!-- ❓ FAQ (ACCORDION) -->
  <div class="space-y-4 mt-16">

    <h2 class="text-lg font-semibold">FAQ</h2>

    <div class="faq-item border rounded-xl">
      <button class="faq-toggle w-full flex justify-between px-4 py-3">
        Why are my funds ₹0?
        <span>+</span>
      </button>
      <div class="faq-content hidden px-4 pb-4 text-sm text-[var(--color-muted)]">
        Funds increase only after clicking “Save Month”. The calculator shows planned allocation, not saved money.
      </div>
    </div>

    <div class="faq-item border rounded-xl">
      <button class="faq-toggle w-full flex justify-between px-4 py-3">
        Is my data stored online?
        <span>+</span>
      </button>
      <div class="faq-content hidden px-4 pb-4 text-sm text-[var(--color-muted)]">
        No. All data is stored locally in your browser.
      </div>
    </div>

    <div class="faq-item border rounded-xl">
      <button class="faq-toggle w-full flex justify-between px-4 py-3">
        Will I lose my data?
        <span>+</span>
      </button>
      <div class="faq-content hidden px-4 pb-4 text-sm text-[var(--color-muted)]">
        Yes, if you clear browser data. Use export to back it up.
      </div>
    </div>

  </div>

</div>

<script type="module">
import { loadData, saveData, resetData } from "/src/components/tools/finance/storage.js";
import { calculate } from "/src/components/tools/finance/logic.js";

document.addEventListener("DOMContentLoaded", () => {

  let data = loadData();

  // ELEMENTS
  const incomeEl = document.getElementById("income");
  const toggleEl = document.getElementById("futureToggle");
  const dot = document.getElementById("toggleDot");

  const churchEl = document.getElementById("church");
  const helpEl = document.getElementById("help");
  const emergencyEl = document.getElementById("emergency");
  const futureEl = document.getElementById("future");
  const livingEl = document.getElementById("living");

  const helpPendingEl = document.getElementById("helpPending");
  const emergencyPendingEl = document.getElementById("emergencyPending");

  const helpFundEl = document.getElementById("helpFund");
  const emergencyFundEl = document.getElementById("emergencyFund");

  const saveBtn = document.getElementById("saveBtn");
  const resetBtn = document.getElementById("resetBtn");

  const exportBtn = document.getElementById("exportBtn");
  const importInput = document.getElementById("importInput");

  const historyList = document.getElementById("historyList");

  // STATE
  let includeFuture = data.settings.includeFuture ?? false;
  incomeEl.value = data.settings.lastIncome || "";

  function format(v) {
    return "₹" + Math.round(v || 0);
  }

  // 🔁 TOGGLE UI
  function updateToggle() {
    if (includeFuture) {
      toggleEl.classList.remove("bg-[var(--color-border)]");
      toggleEl.classList.add("bg-green-500");
      dot.style.transform = "translateX(24px)";
    } else {
      toggleEl.classList.remove("bg-green-500");
      toggleEl.classList.add("bg-[var(--color-border)]");
      dot.style.transform = "translateX(0)";
    }
  }

  // 🔥 TOGGLE CLICK (CRITICAL FIX)
  toggleEl.addEventListener("click", () => {
    includeFuture = !includeFuture;
    data.settings.includeFuture = includeFuture;

    updateToggle();
    runCalc();
  });

  // 📊 CALCULATION
  function runCalc() {
    const income = Number(incomeEl.value || 0);
    const r = calculate(income, includeFuture);

    churchEl.innerText = format(r.church);
    helpEl.innerText = format(r.help);
    emergencyEl.innerText = format(r.emergency);
    futureEl.innerText = format(r.future);
    livingEl.innerText = format(r.living);

    helpPendingEl.innerText = Math.round(r.help);
    emergencyPendingEl.innerText = Math.round(r.emergency);

    return r;
  }

  // 💰 FUNDS UI
  function updateFunds() {
    helpFundEl.innerText = format(data.funds.help);
    emergencyFundEl.innerText = format(data.funds.emergency);
  }

  // 📅 HISTORY
  function renderHistory() {
    historyList.innerHTML = "";

    Object.entries(data.history || {}).reverse().forEach(([month, val]) => {
      const div = document.createElement("div");
      div.className = "flex justify-between border-b pb-1";
      div.innerHTML = `<span>${month}</span><span>${format(val.income)}</span>`;
      historyList.appendChild(div);
    });
  }

  // INPUT
  incomeEl.addEventListener("input", runCalc);

  // SAVE
  saveBtn.addEventListener("click", () => {
    const r = runCalc();
    const m = new Date().toISOString().slice(0, 7);

    data.settings.lastIncome = r.income;
    data.funds.help += r.help;
    data.funds.emergency += r.emergency;
    data.history[m] = r;

    saveData(data);
    updateFunds();
    renderHistory();
  });

  // RESET
  resetBtn.addEventListener("click", () => {
    if (confirm("Reset all data?")) {
      resetData();
      location.reload();
    }
  });

  // 📤 EXPORT (FIXED)
  exportBtn.addEventListener("click", () => {
    const blob = new Blob([JSON.stringify(data)], { type: "application/json" });
    const url = URL.createObjectURL(blob);

    const a = document.createElement("a");
    a.href = url;
    a.download = "finance-data.json";
    a.click();

    URL.revokeObjectURL(url);
  });

  // 📥 IMPORT
  importInput.addEventListener("change", (e) => {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();

    reader.onload = (ev) => {
      data = JSON.parse(ev.target.result);
      saveData(data);
      location.reload();
    };

    reader.readAsText(file);
  });

  // FAQ
  document.querySelectorAll(".faq-toggle").forEach(btn => {
    btn.addEventListener("click", () => {
      const content = btn.nextElementSibling;
      content.classList.toggle("hidden");
    });
  });

  // 🚀 INIT (ORDER MATTERS)
  updateToggle();   // must come first
  updateFunds();
  renderHistory();
  runCalc();

});
</script>