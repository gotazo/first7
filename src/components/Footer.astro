---
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-muted)]">

  <div class="max-w-6xl mx-auto px-4 py-12">

    <!-- BRAND -->
    <div class="mb-10">

      <a
        href="/"
        class="flex items-center gap-[4px] text-2xl md:text-3xl tracking-tight"
      >

        <span
          class="text-[var(--color-text)]"
          style="font-family: 'Playfair Display', serif; font-weight: 400;"
        >
          first
        </span>

        <span
          class="text-[var(--color-primary)]"
          style="font-family: 'Inter', sans-serif; font-weight: 500;"
        >
          7
        </span>

      </a>

      <p class="mt-3 text-sm leading-relaxed max-w-xl">
        Build a daily habit of faith through Scripture, guided plans,
        structured teachings, and spiritual reflection.
      </p>

    </div>

    <!-- MOBILE -->
    <div class="space-y-4 md:hidden">

      {[
        {
          title: "Explore",
          links: [
            { href: "/ask", label: "Ask" },
            { href: "/teachings", label: "Library" },
            { href: "/plans", label: "Plans" },
            { href: "/verses", label: "Verses" },
            { href: "/prayers", label: "Prayers" },
            { href: "/bible", label: "Bible" }
          ]
        },
        {
          title: "Topics",
          links: [
            { href: "/teachings?topic=vision", label: "Vision" },
            { href: "/teachings?topic=faith", label: "Faith" },
            { href: "/teachings?topic=purpose", label: "Purpose" },
            { href: "/teachings?topic=identity", label: "Identity" }
          ]
        },
        {
          title: "Company",
          links: [
            { href: "/about", label: "About" },
            { href: "/contact", label: "Contact" },
            { href: "/privacy", label: "Privacy Policy" },
            { href: "/terms", label: "Terms" }
          ]
        }
      ].map((section, i) => (
        <div>

          <button
            class="w-full flex justify-between items-center text-sm font-medium text-[var(--color-text)]"
            onclick={`document.getElementById('f${i}').classList.toggle('hidden')`}
          >
            {section.title}
            <span>+</span>
          </button>

          <ul id={`f${i}`} class="mt-3 space-y-2 text-sm hidden">

            {section.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="hover:text-[var(--color-text)]"
                >
                  {l.label}
                </a>
              </li>
            ))}

          </ul>

        </div>
      ))}

      <!-- SUPPORT -->
      <div class="pt-4 border-t border-[var(--color-border)]">

        <a
          href="/support"
          class="btn inline-block mt-3 px-5 py-2.5 rounded-lg text-sm font-medium"
        >
          Support this project →
        </a>

      </div>

    </div>

    <!-- DESKTOP -->
    <div class="hidden md:grid md:grid-cols-4 gap-10">

      <!-- EXPLORE -->
      <div>

        <p class="text-sm font-medium text-[var(--color-text)]">
          Explore
        </p>

        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/ask" class="hover:text-[var(--color-text)]">Ask</a></li>
          <li><a href="/teachings" class="hover:text-[var(--color-text)]">Library</a></li>
          <li><a href="/plans" class="hover:text-[var(--color-text)]">Plans</a></li>
          <li><a href="/verses" class="hover:text-[var(--color-text)]">Verses</a></li>
          <li><a href="/prayers" class="hover:text-[var(--color-text)]">Prayers</a></li>
          <li><a href="/bible" class="hover:text-[var(--color-text)]">Bible</a></li>
        </ul>

      </div>

      <!-- TOPICS -->
      <div>

        <p class="text-sm font-medium text-[var(--color-text)]">
          Topics
        </p>

        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/teachings?topic=vision" class="hover:text-[var(--color-text)]">Vision</a></li>
          <li><a href="/teachings?topic=faith" class="hover:text-[var(--color-text)]">Faith</a></li>
          <li><a href="/teachings?topic=purpose" class="hover:text-[var(--color-text)]">Purpose</a></li>
          <li><a href="/teachings?topic=identity" class="hover:text-[var(--color-text)]">Identity</a></li>
        </ul>

      </div>

      <!-- COMPANY -->
      <div>

        <p class="text-sm font-medium text-[var(--color-text)]">
          Company
        </p>

        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/about" class="hover:text-[var(--color-text)]">About</a></li>
          <li><a href="/contact" class="hover:text-[var(--color-text)]">Contact</a></li>
          <li><a href="/privacy" class="hover:text-[var(--color-text)]">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-[var(--color-text)]">Terms</a></li>
        </ul>

      </div>

      <!-- SUPPORT -->
      <div>

        <p class="text-sm font-medium text-[var(--color-text)]">
          Support
        </p>

        <p class="mt-3 text-sm leading-relaxed">
          Help support the growth of this project and future teachings.
        </p>

        <a
          href="/support"
          class="btn inline-block mt-4 px-5 py-2.5 rounded-lg text-sm font-medium"
        >
          Support this project →
        </a>

      </div>

    </div>

  </div>

  <!-- WEB3 -->
  <div class="border-t border-[var(--color-border)] py-6 text-center">

    <p class="text-sm font-medium text-[var(--color-text)] mb-3">
      Experience First7 on the decentralized web
    </p>

    <a
      href="https://first7.sol.site"
      target="_blank"
      rel="noopener noreferrer"
      onclick="trackWeb3Click()"
      class="btn-secondary inline-block px-4 py-2 rounded-lg text-sm font-medium"
    >
      Visit first7.sol →
    </a>

  </div>

    <!-- BOTTOM -->
  <div class="border-t border-[var(--color-border)] text-center text-xs py-6">
    © {year} First7. All rights reserved.
  </div>

  <!-- Site Tag -->
  <ins
    class="CANBMDDisplayAD"
    data-bmd-ad-unit="1338239420260507T104425170F0EFAD0A84954BE8AE70F11135F81E41"
    style="display:block"
  ></ins>

  <script src="https://secureaddisplay.com/au/bmd/" async></script>
  <!-- /Site Tag -->

</footer>
