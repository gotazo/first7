---
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-muted)]">
  <div class="max-w-6xl mx-auto px-4 py-12 grid gap-10 md:grid-cols-4">

    <!-- BRAND -->
    <div>
<a href="/" class="flex items-center gap-[4px] text-2xl md:text-3xl tracking-tight">

  <span
    class="text-[var(--color-text)]"
    style="
      font-family: 'Playfair Display', serif;
      font-weight: 400;
      letter-spacing: 0.01em;
      font-variant-ligatures: none;
    "
  >
    first
  </span>

  <span
    class="text-[var(--color-primary)]"
    style="
      font-family: 'Inter', sans-serif;
      font-weight: 500;
      font-size: 1.2em;
    "
  >
    7
  </span>

</a>
      <p class="mt-3 text-sm">
        Build a daily habit of faith through guided plans, Scripture, and reflection.
      </p>
      <p class="mt-2 text-sm leading-relaxed">
        First7 is a personal project and not affiliated with any church or organization.
      </p>
    </div>

    <!-- NAVIGATION -->
    <div>
      <p class="text-sm font-medium text-[var(--color-text)]">Explore</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/plans" class="hover:text-[var(--color-text)]">Plans</a></li>
        <li><a href="/devotionals" class="hover:text-[var(--color-text)]">Devotionals</a></li>
        <li><a href="/bible" class="hover:text-[var(--color-text)]">Bible</a></li>
        <li><a href="/downloads" class="hover:text-[var(--color-text)]">Downloads</a></li>
      </ul>
    </div>

    <!-- COMPANY -->
    <div>
      <p class="text-sm font-medium text-[var(--color-text)]">Company</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/about" class="hover:text-[var(--color-text)]">About</a></li>
        <li><a href="/contact" class="hover:text-[var(--color-text)]">Contact</a></li>
        <li><a href="/privacy" class="hover:text-[var(--color-text)]">Privacy Policy</a></li>
        <li><a href="/terms" class="hover:text-[var(--color-text)]">Terms</a></li>
      </ul>
    </div>

    <!-- FAITH + SUPPORT -->
    <div>
      <p class="text-sm font-medium text-[var(--color-text)]">Faith</p>

      <p class="mt-3 text-sm leading-relaxed">
        Content is created to encourage daily faith and reflection. Scripture quotations are from the KJV Bible.
      </p>

      <!-- SUPPORT -->
      <p class="text-sm font-medium text-[var(--color-text)] mt-6">
        Support
      </p>

      <p class="mt-3 text-sm">
        If this project has helped you, you can support its growth.
      </p>

      <a
        href="/support"
        class="inline-block mt-3 text-sm text-[var(--color-primary)] hover:underline"
      >
        Support this project →
      </a>
    </div>

  </div>

  <!-- BOTTOM -->
  <div class="border-t border-[var(--color-border)] text-center text-xs py-6">
    © {year} First7. All rights reserved.
  </div>
</footer>
