---
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-muted)]">

  <div class="max-w-6xl mx-auto px-4 py-12">

    <!-- BRAND -->
    <div class="mb-10">
      <a href="/" class="flex items-center gap-[4px] text-2xl md:text-3xl tracking-tight">

        <span
          class="text-[var(--color-text)]"
          style="font-family: 'Playfair Display', serif; font-weight: 400;"
        >
          first
        </span>

        <span
          class="text-[var(--color-primary)]"
          style="font-family: 'Inter', sans-serif; font-weight: 500;"
        >
          7
        </span>

      </a>

      <p class="mt-3 text-sm">
        Build a daily habit of faith through guided plans, Scripture, and reflection.
      </p>

      <p class="mt-2 text-sm leading-relaxed">
        First7 is an independent project created to encourage daily faith and reflection.
      </p>
    </div>

    <!-- MOBILE ACCORDION -->
    <div class="space-y-4 md:hidden">

      {[
        {
          title: "Explore",
          links: [
            { href: "/tools", label: "Tools" },
            { href: "/plans", label: "Plans" },
            { href: "/guides", label: "Guides" },
            { href: "/resources", label: "Resources" },
            { href: "/verses", label: "Verses" }
          ]
        },
        {
          title: "Company",
          links: [
            { href: "/about", label: "About" },
            { href: "/contact", label: "Contact" },
            { href: "/privacy", label: "Privacy Policy" },
            { href: "/terms", label: "Terms" }
          ]
        },
        {
          title: "Bible",
          links: [
            { href: "/bible", label: "Read Bible" },
            { href: "/preface", label: "Preface" },
            { href: "/dedicatory", label: "Dedicatory" }
          ]
        }
      ].map((section, i) => (
        <div>
          <button
            class="w-full flex justify-between items-center text-sm font-medium text-[var(--color-text)]"
            onclick={`document.getElementById('f${i}').classList.toggle('hidden')`}
          >
            {section.title}
            <span>+</span>
          </button>

          <ul id={`f${i}`} class="mt-3 space-y-2 text-sm hidden">
            {section.links.map((l) => (
              <li>
                <a href={l.href} class="hover:text-[var(--color-text)]">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- SUPPORT -->
      <div class="pt-4 border-t border-[var(--color-border)]">
        <a
          href="/support"
          class="inline-block mt-3 px-5 py-2.5 rounded-lg bg-[var(--color-primary)] text-white text-sm font-medium hover:opacity-90 transition"
        >
          Support this project →
        </a>
      </div>

    </div>

    <!-- DESKTOP GRID -->
    <div class="hidden md:grid md:grid-cols-4 gap-10">

      <!-- EXPLORE -->
      <div>
        <p class="text-sm font-medium text-[var(--color-text)]">Explore</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/tools" class="hover:text-[var(--color-text)]">Tools</a></li>
          <li><a href="/plans" class="hover:text-[var(--color-text)]">Plans</a></li>
          <li><a href="/guides" class="hover:text-[var(--color-text)]">Guides</a></li>
          <li><a href="/resources" class="hover:text-[var(--color-text)]">Resources</a></li>
          <li><a href="/verses" class="hover:text-[var(--color-text)]">Verses</a></li>
          <li><a href="/bible" class="hover:text-[var(--color-text)]">Bible</a></li>
        </ul>
      </div>

      <!-- COMPANY -->
      <div>
        <p class="text-sm font-medium text-[var(--color-text)]">Company</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/about" class="hover:text-[var(--color-text)]">About</a></li>
          <li><a href="/contact" class="hover:text-[var(--color-text)]">Contact</a></li>
          <li><a href="/privacy" class="hover:text-[var(--color-text)]">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-[var(--color-text)]">Terms</a></li>
        </ul>
      </div>

      <!-- BIBLE -->
      <div>
        <p class="text-sm font-medium text-[var(--color-text)]">Bible</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/bible" class="hover:text-[var(--color-text)]">Read Bible</a></li>
          <li><a href="/preface" class="hover:text-[var(--color-text)]">Preface</a></li>
          <li><a href="/dedicatory" class="hover:text-[var(--color-text)]">Dedicatory</a></li>
        </ul>

        <p class="mt-4 text-xs leading-relaxed">
          Scripture quotations are from the King James Version (KJV).
        </p>
      </div>

      <!-- SUPPORT -->
      <div>
        <p class="text-sm font-medium text-[var(--color-text)]">Support</p>

        <p class="mt-3 text-sm">
          If this project has helped you, you can support its growth.
        </p>

        <a
          href="/support"
          class="inline-block mt-4 px-5 py-2.5 rounded-lg bg-[var(--color-primary)] text-white text-sm font-medium hover:opacity-90 transition"
        >
          Support this project →
        </a>
      </div>

    </div>

  </div>

  <!-- WEB3 PROMO -->
<div class="border-t border-[var(--color-border)] py-6 text-center">
  <p class="text-sm font-medium text-[var(--color-text)] mb-3">
    Experience First7 on the decentralized web
  </p>

  <a
    href="https://first7.sol.site"
    target="_blank"
    rel="noopener noreferrer"
    onclick="trackWeb3Click()"
    class="inline-block px-4 py-2 rounded-lg border border-[var(--color-primary)] text-[var(--color-primary)] text-sm font-medium hover:bg-[var(--color-primary)] hover:text-white transition"
  >
    Visit first7.sol →
  </a>
</div>

  <!-- BOTTOM -->
  <div class="border-t border-[var(--color-border)] text-center text-xs py-6">
    © {year} First7. All rights reserved.
  </div>

</footer>