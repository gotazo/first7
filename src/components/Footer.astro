---
import { getCollection } from "astro:content";

const year = new Date().getFullYear();

await getCollection("teachings");
---

<footer class="mt-20 border-t border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-muted)]">

  <div class="max-w-6xl mx-auto px-4 py-12">

    <!-- BRAND -->
    <div class="mb-12">

      <a
        href="/"
        class="flex items-center gap-[4px] text-2xl md:text-3xl tracking-tight"
      >

        <span
          class="text-[var(--color-text)]"
          style="font-family: 'Playfair Display', serif; font-weight: 400;"
        >
          first
        </span>

        <span
          class="text-[var(--color-primary)]"
          style="font-family: 'Inter', sans-serif; font-weight: 500;"
        >
          7
        </span>

      </a>

      <p class="mt-3 text-sm leading-relaxed max-w-xl">
        Build a daily habit of faith through Scripture,
        structured teachings, guided plans,
        and spiritual reflection.
      </p>

    </div>

    <!-- MOBILE -->
    <div class="space-y-4 md:hidden">

      {[
        {
          title: "Explore",
          links: [
            { href: "/library", label: "Library" },
            { href: "/ask", label: "Ask & Grow" },
            { href: "/blog", label: "Blog" },
            { href: "/bible", label: "Bible" }
          ]
        },
        {
          title: "Resources",
          links: [
            { href: "/prophecy", label: "Bible Prophecy" },
            { href: "/number", label: "Biblical Numbers" },
            { href: "/resources", label: "Resources" },
            { href: "/plans", label: "Plans" },
            { href: "/guides", label: "Guides" },
            { href: "/tools", label: "Tools" },
            { href: "/prayers", label: "Prayers" }
          ]
        },
        {
          title: "Company",
          links: [
            { href: "/about", label: "About" },
            { href: "/contact", label: "Contact" },
            { href: "/privacy", label: "Privacy Policy" },
            { href: "/terms", label: "Terms" }
          ]
        }
      ].map((section, i) => (

        <div>

          <button
            class="w-full flex justify-between items-center text-sm font-medium text-[var(--color-text)]"
            onclick={`document.getElementById('f${i}')?.classList.toggle('hidden')`}
          >
            {section.title}
            <span>+</span>
          </button>

          <ul
            id={`f${i}`}
            class="mt-3 space-y-2 text-sm hidden"
          >

            {section.links.map((l) => (

              <li>

                <a
                  href={l.href}
                  class="hover:text-[var(--color-text)] transition"
                >
                  {l.label}
                </a>

              </li>

            ))}

          </ul>

        </div>

      ))}

      <!-- SUPPORT -->
      <div class="pt-5 border-t border-[var(--color-border)]">

        <a
          href="/support"
          class="btn inline-block mt-3 px-5 py-2.5 rounded-lg text-sm font-medium"
        >
          Support this project →
        </a>

      </div>

    </div>

    <!-- DESKTOP -->
    <div class="hidden md:grid md:grid-cols-4 gap-10">

      <!-- EXPLORE -->
      <div>

        <p class="text-sm font-medium text-[var(--color-text)]">
          Explore
        </p>

        <ul class="mt-3 space-y-2 text-sm">

          <li>
            <a
              href="/library"
              class="hover:text-[var(--color-text)] transition"
            >
              Library
            </a>
          </li>

          <li>
            <a
              href="/ask"
              class="hover:text-[var(--color-text)] transition"
            >
              Ask & Grow
            </a>
          </li>

          <li>
            <a
              href="/blog"
              class="hover:text-[var(--color-text)] transition"
            >
              Blog
            </a>
          </li>

          <li>
            <a
              href="/bible"
              class="hover:text-[var(--color-text)] transition"
            >
              Bible
            </a>
          </li>

        </ul>

      </div>

      <!-- RESOURCES -->
      <div>

        <p class="text-sm font-medium text-[var(--color-text)]">
          Resources
        </p>

        <ul class="mt-3 space-y-2 text-sm">

            <li>
              <a
                href="/prophecy"
                class="hover:text-[var(--color-text)] transition"
              >
                Bible Prophecy
              </a>
            </li>

            <li>
              <a
                href="/number"
                class="hover:text-[var(--color-text)] transition"
              >
                Biblical Numbers
              </a>
            </li>

          <li>
            <a
              href="/resources"
              class="hover:text-[var(--color-text)] transition"
            >
              Resources
            </a>
          </li>

          <li>
            <a
              href="/plans"
              class="hover:text-[var(--color-text)] transition"
            >
              Plans
            </a>
          </li>

          <li>
            <a
              href="/guides"
              class="hover:text-[var(--color-text)] transition"
            >
              Guides
            </a>
          </li>

          <li>
            <a
              href="/tools"
              class="hover:text-[var(--color-text)] transition"
            >
              Tools
            </a>
          </li>

          <li>
            <a
              href="/prayers"
              class="hover:text-[var(--color-text)] transition"
            >
              Prayers
            </a>
          </li>

        </ul>

      </div>

      <!-- COMPANY -->
      <div>

        <p class="text-sm font-medium text-[var(--color-text)]">
          Company
        </p>

        <ul class="mt-3 space-y-2 text-sm">

          <li>
            <a
              href="/about"
              class="hover:text-[var(--color-text)] transition"
            >
              About
            </a>
          </li>

          <li>
            <a
              href="/contact"
              class="hover:text-[var(--color-text)] transition"
            >
              Contact
            </a>
          </li>

          <li>
            <a
              href="/privacy"
              class="hover:text-[var(--color-text)] transition"
            >
              Privacy Policy
            </a>
          </li>

          <li>
            <a
              href="/terms"
              class="hover:text-[var(--color-text)] transition"
            >
              Terms
            </a>
          </li>

        </ul>

      </div>

      <!-- SUPPORT -->
      <div>

        <p class="text-sm font-medium text-[var(--color-text)]">
          Support
        </p>

        <p class="mt-3 text-sm leading-relaxed">
          Help support the growth of this project
          and future teachings.
        </p>

        <a
          href="/support"
          class="btn inline-block mt-4 px-5 py-2.5 rounded-lg text-sm font-medium"
        >
          Support this project →
        </a>

      </div>

    </div>

  </div>

  <!-- WEB3 -->
  <div class="border-t border-[var(--color-border)] py-6 text-center">

    <p class="text-sm font-medium text-[var(--color-text)] mb-3">
      Experience First7 on the decentralized web
    </p>

    <a
      href="https://first7.sol.site"
      target="_blank"
      rel="noopener noreferrer"
      data-web3-click
      class="btn-secondary inline-block px-4 py-2 rounded-lg text-sm font-medium"
    >
      Visit first7.sol →
    </a>

  </div>

  <!-- COPYRIGHT -->
  <div class="border-t border-[var(--color-border)] text-center text-xs py-6">

    © {year} First7. All rights reserved.

  </div>

  <!-- SITE TAG -->


</footer>
