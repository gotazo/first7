---
import DarkToggle from "./DarkToggle.astro";

import {
  ChevronDown,
} from "../lib/icons";

const pathname = Astro.url.pathname;
---

<nav
  class="
    sticky
    top-0
    z-50
    border-b
    border-[var(--color-border)]
    bg-[var(--color-bg)]/80
    backdrop-blur-xl
  "
>

  <div
    class="
      mx-auto
      flex
      max-w-7xl
      items-center
      justify-between
      px-6
      py-4
    "
  >

    <!-- LOGO -->

    <a
      href="/"
      aria-label="First7 Home"
      class="
        group
        flex
        items-center
        gap-1
        text-3xl
        tracking-tight
      "
    >

      <span
        class="
          text-[var(--color-text)]
          transition-colors
          duration-200
          group-hover:text-[var(--color-primary)]
        "
        style="font-family:'Playfair Display', serif;"
      >
        first
      </span>

      <span
        class="
          font-semibold
          text-[var(--color-primary)]
        "
      >
        7
      </span>

    </a>

    <!-- DESKTOP NAV -->

    <div
      class="
        hidden
        items-center
        gap-2
        text-sm
        md:flex
      "
    >

      <!-- VERSES -->

      <div class="group relative">

        <a
          href="/verses"
          class:list={[
            "inline-flex items-center gap-1.5 rounded-xl px-3 py-2 transition-all duration-200 hover:bg-[var(--color-bg-soft)]",
            pathname.startsWith("/verses")
              ? "font-medium text-[var(--color-text)]"
              : "text-[var(--color-muted)] hover:text-[var(--color-text)]",
          ]}
        >

          <span>Verses</span>

          <ChevronDown
            class="
              h-4
              w-4
              transition-transform
              duration-200
              group-hover:rotate-180
            "
          />

        </a>

          <div
          class="
            invisible
            absolute
            left-1/2
            top-full
            z-50
            w-[500px]
            -translate-x-1/2
            pt-4
            opacity-0
            transition-all
            duration-200
            group-hover:visible
            group-hover:opacity-100
          "
        >

          <div
            class="
              rounded-3xl
              border
              border-[var(--color-border)]
              bg-[var(--color-bg)]
              p-6
              shadow-xl
            "
          >

            <div class="grid grid-cols-2 gap-6">

              <div>

                <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-primary)]">
                  Emotions
                </p>

                <a href="/verses/bible-verses-for-anxiety" class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]">
                  Anxiety
                </a>

                <a href="/verses/bible-verses-for-fear" class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]">
                  Fear
                </a>

                <a href="/verses/bible-verses-for-depression" class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]">
                  Depression
                </a>

              </div>

              <div>

                <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-primary)]">
                  Growth
                </p>

                <a href="/verses/bible-verses-for-strength" class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]">
                  Strength
                </a>

                <a href="/verses/bible-verses-for-love" class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]">
                  Love
                </a>

                <a href="/verses/bible-verses-for-healing" class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]">
                  Healing
                </a>

              </div>

            </div>

          </div>

        </div>

      </div>

      <!-- PRAYERS -->

      <div class="group relative">

        <a
          href="/prayers"
          class:list={[
            "inline-flex items-center gap-1.5 rounded-xl px-3 py-2 transition-all duration-200 hover:bg-[var(--color-bg-soft)]",
            pathname.startsWith("/prayers")
              ? "font-medium text-[var(--color-text)]"
              : "text-[var(--color-muted)] hover:text-[var(--color-text)]",
          ]}
        >

          <span>Prayers</span>

          <ChevronDown
            class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180"
          />

        </a>

        <div
          class="
            invisible
            absolute
            left-1/2
            top-full
            z-50
            w-[500px]
            -translate-x-1/2
            pt-4
            opacity-0
            transition-all
            duration-200
            group-hover:visible
            group-hover:opacity-100
          "
        >

          <div
            class="
              rounded-3xl
              border
              border-[var(--color-border)]
              bg-[var(--color-bg)]
              p-6
              shadow-xl
            "
          >

            <div class="grid grid-cols-2 gap-6">

              <div>

                <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-primary)]">
                  Needs
                </p>

                <a href="/prayers/anxiety" class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]">Anxiety</a>

                <a href="/prayers/peace" class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]">Peace</a>

                <a href="/prayers/healing" class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]">Healing</a>

              </div>

              <div>

                <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-primary)]">
                  Growth
                </p>

                <a href="/prayers/strength" class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]">Strength</a>

                <a href="/prayers/guidance" class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]">Guidance</a>

              </div>

            </div>

          </div>

        </div>

      </div>

      <!-- VERSE JAR -->

      <a
        href="/verse-jar"
        class:list={[
          "rounded-xl px-3 py-2 transition-all duration-200 hover:bg-[var(--color-bg-soft)]",
          pathname.startsWith("/verse-jar")
            ? "font-medium text-[var(--color-text)]"
            : "text-[var(--color-muted)] hover:text-[var(--color-text)]",
        ]}
      >
        Verse Jar
      </a>

      <!-- ASK -->

      <a
        href="/ask"
        class:list={[
          "rounded-xl px-3 py-2 transition-all duration-200 hover:bg-[var(--color-bg-soft)]",
          pathname.startsWith("/ask")
            ? "font-medium text-[var(--color-text)]"
            : "text-[var(--color-muted)] hover:text-[var(--color-text)]",
        ]}
      >
        Ask
      </a>

        <!-- LIBRARY -->

      <div class="group relative">

        <a
          href="/teachings"
          class:list={[
            "inline-flex items-center gap-1.5 rounded-xl px-3 py-2 transition-all duration-200 hover:bg-[var(--color-bg-soft)]",
            pathname.startsWith("/teachings") ||
            pathname.startsWith("/dictionary") ||
            pathname.startsWith("/number") ||
            pathname.startsWith("/prophecy") ||
            pathname.startsWith("/reflections") ||
            pathname.startsWith("/resources")
              ? "font-medium text-[var(--color-text)]"
              : "text-[var(--color-muted)] hover:text-[var(--color-text)]",
          ]}
        >

          <span>Library</span>

          <ChevronDown
            class="
              h-4
              w-4
              transition-transform
              duration-200
              group-hover:rotate-180
            "
          />

        </a>

        <div
          class="
            invisible
            absolute
            left-1/2
            top-full
            z-50
            w-[300px]
            -translate-x-1/2
            pt-4
            opacity-0
            transition-all
            duration-200
            group-hover:visible
            group-hover:opacity-100
          "
        >

          <div
            class="
              rounded-3xl
              border
              border-[var(--color-border)]
              bg-[var(--color-bg)]
              p-4
              shadow-xl
            "
          >

            <div class="space-y-1">

              <a
                href="/teachings"
                class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]"
              >
                Teachings
              </a>

              <a
                href="/dictionary"
                class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]"
              >
                Dictionary
              </a>

              <a
                href="/number"
                class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]"
              >
                Numbers
              </a>

              <a
                href="/prophecy"
                class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]"
              >
                Prophecy
              </a>

              <a
                href="/reflections"
                class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]"
              >
                Reflections
              </a>

              <a
                href="/resources"
                class="block rounded-xl px-3 py-2 transition hover:bg-[var(--color-bg-soft)]"
              >
                Resources
              </a>

            </div>

          </div>

        </div>

      </div>

      <!-- PLANS -->

      <a
        href="/plans"
        class:list={[
          "rounded-xl px-3 py-2 transition-all duration-200 hover:bg-[var(--color-bg-soft)]",
          pathname.startsWith("/plans")
            ? "font-medium text-[var(--color-text)]"
            : "text-[var(--color-muted)] hover:text-[var(--color-text)]",
        ]}
      >
        Plans
      </a>

      <!-- BIBLE -->

      <a
        href="/bible"
        class:list={[
          "rounded-xl px-3 py-2 transition-all duration-200 hover:bg-[var(--color-bg-soft)]",
          pathname.startsWith("/bible")
            ? "font-medium text-[var(--color-text)]"
            : "text-[var(--color-muted)] hover:text-[var(--color-text)]",
        ]}
      >
        Bible
      </a>

      <!-- PLAY -->

      <a
        href="https://play.first7.org"
        target="_blank"
        rel="noopener noreferrer"
        class="
          ml-2
          inline-flex
          items-center
          gap-2
          rounded-xl
          border
          border-[rgba(214,179,106,0.18)]
          bg-[rgba(214,179,106,0.08)]
          px-4
          py-2
          text-xs
          font-semibold
          uppercase
          tracking-[0.15em]
          text-[var(--color-primary)]
          transition-all
          duration-200
          hover:-translate-y-0.5
          hover:border-[rgba(214,179,106,0.3)]
          hover:bg-[rgba(214,179,106,0.14)]
        "
      >
        Play ↗
      </a>

    </div>

    <!-- RIGHT -->

    <div class="flex items-center gap-4">

      <DarkToggle />

      <button
        id="menu-btn"
        class="
          rounded-xl
          border
          border-[var(--color-border)]
          p-2
          transition
          hover:bg-[var(--color-bg-soft)]
          md:hidden
        "
        aria-label="Open Menu"
      >
        ☰
      </button>

    </div>

  </div>

    <!-- MOBILE MENU -->

  <div
    id="mobile-menu"
    class="
      hidden
      border-t
      border-[var(--color-border)]
      bg-[var(--color-bg)]
      md:hidden
    "
  >

    <div class="space-y-5 px-6 py-6">

      <!-- VERSES -->

      <div>

        <button
          id="verses-btn"
          class="
            flex
            w-full
            items-center
            justify-between
            rounded-xl
            px-3
            py-3
            font-medium
            transition
            hover:bg-[var(--color-bg-soft)]
          "
        >
          <span>Verses</span>
          <ChevronDown
            id="verses-icon"
            class="h-4 w-4 transition-transform duration-200"
          />
        </button>

        <div
          id="mobile-verses"
          class="hidden mt-2 space-y-1 pl-4"
        >

          <a href="/verses/bible-verses-for-anxiety" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Anxiety</a>

          <a href="/verses/bible-verses-for-fear" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Fear</a>

          <a href="/verses/bible-verses-for-strength" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Strength</a>

          <a href="/verses/bible-verses-for-depression" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Depression</a>

          <a href="/verses/bible-verses-for-love" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Love</a>

          <a href="/verses/bible-verses-for-healing" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Healing</a>

        </div>

      </div>

      <!-- PRAYERS -->

      <div>

        <button
          id="prayers-btn"
          class="flex w-full items-center justify-between rounded-xl px-3 py-3 font-medium transition hover:bg-[var(--color-bg-soft)]"
        >
          <span>Prayers</span>
          <ChevronDown
            id="prayers-icon"
            class="h-4 w-4 transition-transform duration-200"
          />
        </button>

        <div
          id="mobile-prayers"
          class="hidden mt-2 space-y-1 pl-4"
        >

          <a href="/prayers/anxiety" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Anxiety</a>

          <a href="/prayers/peace" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Peace</a>

          <a href="/prayers/healing" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Healing</a>

          <a href="/prayers/strength" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Strength</a>

          <a href="/prayers/guidance" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Guidance</a>

        </div>

      </div>

      <a href="/verse-jar" class="block rounded-xl px-3 py-3 hover:bg-[var(--color-bg-soft)]">Verse Jar</a>

      <a href="/ask" class="block rounded-xl px-3 py-3 hover:bg-[var(--color-bg-soft)]">Ask</a>

      <!-- LIBRARY -->

      <div>

        <button
          id="library-btn"
          class="flex w-full items-center justify-between rounded-xl px-3 py-3 font-medium transition hover:bg-[var(--color-bg-soft)]"
        >
          <span>Library</span>
          <ChevronDown
            id="library-icon"
            class="h-4 w-4 transition-transform duration-200"
          />
        </button>

        <div
          id="mobile-library"
          class="hidden mt-2 space-y-1 pl-4"
        >

          <a href="/teachings" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Teachings</a>

          <a href="/dictionary" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Dictionary</a>

          <a href="/number" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Numbers</a>

          <a href="/prophecy" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Prophecy</a>

          <a href="/reflections" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Reflections</a>

          <a href="/resources" class="block rounded-lg px-3 py-2 hover:bg-[var(--color-bg-soft)]">Resources</a>

        </div>

      </div>

      <a href="/plans" class="block rounded-xl px-3 py-3 hover:bg-[var(--color-bg-soft)]">Plans</a>

      <a href="/bible" class="block rounded-xl px-3 py-3 hover:bg-[var(--color-bg-soft)]">Bible</a>

      <a
        href="https://play.first7.org"
        target="_blank"
        rel="noopener noreferrer"
        class="
          inline-flex
          w-fit
          items-center
          gap-2
          rounded-xl
          border
          border-[rgba(214,179,106,0.18)]
          bg-[rgba(214,179,106,0.08)]
          px-4
          py-3
          text-sm
          font-semibold
          text-[var(--color-primary)]
        "
      >
        Play ↗
      </a>

    </div>

  </div>

</nav>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {

  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  menuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  const accordions = [
    ["verses-btn", "mobile-verses", "verses-icon"],
    ["prayers-btn", "mobile-prayers", "prayers-icon"],
    ["library-btn", "mobile-library", "library-icon"],
  ];

  accordions.forEach(([buttonId, panelId, iconId]) => {

    const button = document.getElementById(buttonId);
    const panel = document.getElementById(panelId);
    const icon = document.getElementById(iconId);

    button?.addEventListener("click", () => {

      panel?.classList.toggle("hidden");
      icon?.classList.toggle("rotate-180");

    });

  });

});
</script>
