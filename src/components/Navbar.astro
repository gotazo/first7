---
import DarkToggle from "./DarkToggle.astro";

const pathname = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-[var(--color-bg)]/80 backdrop-blur border-b border-[var(--color-border)]">

  <div class="max-w-6xl mx-auto px-5 py-4 flex justify-between items-center">

    <!-- LOGO -->
    <a href="/" class="flex items-center gap-[4px] text-2xl md:text-3xl tracking-tight">
      <span
        class="text-[var(--color-text)]"
        style="font-family: 'Playfair Display', serif;"
      >
        first
      </span>

      <span
        class="text-[var(--color-primary)]"
        style="font-family: 'Inter', sans-serif;"
      >
        7
      </span>
    </a>

    <!-- DESKTOP NAV -->
    <div class="hidden md:flex items-center gap-6 text-sm">

      <!-- VERSES -->
      <div class="relative group">

        <a
          href="/verses"
          class="flex items-center gap-1 px-2 py-1 text-[var(--color-muted)] hover:text-[var(--color-text)]"
        >
          Verses
          <span class="text-xs">▼</span>
        </a>

        <div class="absolute left-1/2 -translate-x-1/2 top-full pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition duration-150">

          <div class="w-[500px] rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] shadow-xl p-6">

            <div class="grid grid-cols-2 gap-4">

              <div>
                <p class="text-xs uppercase text-[var(--color-muted)] mb-2">
                  Emotions
                </p>

                <a href="/verses/bible-verses-for-anxiety" class="block px-3 py-2 rounded-lg hover:bg-[var(--color-primary)]/10">
                  Anxiety
                </a>

                <a href="/verses/bible-verses-for-fear" class="block px-3 py-2 rounded-lg hover:bg-[var(--color-primary)]/10">
                  Fear
                </a>

                <a href="/verses/bible-verses-for-depression" class="block px-3 py-2 rounded-lg hover:bg-[var(--color-primary)]/10">
                  Depression
                </a>
              </div>

              <div>
                <p class="text-xs uppercase text-[var(--color-muted)] mb-2">
                  Growth
                </p>

                <a href="/verses/bible-verses-for-strength" class="block px-3 py-2 rounded-lg hover:bg-[var(--color-primary)]/10">
                  Strength
                </a>

                <a href="/verses/bible-verses-for-love" class="block px-3 py-2 rounded-lg hover:bg-[var(--color-primary)]/10">
                  Love
                </a>

                <a href="/verses/bible-verses-for-healing" class="block px-3 py-2 rounded-lg hover:bg-[var(--color-primary)]/10">
                  Healing
                </a>
              </div>

            </div>

          </div>

        </div>

      </div>

      <!-- PRAYERS -->
      <div class="relative group">

        <a
          href="/prayers"
          class="flex items-center gap-1 px-2 py-1 text-[var(--color-muted)] hover:text-[var(--color-text)]"
        >
          Prayers
          <span class="text-xs">▼</span>
        </a>

        <div class="absolute left-1/2 -translate-x-1/2 top-full pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition duration-150">

          <div class="w-[500px] rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] shadow-xl p-6">

            <div class="grid grid-cols-2 gap-4">

              <div>
                <p class="text-xs uppercase text-[var(--color-muted)] mb-2">
                  Needs
                </p>

                <a href="/prayers/anxiety" class="block px-3 py-2 rounded-lg hover:bg-[var(--color-primary)]/10">
                  Anxiety
                </a>

                <a href="/prayers/peace" class="block px-3 py-2 rounded-lg hover:bg-[var(--color-primary)]/10">
                  Peace
                </a>

                <a href="/prayers/healing" class="block px-3 py-2 rounded-lg hover:bg-[var(--color-primary)]/10">
                  Healing
                </a>
              </div>

              <div>
                <p class="text-xs uppercase text-[var(--color-muted)] mb-2">
                  Growth
                </p>

                <a href="/prayers/strength" class="block px-3 py-2 rounded-lg hover:bg-[var(--color-primary)]/10">
                  Strength
                </a>

                <a href="/prayers/guidance" class="block px-3 py-2 rounded-lg hover:bg-[var(--color-primary)]/10">
                  Guidance
                </a>
              </div>

            </div>

          </div>

        </div>

      </div>

<!-- PRIMARY NAV -->

<!-- VERSE JAR -->

<a
  href="/verse-jar"
  class={`transition ${
    pathname.startsWith("/verse-jar")
      ? "text-[var(--color-text)]"
      : "text-[var(--color-muted)] hover:text-[var(--color-text)]"
  }`}
>
  Verse Jar
</a>

<!-- ASK -->

<a
href="/ask"
class={`transition ${
    pathname.startsWith("/ask")
      ? "text-[var(--color-text)]"
      : "text-[var(--color-muted)] hover:text-[var(--color-text)]"
  }`}

>

Ask </a>

<!-- LIBRARY -->

<div class="relative group">

<a
href="/teachings"
class={`flex items-center gap-1 transition ${
      pathname.startsWith("/teachings") ||
      pathname.startsWith("/dictionary") ||
      pathname.startsWith("/prophecy") ||
      pathname.startsWith("/reflections") ||
      pathname.startsWith("/resources")
        ? "text-[var(--color-text)]"
        : "text-[var(--color-muted)] hover:text-[var(--color-text)]"
    }`}

>


Library

<span class="text-xs">▼</span>


  </a>

  <div class="absolute left-1/2 -translate-x-1/2 top-full pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition duration-150">


<div class="w-[280px] rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] shadow-xl p-4">

  <div class="space-y-1">

    <a
      href="/teachings"
      class="block rounded-lg px-3 py-2 hover:bg-[var(--color-primary)]/10"
    >
      Teachings
    </a>

    <a
      href="/dictionary"
      class="block rounded-lg px-3 py-2 hover:bg-[var(--color-primary)]/10"
    >
      Dictionary
    </a>

    <a
      href="/prophecy"
      class="block rounded-lg px-3 py-2 hover:bg-[var(--color-primary)]/10"
    >
      Prophecy
    </a>

    <a
      href="/reflections"
      class="block rounded-lg px-3 py-2 hover:bg-[var(--color-primary)]/10"
    >
      Reflections
    </a>

    <a
      href="/resources"
      class="block rounded-lg px-3 py-2 hover:bg-[var(--color-primary)]/10"
    >
      Resources
    </a>

  </div>

</div>

  </div>

</div>

<!-- PLANS -->

<a
href="/plans"
class={`transition ${
    pathname.startsWith("/plans")
      ? "text-[var(--color-text)]"
      : "text-[var(--color-muted)] hover:text-[var(--color-text)]"
  }`}

>

Plans </a>

<!-- BIBLE -->

<a
href="/bible"
class={`transition ${
    pathname.startsWith("/bible")
      ? "text-[var(--color-text)]"
      : "text-[var(--color-muted)] hover:text-[var(--color-text)]"
  }`}

>

Bible </a>


<!-- PLAY -->

<a
  href="https://play.first7.org"
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex items-center gap-2 rounded-full border border-[rgba(214,179,106,0.18)] bg-[rgba(214,179,106,0.08)] px-3 py-1.5 text-xs uppercase tracking-[0.16em] text-[var(--color-primary)] transition hover:border-[rgba(214,179,106,0.3)] hover:bg-[rgba(214,179,106,0.14)]"
>
  Play ↗
</a>

    </div>

    <!-- RIGHT -->
    <div class="flex items-center gap-4">

      <DarkToggle />

      <!-- MOBILE BUTTON -->
      <button
        id="menu-btn"
        class="md:hidden p-2 rounded-lg border border-[var(--color-border)]"
      >
        ☰
      </button>

    </div>

  </div>

  <!-- MOBILE MENU -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-[var(--color-border)]"
  >

    <div class="px-5 py-4 space-y-4">

      <!-- VERSES -->
      <div>

        <button
          id="verses-btn"
          class="w-full text-left font-medium"
        >
          Verses ▼
        </button>

        <div
          id="mobile-verses"
          class="hidden mt-2 space-y-2 pl-3 text-sm"
        >
          <a href="/verses/bible-verses-for-anxiety">Anxiety</a>
          <a href="/verses/bible-verses-for-fear">Fear</a>
          <a href="/verses/bible-verses-for-strength">Strength</a>
          <a href="/verses/bible-verses-for-depression">Depression</a>
          <a href="/verses/bible-verses-for-love">Love</a>
          <a href="/verses/bible-verses-for-healing">Healing</a>
        </div>

      </div>

      <!-- PRAYERS -->
      <div>

        <button
          id="prayers-btn"
          class="w-full text-left font-medium"
        >
          Prayers ▼
        </button>

        <div
          id="mobile-prayers"
          class="hidden mt-2 space-y-2 pl-3 text-sm"
        >
          <a href="/prayers/anxiety">Anxiety</a>
          <a href="/prayers/peace">Peace</a>
          <a href="/prayers/healing">Healing</a>
          <a href="/prayers/strength">Strength</a>
          <a href="/prayers/guidance">Guidance</a>
        </div>

      </div>

      <!-- PRIMARY MOBILE LINKS -->
      <a href="/verse-jar">Verse Jar</a>
      <a href="/ask">Ask</a>

<div>

<button
id="library-btn"
class="w-full text-left font-medium"

>

Library ▼


  </button>

  <div
    id="mobile-library"
    class="hidden mt-2 space-y-2 pl-3 text-sm"
  >


<a href="/teachings">Teachings</a>

<a href="/dictionary">Dictionary</a>

<a href="/prophecy">Prophecy</a>

<a href="/reflections">Reflections</a>

<a href="/resources">Resources</a>


  </div>

</div>


<a href="/plans">Plans</a>

<a href="/bible">Bible</a>

<a
  href="https://play.first7.org"
  class="inline-flex w-fit rounded-full border border-[rgba(214,179,106,0.18)] bg-[rgba(214,179,106,0.08)] px-3 py-2 text-xs uppercase tracking-[0.16em] text-[var(--color-primary)]"
>
  Play ↗
</a>

    </div>

  </div>

</nav>

<!-- MOBILE SCRIPT -->
<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {

    const btn = document.getElementById("menu-btn");
    const menu = document.getElementById("mobile-menu");

    const versesBtn = document.getElementById("verses-btn");
    const versesMenu = document.getElementById("mobile-verses");

    const prayersBtn = document.getElementById("prayers-btn");
    const prayersMenu = document.getElementById("mobile-prayers");

    btn?.addEventListener("click", () => {
      menu?.classList.toggle("hidden");
    });

    versesBtn?.addEventListener("click", () => {
      versesMenu?.classList.toggle("hidden");
    });

    prayersBtn?.addEventListener("click", () => {
      prayersMenu?.classList.toggle("hidden");
    });

    const libraryBtn =
    document.getElementById("library-btn");

    const libraryMenu =
    document.getElementById("mobile-library");

    libraryBtn?.addEventListener("click", () => {
    libraryMenu?.classList.toggle("hidden");
    });
  });
</script>