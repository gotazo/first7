---
import DarkToggle from "./DarkToggle.astro";

const pathname = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 bg-[var(--color-bg)]/80 backdrop-blur border-b border-[var(--color-border)]">

  <div class="max-w-6xl mx-auto px-5 py-4 flex justify-between items-center">

    <!-- LOGO -->
<a href="/" class="flex items-center gap-[4px] text-2xl md:text-3xl tracking-tight">

  <span
    class="text-[var(--color-text)]"
    style="
      font-family: 'Playfair Display', serif;
      font-weight: 400;
      letter-spacing: 0.01em;
      font-variant-ligatures: none;
    "
  >
    first
  </span>

  <span
    class="text-[var(--color-primary)]"
    style="
      font-family: 'Inter', sans-serif;
      font-weight: 500;
      font-size: 1.2em;
    "
  >
    7
  </span>

</a>

    <!-- NAV LINKS -->
    <div class="hidden md:flex items-center gap-6 text-sm">

      {[
        { href: "/plans", label: "Plans" },
        { href: "/reflections", label: "Reflections" },
        { href: "/bible", label: "Bible" },
        { href: "/blog", label: "Blog" },
        { href: "/resources", label: "Resources" },
        { href: "/guides", label: "Guides" },
        { href: "/about", label: "About" }
      ].map((link) => {
        const isActive = pathname.startsWith(link.href);

        return (
          <a
            href={link.href}
            class={`relative transition ${
              isActive
                ? "text-[var(--color-text)]"
                : "text-[var(--color-muted)] hover:text-[var(--color-text)]"
            }`}
          >
            {link.label}

            {/* underline */}
            <span
              class={`absolute left-0 -bottom-1 h-[2px] w-full bg-[var(--color-primary)] transition-transform duration-300 origin-left ${
                isActive ? "scale-x-100" : "scale-x-0 group-hover:scale-x-100"
              }`}
            ></span>
          </a>
        );
      })}

    </div>

    <!-- RIGHT -->
    <div class="flex items-center gap-4">

      <DarkToggle />

      <!-- MOBILE MENU BUTTON -->
      <button class="md:hidden p-2 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-primary)] transition">
        <span class="block w-5 h-[2px] bg-[var(--color-text)] mb-1"></span>
        <span class="block w-5 h-[2px] bg-[var(--color-text)] mb-1"></span>
        <span class="block w-5 h-[2px] bg-[var(--color-text)]"></span>
      </button>

    </div>

  </div>

</nav>
