---
import DarkToggle from "./DarkToggle.astro";
---

<nav class="sticky top-0 z-50 bg-[var(--color-bg)]/80 backdrop-blur border-b border-[var(--color-border)]">

  <div class="max-w-6xl mx-auto px-5 py-4 flex justify-between items-center">

    <!-- Logo -->
    <a href="/" class="text-2xl md:text-3xl tracking-tight font-medium text-[var(--color-text)] hover:opacity-90 transition">
      <span class="font-semibold">first</span>
      <span class="text-[var(--color-primary)] font-bold ml-[1px]">7</span>
    </a>

    <!-- Navigation -->
    <div class="hidden md:flex items-center gap-6 text-sm text-[var(--color-muted)]">

      <a href="/plans" class="hover:text-[var(--color-text)] transition">Plans</a>
      <a href="/reflections" class="hover:text-[var(--color-text)] transition">reflections</a>
      <a href="/bible" class="hover:text-[var(--color-text)] transition">Bible</a>
      <a href="/blog" class="hover:text-[var(--color-text)] transition">Blog</a>
      <a href="/resources" class="hover:text-[var(--color-text)] transition">Resources</a>
      <a href="/guides" class="hover:text-[var(--color-text)] transition">Guides</a>
      <a href="/about" class="hover:text-[var(--color-text)] transition">About</a>

    </div>

    <!-- Right side -->
    <div class="flex items-center gap-4">

      <DarkToggle />

      <!-- Mobile menu button (future upgrade) -->
      <button class="md:hidden text-[var(--color-muted)]">
        ☰
      </button>

    </div>

  </div>

</nav>