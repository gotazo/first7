---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact">

  <div class="max-w-3xl mx-auto space-y-6">

    <h1 class="text-3xl font-semibold">Contact</h1>

    <p class="text-[var(--color-muted)]">
      Have a question, suggestion, or feedback? I’d love to hear from you.
    </p>

    <p>
      Email: <a href="mailto:hello@first7.com" class="underline">Contact</a>
    </p>

    <p class="text-sm text-[var(--color-muted)]">
      I may not be able to respond to every message, but I do read all feedback.
    </p>

  </div>

</BaseLayout>