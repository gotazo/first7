---
export const prerender = true;

import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

import FinanceTool from '../../components/tools/finance/FinanceTool.astro';

import BiblicalNameGenerator
from '../../components/tools/biblical-name-generator/BiblicalNameGenerator.astro';

import BibleReadingPlan
from '../../components/tools/bible-reading-plan/BibleReadingPlan.astro';

type ToolEntry = CollectionEntry<'tools'>;

export async function getStaticPaths() {
  const entries = await getCollection('tools');

  const paths = entries.map((entry: ToolEntry) => ({
    params: { slug: entry.data.slug },
    props: { entry }
  }));

  if (import.meta.env.BUILD_TRACE === 'true') {
    console.log(`[build:paths] tools paths=${paths.length}`);
  }

  return paths;
}

const { entry } = Astro.props as { entry: ToolEntry };
const { Content } = await render(entry);
const allTools = await getCollection('tools');

const relatedTools = allTools
.filter((tool) => tool.data.slug !== entry.data.slug)
.sort((a, b) => (a.data.order || 999) - (b.data.order || 999))
.slice(0, 6);

// ✅ FIXED COMPONENT MAPPING (type-safe)
const components = {
  FinanceTool,
  BiblicalNameGenerator,
  BibleReadingPlan,
} as const;

type ComponentKey = keyof typeof components;

const ToolComponent =
  components[entry.data.component as ComponentKey] || null;

---

<BaseLayout title={entry.data.title} description={entry.data.description} full={true}>

  <div class="mx-auto w-[90%] max-w-[1400px] px-4">

    <div class="grid lg:grid-cols-[minmax(0,1fr)_280px] gap-12">

      <!-- MAIN -->
      <article class="max-w-2xl mx-auto py-12">

        <!-- HEADER -->
        <header class="mb-10 space-y-4">

          <p class="text-sm uppercase tracking-wide text-[var(--color-primary)]">
            Tools
          </p>

          <h1 class="text-3xl md:text-5xl font-semibold leading-tight">
            {entry.data.title}
          </h1>

          <div class="space-y-3">

  <p class="text-[var(--color-muted)]">
    {entry.data.description}
  </p>

  {entry.data.slug === "biblical-name-generator" && (

    <p class="text-sm md:text-base text-[var(--color-muted)] max-w-2xl leading-relaxed">

      The ultimate scripture-inspired naming tool with real biblical names,
      generated names, meanings, and themed inspiration.

    </p>

  )}

</div>

        </header>

        <!-- TOOL -->
        <div class="mb-12">
          {ToolComponent ? <ToolComponent /> : <p>Tool not found.</p>}
        </div>

        <!-- CONTENT -->
        <div class="prose prose-neutral dark:prose-invert">
          <Content />
        </div>

      </article>

      <!-- SIDEBAR -->
      <aside class="hidden lg:block py-12">

        <div class="sticky top-24 space-y-6">

          <div class="rounded-2xl border border-[var(--color-border)] p-5 space-y-3">

            <p class="font-medium">More tools</p>

            <div class="space-y-2 text-sm">
                <div class="space-y-3">

                <a
                href="/tools"
                class="block text-sm font-medium hover:text-[var(--color-primary)] transition"

                >

                ← All tools


                  </a>

                  <div class="pt-2 space-y-2">


                {relatedTools.map((tool) => (

                  <a
                    href={`/tools/${tool.data.slug}`}
                    class="block rounded-xl border border-[var(--color-border)] p-3 transition hover:border-[var(--color-primary)] hover:bg-[var(--color-primary)]/5"
                  >

                    <p class="text-sm font-medium">
                      {tool.data.title}
                    </p>

                    <p class="mt-1 text-xs text-[var(--color-muted)] line-clamp-2">
                      {tool.data.description}
                    </p>

                  </a>

                ))}


                  </div>

                </div>

            </div>

          </div>

        </div>

      </aside>

    </div>

  </div>

</BaseLayout>
