---
export const prerender = true;

import BibleLayout from "../../../layouts/BibleLayout.astro";

import {
  getRelatedProphecy,
} from "../../../lib/relationships/getRelatedProphecy";

import {
  getRelatedDictionary,
} from "../../../lib/relationships/getRelatedDictionary";

import {
  getRelatedTeachings,
} from "../../../lib/relationships/getRelatedTeachings";

type BibleData = {
  book: string;
  chapters: Record<string, string[]>;
};

/**
 * ✅ STATIC PATHS
 */
export function getStaticPaths() {

  const bibleModules =
    import.meta.glob(
      "../../../data/bible/*.json",
      { eager: true }
    ) as Record<
      string,
      { default: BibleData }
    >;

  const paths =
    Object.entries(bibleModules)
      .flatMap(([key, module]) => {

        const book =
          key
            .split("/")
            .pop()
            ?.replace(".json", "");

        if (!book) return [];

        return Object.keys(
          module.default.chapters
        ).map((chapter) => ({

          params: {
            book,
            chapter,
          },

        }));

      });

  return paths;

}

/**
 * 📚 LOAD BIBLE MODULES
 */
const bibleModules =
  import.meta.glob(
    "../../../data/bible/*.json",
    { eager: true }
  ) as Record<
    string,
    { default: BibleData }
  >;

/**
 * 📍 ROUTE PARAMS
 */
const { book, chapter } =
  Astro.params as {
    book: string;
    chapter: string;
  };

if (!book || !chapter) {

  throw new Error(
    "Missing route params"
  );

}

const chapterNumber =
  Number(chapter);

/**
 * 🔍 FIND BOOK FILE
 */
const fileKey =
  Object.keys(bibleModules)
    .find((key) =>
      key.endsWith(
        `${book.toLowerCase()}.json`
      )
    );

let data: BibleData | null =
  null;

let verses: string[] = [];

if (fileKey) {

  data =
    bibleModules[fileKey].default;

  const chapterKey =
    String(chapterNumber);

  verses =
    data.chapters[chapterKey] || [];

} else {

  console.error(
    "Book not found:",
    book
  );

}

/**
 * 📖 SCRIPTURE KEY
 */
const scriptureKey =
  data
    ? `${data.book} ${chapterNumber}`
    : "";

/**
 * 🔮 RELATED CONTENT
 */
const prophecyEntries =
  await getRelatedProphecy(
    scriptureKey
  );

const dictionaryEntries =
  await getRelatedDictionary(
    scriptureKey
  );

const teachingEntries =
  await getRelatedTeachings(
    scriptureKey
  );
---

<BibleLayout
  currentBook={book}
  currentChapter={chapterNumber}

  relatedProphecy={
    prophecyEntries
  }

  relatedDictionary={
    dictionaryEntries
  }

  relatedTeachings={
    teachingEntries
  }
>

  <!-- 📖 HEADER -->
  <Fragment slot="header">

    <h1
      class="
        text-4xl
        font-semibold
        tracking-tight
      "
    >

      {data?.book} {chapterNumber}

    </h1>

  </Fragment>

  <!-- 📜 VERSES -->
  <div
    class="
      space-y-6
      text-lg
      leading-relaxed
    "
  >

    {verses.map(
      (
        verse: string,
        i: number
      ) => (

        <p
          id={`v${i + 1}`}
          class="
            bible-verse
            scroll-mt-40
          "
        >

          <span
            class="
              verse-number
              mr-2
              text-sm
              text-[var(--color-muted)]
            "
          >

            {i + 1}

          </span>

          {verse}

        </p>

      )
    )}

  </div>

</BibleLayout>

<script is:inline>
  const match =
    window.location.hash.match(
      /^#v(\d+)$/
    );

  const verseNumber =
    match?.[1];

  if (verseNumber) {
    const verse =
      document.getElementById(
        `v${verseNumber}`
      );

    if (verse) {
      verse.classList.add(
        "bible-verse-target"
      );

      requestAnimationFrame(() => {
        verse.scrollIntoView({
          block: "start",
          behavior: "smooth"
        });
      });
    }
  }
</script>

<style>
  .bible-verse-target {
    border-left: 3px solid
      var(--color-primary);
    background:
      color-mix(
        in srgb,
        var(--color-primary) 12%,
        transparent
      );
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;
  }
</style>
