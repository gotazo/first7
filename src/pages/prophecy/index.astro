---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import StudyHero from "../../components/shared/StudyHero.astro";

import { getCollection } from "astro:content";

const entries = (
await getCollection("prophecy")
)
.filter((entry) => !entry.data.draft)
.sort((a, b) =>
a.data.title.localeCompare(
b.data.title
)
);

const categoryOrder = [
  "symbols",
  "people",
  "nations",
  "places",
  "events",
  "timelines",
];

const categories = Array.from(
  new Set(
    entries.map(
      (entry) => entry.data.category
    )
  )
).sort(
  (a, b) =>
    categoryOrder.indexOf(a) -
    categoryOrder.indexOf(b)
);

const categoryGroups =
categories.map((category) => ({
category,
items: entries.filter(
(entry) =>
entry.data.category === category
),
}));
---

<BaseLayout
  title="Bible Prophecy Study"
  description="Study Bible prophecy through Scripture, symbols, nations, people, timelines, and connected prophetic themes."
>

  <main
    class="
      mx-auto
      max-w-6xl
      px-4
      py-16
      sm:px-6
    "
  >

    <StudyHero
      section="Bible Prophecy"
      title="Bible Prophecy Study"
      description="Explore Bible prophecy through organized studies on symbols, nations, people, timelines, and prophetic themes."
    />

    <section
      class="
        mt-8
        text-center
      "
    >

      <p
        class="
          text-[var(--color-muted)]
        "
      >
        {entries.length} Topics ·
        {categories.length} Categories
      </p>

    </section>

    <!-- Category Navigation -->

    <section
      class="
        mt-10
        flex
        flex-wrap
        justify-center
        gap-2
      "
    >

      {categories.map(
        (category) => (

          <a
            href={`#${category}`}
            class="
              rounded-lg
              border
              border-[var(--color-border)]
              px-3
              py-2
              text-sm
              capitalize
              transition
              hover:border-[var(--color-primary)]
            "
          >
            {category}
          </a>

        )
      )}

    </section>

    <!-- Category Sections -->

    <section
      class="
        mt-16
        space-y-16
      "
    >

      {categoryGroups.map(
        ({ category, items }) => (

          <section
            id={category}
            class="space-y-6"
          >

            <div
              class="
                flex
                items-center
                gap-4
              "
            >

              <h2
                class="
                  text-3xl
                  font-bold
                  capitalize
                "
              >
                {category}
              </h2>

              <div
                class="
                  h-px
                  flex-1
                  bg-[var(--color-border)]
                "
              />

            </div>

            <div
              class="
                grid
                gap-4
                md:grid-cols-2
                lg:grid-cols-3
              "
            >

              {items.map(
                (item) => (

                  <a
                    href={`/prophecy/${item.id}`}
                    class="
                      rounded-2xl
                      border
                      border-[var(--color-border)]
                      p-5
                      transition
                      hover:border-[var(--color-primary)]
                      hover:-translate-y-0.5
                    "
                  >

                    <div class="space-y-2">

                      <h3
                        class="
                          text-lg
                          font-semibold
                        "
                      >
                        {item.data.title}
                      </h3>

                      <p
                        class="
                          text-sm
                          leading-relaxed
                          text-[var(--color-muted)]
                        "
                      >
                        {item.data.description}
                      </p>

                    </div>

                  </a>

                )
              )}

            </div>

          </section>

        )
      )}

    </section>

  </main>

</BaseLayout>
