---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";

import { getCollection } from "astro:content";

const entries = await getCollection("prophecy");

const symbols = entries.filter(
  (e) => e.data.category === "symbols" && !e.data.draft
);

const people = entries.filter(
  (e) => e.data.category === "people" && !e.data.draft
);

const nations = entries.filter(
  (e) => e.data.category === "nations" && !e.data.draft
);

const timeline = entries.filter(
  (e) => e.data.category === "timeline" && !e.data.draft
);

const dictionary = await getCollection("dictionary");
---

<BaseLayout
  title="Bible Prophecy Study"
  description="Study Bible prophecy through Scripture, symbols, nations, people, timelines, and connected KJV study terms."
>

  <main class="mx-auto w-full max-w-7xl px-4 py-16 sm:px-6">

    <!-- Hero -->
    <section class="mx-auto max-w-4xl space-y-8 text-center">

      <div class="space-y-4">

        <p class="text-sm uppercase tracking-[0.3em] text-[var(--color-muted)]">
          Scripture First
        </p>

        <h1 class="text-5xl font-semibold tracking-tight sm:text-6xl">

          Bible Prophecy Study

        </h1>

        <p class="mx-auto max-w-3xl text-lg leading-relaxed text-[var(--color-muted)]">

          Explore Bible prophecy through carefully organized KJV Scriptures,
          study terms, symbols, nations, people, and connected references.

        </p>

      </div>

    </section>

    <!-- Main Grid -->
    <div class="mt-20 grid gap-10 lg:grid-cols-2">

      <!-- Symbols -->
      <section class="space-y-5 rounded-3xl border border-[var(--color-border)] p-8">

        <div class="space-y-2">

          <h2 class="text-3xl font-semibold">
            Symbols
          </h2>

          <p class="text-[var(--color-muted)]">

            Study symbolic imagery used throughout prophetic Scripture.

          </p>

        </div>

        <div class="space-y-3">

          {symbols.map((item) => (

            <a
              href={`/prophecy/${item.id}`}
              class="block rounded-2xl border border-transparent px-4 py-3 transition hover:border-[var(--color-border)] hover:bg-[var(--color-surface)]"
            >

              <div class="space-y-1">

                <h3 class="font-medium">
                  {item.data.title}
                </h3>

                <p class="text-sm text-[var(--color-muted)]">
                  {item.data.description}
                </p>

              </div>

            </a>

          ))}

        </div>

      </section>

      <!-- People -->
      <section class="space-y-5 rounded-3xl border border-[var(--color-border)] p-8">

        <div class="space-y-2">

          <h2 class="text-3xl font-semibold">
            People
          </h2>

          <p class="text-[var(--color-muted)]">

            Explore prophetic figures and individuals mentioned in Scripture.

          </p>

        </div>

        <div class="space-y-3">

          {people.map((item) => (

            <a
              href={`/prophecy/${item.id}`}
              class="block rounded-2xl border border-transparent px-4 py-3 transition hover:border-[var(--color-border)] hover:bg-[var(--color-surface)]"
            >

              <div class="space-y-1">

                <h3 class="font-medium">
                  {item.data.title}
                </h3>

                <p class="text-sm text-[var(--color-muted)]">
                  {item.data.description}
                </p>

              </div>

            </a>

          ))}

        </div>

      </section>

      <!-- Nations -->
      <section class="space-y-5 rounded-3xl border border-[var(--color-border)] p-8">

        <div class="space-y-2">

          <h2 class="text-3xl font-semibold">
            Nations
          </h2>

          <p class="text-[var(--color-muted)]">

            Study nations and kingdoms connected with Bible prophecy.

          </p>

        </div>

        <div class="space-y-3">

          {nations.map((item) => (

            <a
              href={`/prophecy/${item.id}`}
              class="block rounded-2xl border border-transparent px-4 py-3 transition hover:border-[var(--color-border)] hover:bg-[var(--color-surface)]"
            >

              <div class="space-y-1">

                <h3 class="font-medium">
                  {item.data.title}
                </h3>

                <p class="text-sm text-[var(--color-muted)]">
                  {item.data.description}
                </p>

              </div>

            </a>

          ))}

        </div>

      </section>

      <!-- Timeline -->
      <section class="space-y-5 rounded-3xl border border-[var(--color-border)] p-8">

        <div class="space-y-2">

          <h2 class="text-3xl font-semibold">
            Timeline
          </h2>

          <p class="text-[var(--color-muted)]">

            Explore prophetic events and their Scriptural connections.

          </p>

        </div>

        <div class="space-y-3">

          {timeline.map((item) => (

            <a
              href={`/prophecy/${item.id}`}
              class="block rounded-2xl border border-transparent px-4 py-3 transition hover:border-[var(--color-border)] hover:bg-[var(--color-surface)]"
            >

              <div class="space-y-1">

                <h3 class="font-medium">
                  {item.data.title}
                </h3>

                <p class="text-sm text-[var(--color-muted)]">
                  {item.data.description}
                </p>

              </div>

            </a>

          ))}

        </div>

      </section>

    </div>

    <!-- Dictionary -->
    <section class="mt-20 space-y-8">

      <div class="space-y-3">

        <h2 class="text-4xl font-semibold">
          Prophecy Dictionary
        </h2>

        <p class="max-w-3xl text-[var(--color-muted)]">

          Understand prophetic words, symbols, and KJV study terms through
          connected Scripture references and simple explanations.

        </p>

      </div>

      <div class="flex flex-wrap gap-3">

        {dictionary.map((term) => (

          <a
            href={`/prophecy/dictionary/${term.id}`}
            class="rounded-full border border-[var(--color-border)] px-4 py-2 text-sm transition hover:border-[var(--color-primary)]"
          >

            {term.data.title}

          </a>

        ))}

      </div>

    </section>

  </main>

</BaseLayout>
