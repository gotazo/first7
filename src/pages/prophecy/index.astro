---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("prophecy");

const symbols = entries.filter(
  (e) => e.data.category === "symbols" && !e.data.draft
);

const people = entries.filter(
  (e) => e.data.category === "people" && !e.data.draft
);

const nations = entries.filter(
  (e) => e.data.category === "nations" && !e.data.draft
);

const timeline = entries.filter(
  (e) => e.data.category === "timeline" && !e.data.draft
);

const dictionary = await getCollection("dictionary");

const prophecyGroups = [
  {
    title: "Symbols",
    description:
      "Study symbolic imagery used throughout prophetic Scripture.",
    items: symbols.sort((a, b) =>
      a.data.title.localeCompare(b.data.title)
    ),
  },
  {
    title: "People",
    description:
      "Explore prophetic figures and individuals mentioned in Scripture.",
    items: people.sort((a, b) =>
      a.data.title.localeCompare(b.data.title)
    ),
  },
  {
    title: "Nations",
    description:
      "Study nations and kingdoms connected with Bible prophecy.",
    items: nations.sort((a, b) =>
      a.data.title.localeCompare(b.data.title)
    ),
  },
  {
    title: "Timeline",
    description:
      "Explore prophetic events and their Scriptural connections.",
    items: timeline.sort((a, b) =>
      a.data.title.localeCompare(b.data.title)
    ),
  },
].filter((group) => group.items.length > 0);
---

<BaseLayout
  title="Bible Prophecy Study"
  description="Study Bible prophecy through Scripture, symbols, nations, people, timelines, and connected KJV study terms."
>

  <main class="mx-auto w-full max-w-7xl px-4 py-16 sm:px-6">

    <section class="space-y-8">

      <div class="space-y-4">

        <h1 class="text-4xl font-semibold tracking-tight">
          Bible Prophecy Study
        </h1>

        <p class="max-w-3xl text-lg leading-relaxed text-[var(--color-muted)]">
          Explore Bible prophecy through organized studies on symbols,
          prophetic people, nations, timelines, and connected Scripture
          references.
        </p>

      </div>

      <section class="space-y-3">

        <h2 class="text-2xl font-semibold">
          Browse Prophecy Topics
        </h2>

        <p class="max-w-2xl text-[var(--color-muted)]">
          Explore key areas of Bible prophecy and study connected
          Scriptures through organized topics.
        </p>

      </section>

      <!-- Masonry -->

      <section class="library-masonry">

        {prophecyGroups.map((group) => (

          <section
          class="library-card rounded-xl border p-7"
          >

            <div>

              <div>

                <h3 class="text-xl font-semibold leading-snug">
                  {group.title}
                </h3>

                <p class="mt-2 text-base font-medium leading-relaxed">
                  {group.description}
                </p>

              </div>

            </div>

            <ul class="mt-6 space-y-2">

              {group.items.map((item) => (

                <li>

                  <a
                    href={`/prophecy/${item.id}`}
                    class="card group block rounded-xl p-5"
                  >

                    <span class="text-sm text-[var(--color-muted)] group-hover:text-[var(--color-text)]">
                      {item.data.title}
                    </span>

                    <span class="text-[var(--color-muted)] opacity-0 transition group-hover:translate-x-1 group-hover:opacity-100">
                      →
                    </span>

                  </a>

                </li>

              ))}

            </ul>

          </section>

        ))}

        <!-- Dictionary -->

        <section
        class="library-card rounded-xl border p-7"
        >

          <div>

            <div>

              <h3 class="text-xl font-semibold leading-snug">
                Prophecy Dictionary
              </h3>

              <p class="mt-2 text-base font-medium leading-relaxed">
                Understand prophetic words, symbols, and study terms.
              </p>

            </div>


          </div>

          <ul class="mt-5 space-y-2">

            {dictionary
              .sort((a, b) =>
                a.data.title.localeCompare(b.data.title)
              )
              .map((term) => (

                <li>

                  <a
                    href={`/dictionary/${term.id}`}
                    class="card group block rounded-xl p-5"
                  >

                    <span class="text-sm text-[var(--color-muted)] group-hover:text-[var(--color-text)]">
                      {term.data.title}
                    </span>

                    <span class="text-[var(--color-muted)] opacity-0 transition group-hover:translate-x-1 group-hover:opacity-100">
                      →
                    </span>

                  </a>

                </li>

              ))}

          </ul>

        </section>

      </section>

      <!-- Continue Study -->

      <section class="card rounded-2xl p-8">

        <div class="space-y-3">

            <h2 class="text-3xl font-semibold">
              Continue Your Study
            </h2>

          <p class="max-w-2xl text-[var(--color-muted)]">
            Bible prophecy is best understood alongside the broader
            teaching of Scripture. Continue exploring related study
            resources.
          </p>

        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-3">

            <a
              href="/dictionary"
              class="card block rounded-xl p-5"
            >

            <h3 class="font-semibold">
              Bible Dictionary
            </h3>

            <p class="mt-2 text-sm text-[var(--color-muted)]">
              Study biblical words, themes, and meanings.
            </p>

          </a>

          <a
            href="/teachings"
            class="card block rounded-xl p-5"
          >

              <h3 class="font-semibold">
              Teachings Library
            </h3>

            <p class="mt-2 text-sm text-[var(--color-muted)]">
              Explore structured Bible teachings by topic.
            </p>

          </a>

          <a
            href="/bible"
            class="card block rounded-xl p-5"
          >

              <h3 class="font-semibold">
              Read the Bible
            </h3>

            <p class="mt-2 text-sm text-[var(--color-muted)]">
              Read and search Scripture alongside your studies.
            </p>

          </a>

        </div>

      </section>

    </section>

  </main>

</BaseLayout>
