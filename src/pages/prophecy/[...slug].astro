---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";

import StudyHero
  from "../../components/shared/StudyHero.astro";

import TopicChips
  from "../../components/shared/TopicChips.astro";

import ScriptureBlock
  from "../../components/prophecy/ScriptureBlock.astro";

import StudyTerms
  from "../../components/prophecy/StudyTerms.astro";

import RelatedScriptures
  from "../../components/prophecy/RelatedScriptures.astro";

import RelatedTopics
  from "../../components/prophecy/RelatedTopics.astro";

import {
  getCollection,
  render,
} from "astro:content";

export async function getStaticPaths() {

  const entries =
    await getCollection("prophecy");

  return entries
    .filter(
      (entry) => !entry.data.draft
    )
    .map((entry) => ({

      params: {
        slug: entry.id,
      },

      props: {
        entry,
      },

    }));

}

const { entry } = Astro.props;

/**
 * 📄 Render markdown
 */
const { Content } =
  await render(entry);

/**
 * 📚 Collections
 */
const allProphecy =
  await getCollection("prophecy");

const allDictionary =
  await getCollection("dictionary");

/**
 * 🔗 Related prophecy topics
 */
const relatedTopics =
  allProphecy.filter((item) =>
    entry.data.related.includes(
      item.id
    )
  );

/**
 * 📘 Dictionary term linking
 */
const prophecyTerms =
  entry.data.terms.map(
    (term: string) =>
      term.toLowerCase()
  );

const dictionaryTerms =
  allDictionary.filter((term) =>
    prophecyTerms.includes(
      term.data.term.toLowerCase()
    )
  );
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
>

  <main
    class="
      mx-auto
      w-full
      max-w-4xl
      px-4
    "
  >

    <!-- Hero Search -->
    <StudyHero
      section="Biblical Prophecy"
      title={entry.data.title}
      description={entry.data.description}
      searchPlaceholder="Search prophecy..."
    />

    <TopicChips
      items={[
        {
          label: "Israel",
          href: "/prophecy/nations/israel"
        },
        {
          label: "Babylon",
          href: "/prophecy/nations/babylon"
        },
        {
          label: "Daniel",
          href: "/prophecy/people/daniel"
        },
        {
          label: "Beast",
          href: "/prophecy/symbols/beast"
        }
      ]}
    />

    <article class="space-y-12">

      <!-- Featured Verse -->
      {entry.data.featuredVerse && (

        <ScriptureBlock
          ref={
            entry.data.featuredVerse.ref
          }
          text={
            entry.data.featuredVerse.text
          }
        />

      )}

      <!-- Main Content -->
      <section
        class="
          prose
          prose-invert
          max-w-none
        "
      >

        <Content />

      </section>

      <!-- Related Scriptures -->
      {entry.data.scriptures.length > 0 && (

        <RelatedScriptures
          scriptures={
            entry.data.scriptures
          }
        />

      )}

      <!-- Dictionary Terms -->
      {dictionaryTerms.length > 0 && (

        <StudyTerms
          terms={dictionaryTerms}
        />

      )}

      <!-- Study Notes -->
      {entry.data.notes.length > 0 && (

        <section class="space-y-4">

          <h2
            class="
              text-2xl
              font-semibold
            "
          >

            Study Notes

          </h2>

          <ul class="space-y-3">

            {entry.data.notes.map(
              (note: string) => (

                <li
                  class="
                    rounded-2xl
                    border
                    border-[var(--color-border)]
                    p-4
                    text-[15px]
                    leading-relaxed
                  "
                >

                  {note}

                </li>

              )
            )}

          </ul>

        </section>

      )}

      <!-- Related Topics -->
      {relatedTopics.length > 0 && (

        <RelatedTopics
          topics={relatedTopics}
        />

      )}

    </article>

  </main>

</BaseLayout>
