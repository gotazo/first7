---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TeachingSidebar from "../../components/TeachingSidebar.astro";
import { getCollection } from "astro:content";

const teachings = await getCollection("teachings");

const topics = Array.from(new Set(teachings.flatMap((t) => t.data.topics))).sort();

const topicGroups = topics.map((topic) => ({
  topic,
  teachings: teachings
    .filter((t) => t.data.topics.includes(topic))
    .sort((a, b) => a.data.title.localeCompare(b.data.title)),
}));
---

<BaseLayout title="Library">

  <div class="flex flex-col lg:flex-row gap-10">

    <TeachingSidebar />

    <main class="flex-1">

      <section class="space-y-6">

        <h1 class="text-2xl font-semibold">
          Library
        </h1>

        <div class="space-y-10">

          <!-- INTRO -->
          <section class="space-y-3">
            <h2 class="text-xl font-medium">
              Browse Teachings by Topic
            </h2>

            <p class="text-[var(--color-muted)] max-w-2xl">
              Explore structured teachings organized by spiritual themes,
              growth areas, and life seasons.
            </p>
          </section>

          <!-- TOPICS MASONRY -->
          <section class="topics-masonry">

            {topicGroups.map(({ topic, teachings }) => (

              <section
                class="topic-card rounded-xl border p-5 transition"
              >
                <div class="flex items-start justify-between gap-4">
                  <h3 class="font-medium capitalize leading-snug">
                    {topic}
                  </h3>

                  <span class="topic-count rounded-full border px-2.5 py-1 text-xs text-[var(--color-muted)]">
                    {teachings.length}
                  </span>
                </div>

                <ul class="mt-3 space-y-2">
                  {teachings.map((teaching) => (
                    <li>
                      <a
                        href={`/teachings/${teaching.id}`}
                        class="block text-sm text-[var(--color-muted)] hover:text-[var(--color-text)]"
                      >
                        {teaching.data.title}
                      </a>
                    </li>
                  ))}
                </ul>

              </section>

            ))}

          </section>

        </div>

      </section>

    </main>

  </div>

</BaseLayout>

<style>
  .topics-masonry {
    column-count: 1;
    column-gap: 1rem;
  }

  .topic-card {
    break-inside: avoid;
    display: inline-block;
    margin: 0 0 1rem;
    width: 100%;
    background: color-mix(in srgb, var(--color-bg) 94%, var(--color-primary));
    vertical-align: top;
  }

  .topic-card:hover {
    background: color-mix(in srgb, var(--color-bg) 88%, var(--color-primary));
    border-color: color-mix(in srgb, var(--color-primary) 45%, transparent);
    box-shadow: 0 14px 36px color-mix(in srgb, var(--color-primary) 12%, transparent);
    transform: translateY(-2px);
  }

  .topic-count {
    line-height: 1;
    white-space: nowrap;
  }

  @media (min-width: 640px) {
    .topics-masonry {
      column-count: 2;
      column-gap: 1.125rem;
    }

    .topic-card {
      margin-bottom: 1.125rem;
    }
  }

  @media (min-width: 1024px) {
    .topics-masonry {
      column-count: 3;
      column-gap: 1.25rem;
    }

    .topic-card {
      margin-bottom: 1.25rem;
    }
  }

  @media (min-width: 1536px) {
    .topics-masonry {
      column-count: 4;
    }
  }
</style>
