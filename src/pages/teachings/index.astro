---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TeachingSidebar from "../../components/TeachingSidebar.astro";
import { getCollection } from "astro:content";

const teachings = await getCollection("teachings");

const topics = Array.from(new Set(teachings.flatMap((t) => t.data.topics))).sort();

const topicGroups = topics.map((topic) => ({
  topic,
  teachings: teachings
    .filter((t) => t.data.topics.includes(topic))
    .sort((a, b) => a.data.title.localeCompare(b.data.title)),
}));
---

<BaseLayout title="Library">

  <div class="flex flex-col lg:flex-row gap-10">

    <TeachingSidebar />

    <main class="flex-1">

      <section class="space-y-6">

        <h1 class="text-2xl font-semibold">
          Library
        </h1>

        <div class="space-y-10">

          <!-- INTRO -->
          <section class="space-y-3">
            <h2 class="text-xl font-medium">
              Browse Teachings by Topic
            </h2>

            <p class="text-[var(--color-muted)] max-w-2xl">
              Explore structured teachings organized by spiritual themes,
              growth areas, and life seasons.
            </p>
          </section>

          <!-- TOPICS GRID -->
          <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">

            {topicGroups.map(({ topic, teachings }) => (

              <section
                class="rounded-xl border p-5 hover:bg-[var(--color-primary)]/5 transition"
              >
                <h3 class="font-medium capitalize">
                  {topic}
                </h3>

                <ul class="mt-3 space-y-2">
                  {teachings.map((teaching) => (
                    <li>
                      <a
                        href={`/teachings/${teaching.id}`}
                        class="block text-sm text-[var(--color-muted)] hover:text-[var(--color-text)]"
                      >
                        {teaching.data.title}
                      </a>
                    </li>
                  ))}
                </ul>

              </section>

            ))}

          </section>

        </div>

      </section>

    </main>

  </div>

</BaseLayout>
