---

import BaseLayout from "../../layouts/BaseLayout.astro";
import TeachingSidebar from "../../components/TeachingSidebar.astro";
import { getCollection } from "astro:content";

const teachings =
await getCollection("teachings");

/**

* Get unique topics
  */
  const topics = Array.from(
  new Set(
  teachings.flatMap(
  (t) => t.data.topics
  )
  )
  ).sort();

/**

* Group topics by first letter
  */
  const groupedTopics = topics.reduce(
  (groups, topic) => {

  const letter =
  topic.charAt(0).toUpperCase();

  if (!groups[letter]) {
  groups[letter] = [];
  }

  groups[letter].push({
  topic,

  teachings:
  teachings
  .filter((t) =>
  t.data.topics.includes(
  topic
  )
  )
  .sort((a, b) =>
  a.data.title.localeCompare(
  b.data.title
  )
  ),
  });

  return groups;

},
{} as Record<
string,
{
topic: string;
teachings: typeof teachings;
}[]

>

);

const letters =
Object.keys(groupedTopics)
.sort();

---

<BaseLayout title="Library">

  <div
    class="
      flex
      flex-col
      lg:flex-row
      gap-10
    "
  >

<TeachingSidebar />

<main class="flex-1">

  <section class="space-y-8">

    <header class="space-y-4">

      <h1
        class="
          text-3xl
          font-semibold
        "
      >
        Library
      </h1>

      <p
        class="
          max-w-3xl
          text-[var(--color-muted)]
        "
      >
        Explore structured biblical
        teachings organized by topic.
        Study doctrine, Christian living,
        prophecy, prayer, discipleship,
        and spiritual growth through
        Scripture.
      </p>

      <div
        class="
          flex
          flex-wrap
          gap-6
          text-sm
          text-[var(--color-muted)]
        "
      >

        <span>
          {teachings.length}
          Teachings
        </span>

        <span>
          {topics.length}
          Topics
        </span>

      </div>

    </header>

    <!-- A-Z Navigation -->

    <section
      class="
        flex
        flex-wrap
        gap-2
      "
    >

      {letters.map(
        (letter) => (

          <a
            href={`#${letter}`}
            class="
              rounded-lg
              border
              border-[var(--color-border)]
              px-3
              py-2
              text-sm
              transition
              hover:border-[var(--color-primary)]
            "
          >
            {letter}
          </a>

        )
      )}

    </section>

    <!-- Topic Groups -->

    <section
      class="
        mt-8
        space-y-16
      "
    >

      {letters.map(
        (letter) => (

          <section
            id={letter}
            class="space-y-6"
          >

            <div
              class="
                flex
                items-center
                gap-4
              "
            >

              <h2
                class="
                  text-4xl
                  font-bold
                "
              >
                {letter}
              </h2>

              <div
                class="
                  h-px
                  flex-1
                  bg-[var(--color-border)]
                "
              />

            </div>

            <div
              class="
                grid
                gap-4
                md:grid-cols-2
                xl:grid-cols-3
              "
            >

              {groupedTopics[
                letter
              ].map(
                ({
                  topic,
                  teachings,
                }) => (

                  <section
                    class="
                      rounded-2xl
                      border
                      border-[var(--color-border)]
                      p-5
                    "
                  >

                    <div
                      class="
                        flex
                        items-center
                        justify-between
                        gap-4
                      "
                    >

                      <h3
                        class="
                          text-lg
                          font-semibold
                          capitalize
                        "
                      >
                        {topic}
                      </h3>

                      <span
                        class="
                          text-xs
                          text-[var(--color-muted)]
                        "
                      >
                        {
                          teachings.length
                        }
                      </span>

                    </div>

                    <ul
                      class="
                        mt-4
                        space-y-2
                      "
                    >

                      {teachings.map(
                        (
                          teaching
                        ) => (

                          <li>

                            <a
                              href={`/teachings/${teaching.id}`}
                              class="
                                text-sm
                                text-[var(--color-muted)]
                                hover:text-[var(--color-text)]
                              "
                            >
                              {teaching.data.title}
                            </a>

                          </li>

                        )
                      )}

                    </ul>

                  </section>

                )
              )}

            </div>

          </section>

        )
      )}

    </section>

  </section>

</main>

  </div>

</BaseLayout>
