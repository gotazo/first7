---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";

import StudyHero from "../../components/study/common/StudyHero.astro";

import StudyHeroMeta from "../../components/study/common/StudyHeroMeta.astro";
import StudyShare from "../../components/study/common/StudyShare.astro";
import StudyBreadcrumb from "../../components/study/common/StudyBreadcrumb.astro";

import StudySection from "../../components/study/common/StudySection.astro";
import StudyScripture from "../../components/study/teachings/StudyScripture.astro";

import RelatedScriptures from "../../components/prophecy/RelatedScriptures.astro";
import StudyTerms from "../../components/prophecy/StudyTerms.astro";
import RelatedTopics from "../../components/prophecy/RelatedTopics.astro";

import {
  getCollection,
} from "astro:content";

export async function getStaticPaths() {

  const teachings =
    await getCollection("teachings");

  const paths =
    teachings.map((t) => ({

      params: {
        slug: String(t.id),
      },

      props: {
        teaching: t,
      },

    }));

  if (
    import.meta.env.BUILD_TRACE
    === "true"
  ) {

    console.log(
      `[build:paths] teachings paths=${paths.length}`
    );

  }

  return paths;

}

const { teaching } =
  Astro.props;

/**
 * 📚 Collections
 */
const allProphecy =
  await getCollection("prophecy");

const allDictionary =
  await getCollection("dictionary");

/**
 * 🔮 Related prophecy
 */
const relatedProphecy =
  allProphecy.filter((entry) =>

    entry.data.scriptures?.some(
      (scripture: string) =>

        teaching.data.scriptures?.includes(
          scripture
        )

    )

  );

/**
 * 📘 Related dictionary
 */
const teachingKeywords =
  teaching.data.keywords.map(
    (keyword: string) =>
      keyword.toLowerCase()
  );

const dictionaryTerms =
  allDictionary.filter((entry) =>

    teachingKeywords.includes(
      entry.data.term.toLowerCase()
    )

  );
---

<BaseLayout
  title={teaching.data.title}
>



    <!-- Main -->
    <main>

      <article
        class="
          mx-auto
          w-full
          max-w-4xl
          space-y-10
        "
      >

        <!-- Header -->
        <StudyBreadcrumb
  items={[
    { label: "Home", href: "/" },
    { label: "Teachings", href: "/teachings" },
    { label: teaching.data.title },
  ]}
/>

<StudyHero
  section="Teaching"
  title={teaching.data.title}
  description={teaching.data.summary}
>

  <StudyHeroMeta
    slot="meta"
    label="Topics"
    items={teaching.data.topics}
    href="/teachings"
    linkLabel="View all topics"
  />

  <StudyShare
    slot="actions"
    title={teaching.data.title}
  />

</StudyHero>

        <!-- Scripture -->
        
        <StudyScripture
          reference={teaching.data.scripture.ref}
          text={teaching.data.scripture.text}
        />

        <!-- Truth -->
        <StudySection title="Truth">

  <p>

    {teaching.data.truth}

  </p>

</StudySection>

        <!-- Insight -->
        <StudySection title="Insight">

  <ul
    class="
      list-disc
      space-y-2
      pl-6
    "
  >

    {teaching.data.insight.map(
      (i: string) => (

        <li>

          {i}

        </li>

      )
    )}

  </ul>

</StudySection>

        <!-- Application -->
        <StudySection title="Application">

  <ul
    class="
      list-disc
      space-y-2
      pl-6
    "
  >

    {teaching.data.application.map(
      (a: string) => (

        <li>

          {a}

        </li>

      )
    )}

  </ul>

</StudySection>

        <!-- Prayer -->
{teaching.data.prayer && (
  <section class="space-y-3">

    <h2
      class="
        text-xl
        font-medium
      "
    >

      Prayer

    </h2>

    <p>

      {teaching.data.prayer}

    </p>

  </section>
)}

        <!-- Related Scriptures -->
        {teaching.data.scriptures?.length > 0 && (

          <RelatedScriptures
            scriptures={
              teaching.data.scriptures
            }
          />

        )}

        <!-- Related Dictionary -->
        {dictionaryTerms.length > 0 && (

          <StudyTerms
            terms={dictionaryTerms}
          />

        )}

        <!-- Related Prophecy -->
        {relatedProphecy.length > 0 && (

          <RelatedTopics
            topics={relatedProphecy}
          />

        )}

        <!-- Footer -->
        <section
          class="
            space-y-4
            border-t
            border-[var(--color-border)]
            pt-6
          "
        >

          <p
            class="
              text-sm
              leading-relaxed
              text-[var(--color-muted)]
            "
          >

            These teachings are prayerfully
            developed through Scripture study,
            sermon preparation, biblical research,
            and insights learned from various
            pastors and teachers.

            Content is carefully rewritten and
            organized to encourage spiritual
            growth while remaining grounded
            in Scripture.

          </p>

          <a
            href="/share"
            class="
              btn
              inline-block
              rounded-lg
              px-5
              py-2.5
              text-sm
              font-medium
            "
          >

            Share a reflection or testimony →

          </a>

        </section>

      </article>

    </main>

 
</BaseLayout>

<script>

  const shareButton =
    document.querySelector(
      "[data-teaching-share]"
    );

  if (
    shareButton
    instanceof HTMLButtonElement
  ) {

    const label =
      shareButton.querySelector(
        "[data-share-label]"
      );

    const originalLabel =
      label?.textContent || "Share";

    let resetTimer:
      number | undefined;

    const setLabel =
      (text: string) => {

        if (label)
          label.textContent = text;

        window.clearTimeout(
          resetTimer
        );

        resetTimer =
          window.setTimeout(() => {

            if (label)
              label.textContent =
                originalLabel;

          }, 1800);

      };

    shareButton
      .addEventListener(
        "click",
        async () => {

          const shareData = {

            title:
              document.title,

            url:
              window.location.href,

          };

          try {

            if (
              navigator.share
            ) {

              await navigator.share(
                shareData
              );

              return;

            }

            await navigator
              .clipboard
              .writeText(
                window.location.href
              );

            setLabel("Copied");

          } catch {

            setLabel(
              "Copy failed"
            );

          }

        }
      );

  }

</script>

<style>

  .share-button:hover {

    border-color:
      color-mix(
        in srgb,
        var(--color-primary) 45%,
        transparent
      );

    color:
      var(--color-text);

    background:
      color-mix(
        in srgb,
        var(--color-bg) 88%,
        var(--color-primary)
      );

    box-shadow:
      0 10px 28px
      color-mix(
        in srgb,
        var(--color-primary) 10%,
        transparent
      );

    transform:
      translateY(-1px);

  }

</style>
