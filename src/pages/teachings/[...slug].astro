---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import TeachingSidebar from "../../components/TeachingSidebar.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const teachings = await getCollection("teachings");

  const paths = teachings.map((t) => ({
    params: {
      slug: String(t.id),
    },
    props: {
      teaching: t,
    },
  }));

  if (import.meta.env.BUILD_TRACE === "true") {
    console.log(`[build:paths] teachings paths=${paths.length}`);
  }

  return paths;
}

const { teaching } = Astro.props;
---

<BaseLayout title={teaching.data.title}>

  <div class="flex flex-col gap-10 lg:flex-row">

    <TeachingSidebar />

    <main class="flex-1">

      <article class="w-full max-w-3xl mx-auto space-y-10">

    <header class="space-y-5">
      <h1 class="text-4xl font-semibold">
        {teaching.data.title}
      </h1>

      <p class="text-lg text-[var(--color-muted)]">
        {teaching.data.summary}
      </p>

      <button
        type="button"
        class="share-button inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-sm text-[var(--color-muted)] transition"
        data-teaching-share
        aria-label={`Share ${teaching.data.title}`}
      >
        <svg
          aria-hidden="true"
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="18" cy="5" r="3"></circle>
          <circle cx="6" cy="12" r="3"></circle>
          <circle cx="18" cy="19" r="3"></circle>
          <path d="m8.6 13.5 6.8 4"></path>
          <path d="m15.4 6.5-6.8 4"></path>
        </svg>
        <span data-share-label>Share</span>
      </button>
    </header>

    <section class="space-y-3">
      <h2 class="text-xl font-medium">Scripture</h2>

      <blockquote class="border-l-2 pl-4 italic">
        <p>{teaching.data.scripture.text}</p>
        <footer class="mt-2 text-sm text-[var(--color-muted)]">
          {teaching.data.scripture.ref}
        </footer>
      </blockquote>
    </section>

    <section class="space-y-3">
      <h2 class="text-xl font-medium">Truth</h2>
      <p>{teaching.data.truth}</p>
    </section>

    <section class="space-y-3">
      <h2 class="text-xl font-medium">Insight</h2>

      <ul class="list-disc pl-6 space-y-2">
        {teaching.data.insight.map((i: string) => (
          <li>{i}</li>
        ))}
      </ul>
    </section>

    <section class="space-y-3">
      <h2 class="text-xl font-medium">Application</h2>

      <ul class="list-disc pl-6 space-y-2">
        {teaching.data.application.map((a: string) => (
          <li>{a}</li>
        ))}
      </ul>
    </section>

    <section class="space-y-3">
      <h2 class="text-xl font-medium">Prayer</h2>
      <p>{teaching.data.prayer}</p>
    </section>

       </article>

    </main>

  </div>

</BaseLayout>

<script>
  const shareButton = document.querySelector("[data-teaching-share]");

  if (shareButton instanceof HTMLButtonElement) {
    const label = shareButton.querySelector("[data-share-label]");
    const originalLabel = label?.textContent || "Share";
    let resetTimer: number | undefined;

    const setLabel = (text: string) => {
      if (label) label.textContent = text;
      window.clearTimeout(resetTimer);
      resetTimer = window.setTimeout(() => {
        if (label) label.textContent = originalLabel;
      }, 1800);
    };

    shareButton.addEventListener("click", async () => {
      const shareData = {
        title: document.title,
        url: window.location.href,
      };

      try {
        if (navigator.share) {
          await navigator.share(shareData);
          return;
        }

        await navigator.clipboard.writeText(window.location.href);
        setLabel("Copied");
      } catch {
        setLabel("Copy failed");
      }
    });
  }
</script>

<style>
  .share-button:hover {
    border-color: color-mix(in srgb, var(--color-primary) 45%, transparent);
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-bg) 88%, var(--color-primary));
    box-shadow: 0 10px 28px color-mix(in srgb, var(--color-primary) 10%, transparent);
    transform: translateY(-1px);
  }
</style>
