---
import { render } from 'astro:content';
import VerseLink from '../../../components/VerseLink.astro';
import {
  getStartPlanDaysStaticPaths,
  type StartEntry
} from '../../../lib/start-plans';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const dayPaths = await getStartPlanDaysStaticPaths();

  return dayPaths.map((dayPath) => ({
    params: {
      plan: dayPath.plan,
      day: `day-${dayPath.entry.data.day}`
    },
    props: {
      entry: dayPath.entry,
      planDays: dayPath.planDays
    }
  }));
}

const { entry, planDays } = Astro.props as {
  entry: StartEntry;
  planDays: number[];
};

const { Content } = await render(entry);

const plan = entry.data.plan.trim();
const day = entry.data.day;
const totalDays = planDays.length;
const nextHref = day < totalDays ? `/plans/${plan}/day-${day + 1}` : `/plans/${plan}`;
---

<BaseLayout title={entry.data.title} full={true}>

  <div class="mx-auto w-[90%] max-w-[1400px] px-4 py-10">

    <div class="grid lg:grid-cols-[260px_minmax(0,1fr)] gap-8">

      <!-- SIDEBAR -->
      <aside class="hidden lg:block">
        <div class="lg:sticky lg:top-24 space-y-6">

          <div>
            <p class="text-sm text-[var(--color-muted)]">Plan</p>
            <h2 class="text-xl font-semibold capitalize">
              {plan.replace(/-/g, ' ')}
            </h2>
            <p class="text-xs text-[var(--color-muted)] mt-1">
              {totalDays} days
            </p>
          </div>

          <!-- DAYS -->
          <div class="space-y-2">
            {planDays.map((planDay) => (
              <a
                href={`/plans/${plan}/day-${planDay}`}
                class="flex justify-between px-3 py-2 rounded-lg text-sm transition"
                data-day={planDay}
              >
                <span>Day {planDay}</span>
                <span data-status></span>
              </a>
            ))}
          </div>

        </div>
      </aside>

      <!-- MAIN -->
      <main>
        <div class="max-w-2xl mx-auto space-y-12 py-6">

          <!-- PROGRESS -->
          <div class="space-y-3">
            <div class="flex justify-between text-sm text-[var(--color-muted)]">
              <span>Day {day} of {totalDays}</span>
              <span id="progress-text">0%</span>
            </div>

            <div class="flex gap-2">
              {Array.from({ length: totalDays }).map((_, i) => (
                <div
                  class="h-2 flex-1 rounded-full bg-[var(--color-border)]"
                  data-bar={i + 1}
                />
              ))}
            </div>
          </div>

          <!-- TITLE -->
          <div>
            <h1 class="text-3xl md:text-4xl font-semibold">
              {entry.data.title}
            </h1>
            <p class="text-[var(--color-muted)] mt-2">
              {entry.data.description}
            </p>
          </div>

          <!-- VERSE -->
          <div class="rounded-2xl border bg-[var(--color-primary)]/5 p-6">
            <p class="text-xs text-[var(--color-muted)]">
              Today's Focus
            </p>
            <p class="mt-2 text-lg font-medium">
              <VerseLink verse={entry.data.verse} />
            </p>
          </div>

          <!-- CONTENT -->
          <article class="space-y-6 text-lg leading-relaxed">
            <Content />
          </article>

          <!-- REFLECTION -->
          <div class="space-y-3">
            <p class="text-sm text-[var(--color-muted)]">
              Reflect
            </p>

            <textarea
              id="reflection"
              rows="5"
              class="w-full rounded-xl border border-[var(--color-border)] p-4"
              placeholder="Write what stood out to you..."
            ></textarea>

            <p id="save-status" class="text-xs text-[var(--color-muted)]">
              Not saved
            </p>
          </div>

          <!-- ACTION -->
          <div class="text-center space-y-4">
            <button
              id="complete-btn"
              class="w-full rounded-xl bg-[var(--color-primary)] px-6 py-4 text-white font-medium"
            >
              Complete Day {day} ->
            </button>
          </div>

        </div>
      </main>

    </div>

  </div>

  <!-- SCRIPT -->
  <script is:inline define:vars={{ plan, day, totalDays, nextHref }}>

    const key = `first7-${plan}`;
    let saved = [];

    try {
      const parsed = JSON.parse(localStorage.getItem(key) || '[]');
      saved = Array.isArray(parsed) ? parsed.filter((value) => Number.isInteger(value)) : [];
    } catch {}

    // PROGRESS
    const percent = Math.round((saved.length / totalDays) * 100);
    const progressText = document.getElementById('progress-text');
    if (progressText) progressText.textContent = percent + '%';

    document.querySelectorAll('[data-bar]').forEach((el) => {
      const d = Number(el.getAttribute('data-bar'));
      if (saved.includes(d)) {
        el.classList.add('bg-[var(--color-primary)]');
      }
    });

    // LOCK LOGIC
    const lastDay = saved.length > 0 ? Math.max(...saved) : 0;

    document.querySelectorAll('[data-day]').forEach((link) => {
      const d = Number(link.getAttribute('data-day'));
      const status = link.querySelector('[data-status]');

      if (saved.includes(d)) {
        link.classList.add('bg-[var(--color-primary)]/10');
        if (status) status.textContent = 'Done';
      } else if (d === lastDay + 1) {
        link.classList.add('text-[var(--color-primary)]', 'font-medium');
        if (status) status.textContent = 'Now';
      } else {
        link.classList.add('opacity-50', 'pointer-events-none');
        if (status) status.textContent = 'Locked';
      }
    });

    // REFLECTION
    const reflectionKey = `reflection-${plan}-${day}`;
    const textarea = document.getElementById('reflection');
    const status = document.getElementById('save-status');

    if (textarea instanceof HTMLTextAreaElement) {
      textarea.value = localStorage.getItem(reflectionKey) || '';

      textarea.addEventListener('input', () => {
        localStorage.setItem(reflectionKey, textarea.value);
        if (status) status.textContent = 'Saved';
      });
    }

    // COMPLETE BUTTON
    const btn = document.getElementById('complete-btn');

    btn?.addEventListener('click', () => {
      if (!saved.includes(day)) {
        saved.push(day);
        localStorage.setItem(key, JSON.stringify(saved));
      }

      btn.textContent = 'Great job. Moving to next day...';

      setTimeout(() => {
        window.location.href = nextHref;
      }, 1200);
    });

  </script>

</BaseLayout>
