---
export const prerender = true;

import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type PrayerEntry = CollectionEntry<'prayers'>;

export async function getStaticPaths() {
  const entries = await getCollection('prayers');

  const paths = entries.map((entry: PrayerEntry) => ({
    params: { slug: entry.data.slug },
    props: { entry }
  }));

  if (import.meta.env.BUILD_TRACE === 'true') {
    console.log(`[build:paths] prayers paths=${paths.length}`);
  }

  return paths;
}

const { entry } = Astro.props as { entry: PrayerEntry };
const { Content } = await render(entry);


---

<BaseLayout title={entry.data.title} full={true}>

  <link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&family=Cormorant+Garamond:wght@500;600;700&display=swap"
  rel="stylesheet"
/>

<div class="mx-auto w-[92%] max-w-[1400px] px-4">

  <div class="flex flex-col lg:grid lg:grid-cols-[minmax(0,1fr)_320px] gap-10">

    <!-- 🟩 SIDEBAR -->
