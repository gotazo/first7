      <!-- Hidden source for JS -->
<div
  id="prayer-content"
  class="hidden"
  aria-hidden="true"
>
  <Content />
</div>

<article class="max-w-4xl mx-auto py-10">

  <header class="space-y-3 mb-8">

    <h1 class="text-3xl md:text-5xl font-semibold leading-tight">
      {entry.data.title}
    </h1>

    <p class="text-[var(--color-muted)]">
      {entry.data.description}
    </p>

  </header>

</article>


    </main>

  </div>
</div>

</BaseLayout>

<script is:inline>
function initPrayerCard(){

if(window.__prayerCardInitialized) return;
window.__prayerCardInitialized = true;

const container = document.getElementById("prayer-content");
const card = document.getElementById("prayer-card");

const downloadBtn =
  document.getElementById("download-btn");

const shareBtn =
  document.getElementById("share-btn");

if(!container || !card) return;

const styleButtons = document.querySelectorAll("[data-style]");

let selectedText = "";
let selectedRef = "";
let currentStyle = "calm";
let cachedPngBlob = null;
let cachedPngKey = "";
let cachedPngPromise = null;
/* THEMES */
const themes = {

  calm: {
    bg: "#f6fbf6",
    text: "#163020",
    accent: "#6aa27a",
    brand: "#64748b"
  },

  elegant: {
    bg: "#faf5ef",
    text: "#2b2118",
    accent: "#c7a86b",
    brand: "#8f7a5b"
  },

  modern: {
    bg: "#0f172a",
    text: "#f8fafc",
    accent: "#38bdf8",
    brand: "#94a3b8"
  }

};

/* TYPOGRAPHY */
function getTypography(){

  if(currentStyle === "modern"){
    return {
      fontFamily: "'Inter', sans-serif",
      fontWeight: 700,
      letterSpacing: "-0.2",
      lineHeightRatio: 1.2,
      wrapWidth: 24
    };
  }

  if(currentStyle === "elegant"){
    return {
      fontFamily: "'Cormorant Garamond', serif",
      fontWeight: 600,
      letterSpacing: ".4",
      lineHeightRatio: 1.45,
      wrapWidth: 20
    };
  }

  return {
    fontFamily: "'Playfair Display', serif",
    fontWeight: 500,
    letterSpacing: "0.3",
    lineHeightRatio: 1.4,
    wrapWidth: 22
  };

}

/* SVG */
function getBackgroundSVG(theme){

if(currentStyle === "calm"){

return `
<rect width="100%" height="100%" fill="${theme.bg}"/>

<circle cx="150" cy="150" r="220"
 fill="${theme.accent}" opacity="0.08"/>

<circle cx="920" cy="920" r="260"
 fill="${theme.accent}" opacity="0.06"/>

<circle cx="540" cy="540" r="420"
 fill="${theme.accent}" opacity="0.02"/>
`;
}

if(currentStyle === "elegant"){

return `
<rect width="100%" height="100%" fill="${theme.bg}"/>

<rect
 x="60"
 y="60"
 width="960"
 height="960"
 rx="40"
 fill="none"
 stroke="${theme.accent}"
 stroke-width="4"
 opacity="0.8"
/>

<rect
 x="90"
 y="90"
 width="900"
 height="900"
 rx="24"
 fill="none"
 stroke="${theme.accent}"
 stroke-width="1"
 opacity="0.3"
/>

<circle
 cx="540"
 cy="540"
 r="420"
 fill="${theme.accent}"
 opacity="0.03"
/>
`;
}

return `
<defs>

<radialGradient id="glow">

<stop offset="0%"
 stop-color="${theme.accent}"
 stop-opacity="0.35"/>

<stop offset="100%"
 stop-color="${theme.accent}"
 stop-opacity="0"/>

</radialGradient>

</defs>

<rect width="100%" height="100%" fill="${theme.bg}"/>

<circle
 cx="250"
 cy="250"
 r="350"
 fill="url(#glow)"
/>

<circle
 cx="850"
 cy="850"
 r="320"
 fill="url(#glow)"
/>

<circle
 cx="540"
 cy="540"
 r="500"
 fill="${theme.accent}"
 opacity="0.03"
/>
`;
}

function generateSVG(text, ref){
  const width = 1080;
  const height = 1080;
  const t = getTypography();
  const theme = themes[currentStyle];

  function wrapText(text, maxChars){
    const words = text.split(" ");
    let lines = [], line = "";

    words.forEach(w=>{
      if((line + w).length > maxChars){
        lines.push(line);
        line = w + " ";
      } else {
        line += w + " ";
      }
    });

    lines.push(line);
    return lines;
  }

  let fontSize = 56;
  let lines, lineHeight, totalHeight;
  const maxHeight = height - 320;

  while(true){
    lines = wrapText(text, t.wrapWidth);
    lineHeight = fontSize * t.lineHeightRatio;
    totalHeight = lines.length * lineHeight;

    if(totalHeight <= maxHeight) break;
    fontSize -= 1.2;
    if(fontSize < 34) break;
  }

  // ✅ center text vertically
  let y = (height - totalHeight) / 2;

  const textSVG = lines.map(line=>{
    const el = `
<text x="50%" y="${y}" text-anchor="middle"
  font-size="${fontSize}"
  letter-spacing="${t.letterSpacing}"
  fill="${theme.text}"
  font-family="${t.fontFamily}"
  font-weight="${t.fontWeight}">
  ${line.trim()}
</text>`;
    y += lineHeight;
    return el;
  }).join("");

  return `

  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${width} ${height}">
  ${getBackgroundSVG(theme)}

  ${textSVG}

  <!-- Divider -->
  <line x1="30%" x2="70%" y1="${height-220}" y2="${height-220}"
    stroke="${theme.accent}" stroke-width="4"/>

  <!-- 📖 Bible reference -->
  <text x="50%" y="${height-160}" text-anchor="middle"
    font-size="32"
    fill="${theme.text}"
    font-family="'Inter', sans-serif">
    Read Bible: ${ref || ""}
  </text>

  <!-- 🌐 Branding -->
  <text x="50%" y="${height-90}" text-anchor="middle"
    font-size="26"
    fill="${theme.brand}"
    font-family="'Inter', sans-serif">
    first7.org
  </text>

</svg>`;
}

/* UPDATE */
function updatePreview(){

  if(!selectedText || !card) return;

  cachedPngBlob = null;
  cachedPngKey = "";
  cachedPngPromise = null;

  card.innerHTML =
    generateSVG(selectedText, selectedRef);

  warmPngCache();

}

function svgToPngBlob(svg){
  return new Promise((resolve, reject)=>{
    const canvas = document.createElement("canvas");
    canvas.width = 1080;
    canvas.height = 1080;

    const ctx = canvas.getContext("2d", { alpha: false });
    if(!ctx){
      reject(new Error("Canvas is not supported."));
      return;
    }

    const img = new Image();
    const svgBlob = new Blob([svg], { type: "image/svg+xml;charset=utf-8" });
    const svgUrl = URL.createObjectURL(svgBlob);

    const cleanup = ()=>{
      URL.revokeObjectURL(svgUrl);
      img.onload = null;
      img.onerror = null;
    };

    img.onload = ()=>{
      try{
        ctx.drawImage(img, 0, 0, 1080, 1080);
        canvas.toBlob(blob=>{
          cleanup();
          blob ? resolve(blob) : reject(new Error("PNG generation failed."));
        }, "image/png");
      }catch(error){
        cleanup();
        reject(error);
      }
    };

    img.onerror = ()=>{
      cleanup();
      reject(new Error("Image generation failed."));
    };

    img.src = svgUrl;
  });
}

async function getPngBlob(){
  const key = `${currentStyle}|${selectedRef}|${selectedText}`;
  if(cachedPngBlob && cachedPngKey === key) return cachedPngBlob;
  if(cachedPngPromise && cachedPngKey === key) return cachedPngPromise;

  const svg = generateSVG(selectedText, selectedRef);
  cachedPngKey = key;

  cachedPngPromise = (async ()=>{
    if(document.fonts?.ready){
      await document.fonts.ready;
    }

    const blob = await svgToPngBlob(svg);

    if(cachedPngKey === key){
      cachedPngBlob = blob;
    }

    return blob;
  })().catch(error=>{
    if(cachedPngKey === key){
      cachedPngBlob = null;
      cachedPngKey = "";
      cachedPngPromise = null;
    }

    throw error;
  }).finally(()=>{
    if(cachedPngKey === key){
      cachedPngPromise = null;
    }
  });

  return cachedPngPromise;
}

function warmPngCache(){
  getPngBlob().catch(()=>{});
}

async function sharePrayer(){
  const text = `${selectedText} — ${selectedRef}`;
  const caption = selectedRef ? `${selectedRef} • first7.org` : "first7.org";

  try{
    const blob = await getPngBlob();
    const file = new File([blob], "prayer-card.png", { type: "image/png" });

    if(navigator.canShare?.({ files: [file] })){
      await navigator.share({ files: [file], text: caption });
      return;
    }
  }catch(error){
    console.warn("Image sharing failed, falling back to text share.", error);
  }

  navigator.share?.({ text });
}

/* LOAD FIRST */
function preloadFirst(){
  const first = container.querySelector(".prayer");
  if(!first) return;

  const text = first.querySelector(".prayer-text")?.innerText || "";
  const ref = first.getAttribute("data-ref") || "";

  selectedText = text;
  selectedRef = ref;

  const firstButton =
  document.querySelector("#prayer-picker button");

firstButton?.classList.add(
  "bg-[var(--color-bg-soft)]"
);

  updatePreview();
}

/* CLICK */
container.addEventListener("click",(e)=>{
  const block = e.target.closest(".prayer");
  if(!block) return;

  const text = block.querySelector(".prayer-text")?.innerText || "";
  const ref = block.getAttribute("data-ref") || "";

  selectedText = text;
  selectedRef = ref;

  updatePreview();
});

/* STYLE */
styleButtons.forEach(btn=>{
  btn.addEventListener("click", ()=>{
    currentStyle = btn.dataset.style;
    updatePreview();
  });
});

function buildPrayerLibrary(){

  const picker =
    document.getElementById("prayer-picker");

  if(!picker) return;

  const prayers =
    container.querySelectorAll(".prayer");

  picker.innerHTML = "";

  prayers.forEach((block)=>{

    const text =
      block.querySelector(".prayer-text")?.innerText || "";

    const ref =
      block.getAttribute("data-ref") || "";

    const title =
      block.getAttribute("data-title") || "";

    const btn =
      document.createElement("button");

    btn.className =
      "w-full text-left p-4 hover:bg-[var(--color-bg-soft)] transition";

    btn.innerHTML = `
      <div class="font-semibold text-sm">
        ${title}
      </div>

      <div class="text-xs opacity-70 mt-1">
        ${ref}
      </div>

      <div class="text-xs opacity-60 mt-2 line-clamp-3">
        ${text}
      </div>
    `;

    btn.addEventListener("click",()=>{

      picker.querySelectorAll("button")
        .forEach(el=>{
          el.classList.remove("bg-[var(--color-bg-soft)]");
        });

      btn.classList.add(
        "bg-[var(--color-bg-soft)]"
      );

      selectedText = text;
      selectedRef = ref;

      updatePreview();

    });

    picker.appendChild(btn);

  });

}

downloadBtn?.addEventListener("click", async ()=>{

  if(!selectedText) return;

  const blob = await getPngBlob();

  const url = URL.createObjectURL(blob);

  const a = document.createElement("a");

  a.href = url;
  a.download = "prayer-card.png";

  a.click();

  setTimeout(()=>{
    URL.revokeObjectURL(url);
  },1000);

});

shareBtn?.addEventListener("click", ()=>{

  if(!selectedText) return;

  sharePrayer();

});

/* INIT */
buildPrayerLibrary();
preloadFirst();

}

document.addEventListener("DOMContentLoaded", initPrayerCard);
</script>
