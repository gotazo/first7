---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type Reflection = CollectionEntry<'reflections'>;

const reflections: Reflection[] = (await getCollection('reflections'))
  .sort((a: Reflection, b: Reflection) =>
    b.data.date.getTime() - a.data.date.getTime()
  );
---

<BaseLayout title="Reflections">

  <section class="max-w-3xl mx-auto px-5 py-16 space-y-12">

    <!-- HEADER -->
    <div class="text-center space-y-3">
      <h1 class="text-4xl font-semibold">
        Reflections
      </h1>

      <p class="text-[var(--color-muted)]">
        Simple, honest moments to pause and be present
      </p>
    </div>

    <!-- LIST -->
    <div class="space-y-6">

      {reflections.map((r) => (
        <a
          href={`/reflections/${r.id}`}
          class="block rounded-2xl border border-[var(--color-border)] p-6 transition hover:bg-[var(--color-primary)]/5"
        >
          <h2 class="text-lg font-medium">
            {r.data.title}
          </h2>

          <p class="mt-2 text-sm text-[var(--color-muted)] leading-relaxed">
            {r.data.excerpt}
          </p>

          <p class="mt-3 text-xs text-[var(--color-muted)]">
            {r.data.date.toLocaleDateString()}
          </p>
        </a>
      ))}

    </div>

  </section>

</BaseLayout>