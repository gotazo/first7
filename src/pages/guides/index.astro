---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const guides = await getCollection("guides");

// Put "how-to-use" first
const sorted = guides.sort((a, b) => {
  if (a.id === "how-to-use") return -1;
  if (b.id === "how-to-use") return 1;
  return a.data.title.localeCompare(b.data.title);
});
---

<BaseLayout title="Guides">

  <section class="max-w-5xl mx-auto py-16 px-4 space-y-16">

    <!-- HERO -->
    <div class="max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-semibold leading-tight">
        Guides
      </h1>
      <p class="mt-4 text-lg text-[var(--color-muted)]">
        Learn how to use the system, build consistency, and grow daily.
      </p>
    </div>

    <!-- START HERE (FEATURED) -->
    {sorted
      .filter(g => g.id === "how-to-use")
      .map((guide) => (

        <a
          href={`/guides/${guide.id}`}
          class="block p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/10 hover:shadow-md transition"
        >
          <p class="text-sm text-[var(--color-muted)]">
            Start here
          </p>

          <h2 class="mt-2 text-2xl font-semibold">
            {guide.data.title}
          </h2>

          <p class="mt-3 text-sm text-[var(--color-muted)] max-w-md">
            A quick guide to help you understand how everything works and how to get the most out of your journey.
          </p>

          <div class="mt-5 text-[var(--color-primary)] font-medium text-sm">
            Read guide →
          </div>
        </a>

      ))}

    <!-- ALL GUIDES -->
    <div class="space-y-6">

      <h2 class="text-xl font-semibold">
        All Guides
      </h2>

      <div class="grid gap-4 md:grid-cols-2">

        {sorted
          .filter(g => g.id !== "how-to-use")
          .map((guide) => (

            <a
              href={`/guides/${guide.id}`}
              class="p-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 hover:bg-[var(--color-primary)]/10 hover:shadow-md transition"
            >
              <div class="flex items-center gap-2">
                <h3 class="font-medium">
                  {guide.data.title}
                </h3>

                {guide.data.featured && (
                  <span class="text-xs bg-[var(--color-primary)]/10 text-[var(--color-primary)] px-2 py-0.5 rounded">
                    New
                  </span>
                )}
              </div>

              <p class="mt-1 text-sm text-[var(--color-muted)]">
                Read →
              </p>
            </a>

          ))}

      </div>

    </div>

    <!-- SYSTEM EXPLAINER -->
    <div class="border border-[var(--color-border)] rounded-2xl p-8 space-y-4 bg-[var(--color-primary)]/5">

      <h2 class="text-xl font-semibold">
        How this works
      </h2>

      <p class="text-[var(--color-muted)]">
        This is a simple system designed to help you grow daily without overwhelm.
      </p>

      <div class="grid gap-4 md:grid-cols-3 text-sm">

        <div class="p-4 rounded-lg border bg-white/40 dark:bg-transparent">
          <p class="font-medium">📖 Read</p>
          <p class="text-[var(--color-muted)] mt-1">
            Short daily content grounded in Scripture
          </p>
        </div>

        <div class="p-4 rounded-lg border bg-white/40 dark:bg-transparent">
          <p class="font-medium">✍️ Reflect</p>
          <p class="text-[var(--color-muted)] mt-1">
            Write your thoughts and process honestly
          </p>
        </div>

        <div class="p-4 rounded-lg border bg-white/40 dark:bg-transparent">
          <p class="font-medium">🔁 Apply</p>
          <p class="text-[var(--color-muted)] mt-1">
            Take one small step each day
          </p>
        </div>

      </div>

    </div>

    <!-- CTA -->
    <div class="text-center space-y-4">

      <h2 class="text-2xl font-semibold">
        Ready to start?
      </h2>

      <p class="text-[var(--color-muted)]">
        Begin your first 7-day journey today.
      </p>

      <a
        href="/plans"
        class="inline-block px-6 py-3 rounded-xl text-white font-medium text-lg hover:opacity-90 transition"
        style="background-color: var(--color-primary);"
      >
        Start a Plan →
      </a>

    </div>

  </section>

</BaseLayout>