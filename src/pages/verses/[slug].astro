  </div>

</div>

<!-- 🌍 EXPLORE -->
<div class="rounded-2xl border p-5 space-y-3">

  <p class="font-medium">
    Explore more
  </p>

  <a href="/verses" class="block text-sm hover:underline">
    📚 View all topics
  </a>

</div>

      </div>
    </aside>

    <!-- 🟦 CONTENT -->
