---
export const prerender = true;

import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type VerseEntry = CollectionEntry<'verses'>;

export async function getStaticPaths() {
const entries = await getCollection('verses');

const paths = entries.map((entry: VerseEntry) => ({
params: { slug: entry.data.slug },
props: { entry }
}));

if (import.meta.env.BUILD_TRACE === 'true') {
console.log(`[build:paths] verses paths=${paths.length}`);
}

return paths;
}

const { entry } = Astro.props as { entry: VerseEntry };
const { Content } = await render(entry);


---

<BaseLayout title={entry.data.title} full={true}>

<!-- Fonts -->

<link
href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&family=Cormorant+Garamond:wght@500;600;700&display=swap"
rel="stylesheet"
/>

<div class="mx-auto w-[92%] max-w-[1400px] px-4">

  <!-- MOBILE FIRST STACK -->
  <div class="grid lg:grid-cols-[minmax(0,1fr)_300px] gap-6">

    <!-- 🟩 CARD + CONTROLS (TOP ON MOBILE, SIDEBAR ON DESKTOP) -->
    

    <!-- 🟦 CONTENT -->
<!-- 🖼️ CANVAS AREA -->
<main class="order-1">

  <div class="space-y-5 lg:sticky lg:top-24">

    <!-- CARD -->
    <div
      id="verse-card"
      class="rounded-3xl overflow-hidden border bg-[var(--color-bg-soft)] flex items-center justify-center"
      style="aspect-ratio:1/1;"
    >
      <span class="text-xs text-[var(--color-muted)]">
        Loading verse...
      </span>
    </div>

    <!-- ACTIONS -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2">

      <button id="download-btn"
        class="btn verse-action-button px-4 py-3 rounded-xl text-sm">
        Download
      </button>

      <button id="share-btn"
        class="btn-secondary verse-action-button px-4 py-3 rounded-xl text-sm">
        Share
      </button>

      <button id="wa-btn"
        class="btn verse-action-button px-4 py-3 rounded-xl text-sm">
        WhatsApp
      </button>

      <button id="copy-btn"
        class="btn-secondary verse-action-button px-4 py-3 rounded-xl text-sm">
        Copy
      </button>

    </div>

    <!-- STYLES -->
    <div class="flex gap-2">

      <button
        data-style="calm"
        class="btn-secondary style-pill flex-1 px-4 py-2 rounded-xl text-sm">
        Calm
      </button>

      <button
        data-style="modern"
        class="btn-secondary style-pill flex-1 px-4 py-2 rounded-xl text-sm">
        Modern
      </button>

      <button
        data-style="elegant"
        class="btn-secondary style-pill flex-1 px-4 py-2 rounded-xl text-sm">
        Elegant
      </button>

    </div>

  </div>

</main>

<!-- 📚 VERSE LIBRARY -->
<aside class="order-2">

  <div class="lg:sticky lg:top-24">

    <div class="rounded-2xl border overflow-hidden">

      <div class="p-4 border-b">

        <h2 class="font-semibold">
          Verse Library
        </h2>

        <p class="text-xs text-[var(--color-muted)] mt-1">
          Select a verse to update the card
        </p>

      </div>

      <div
        id="verse-picker"
        class="max-h-[75vh] overflow-y-auto divide-y"
      >
      </div>

    </div>

  </div>

</aside>

</div>
</div>

<!-- Hidden source for JS -->
<div
  id="verse-content"
  class="hidden"
  aria-hidden="true"
>
  <Content />
</div>

<!-- SEO Content -->
<section class="mx-auto max-w-4xl px-4 py-12">

  <article class="prose prose-neutral dark:prose-invert max-w-none">
    <Content />
  </article>

</section>

</BaseLayout>


<style>
  .verse-action-button {
    position: relative;
    z-index: 1;
    overflow: hidden;
    cursor: pointer;
    touch-action: manipulation;
  }

  .verse-action-button:disabled {
    cursor: wait;
    opacity: 0.7;
  }

  .verse-action-button .button-ripple {
    position: absolute;
    width: 16px;
    height: 16px;
    border-radius: 999px;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.45);
    transform: translate(-50%, -50%) scale(1);
    animation: verse-button-ripple 450ms ease-out forwards;
  }

  @keyframes verse-button-ripple {
    to {
      opacity: 0;
      transform: translate(-50%, -50%) scale(18);
    }
  }
</style>

<script is:inline>
function initVerseCard(){

if(window.__verseCardInitialized) return;
window.__verseCardInitialized = true;

const container = document.getElementById("verse-content");
const card = document.getElementById("verse-card");

const downloadBtn = document.getElementById("download-btn");
const shareBtn = document.getElementById("share-btn");
const waBtn = document.getElementById("wa-btn");
const copyBtn = document.getElementById("copy-btn");

const styleButtons = document.querySelectorAll("[data-style]");

if(!container || !card) return;

let selectedText = "";
let selectedRef = "";
let currentStyle = "calm";
let cachedPngBlob = null;
let cachedPngKey = "";
let cachedPngPromise = null;

/* -------------------------
   THEMES (ONE SOURCE)
------------------------- */
const themes = {
  calm: {
  bg: "#fdf6ec",
  text: "#2d3748",
  accent: "#d97706",
  brand: "#7c8aa0"
},

  elegant: {
    bg: "#fffdf7",
    text: "#4a3426",
    accent: "#8b6f47",
    brand: "#9b8b78"
},

  modern: {
    bg: "#0f172a",
    text: "#ffffff",
    accent: "#38bdf8",
    brand: "#94a3b8"
  }
};

/* -------------------------
   TYPOGRAPHY
------------------------- */
function getTypography(){
  if(currentStyle === "modern"){
    return {
      fontFamily: "'Inter', sans-serif",
      fontWeight: 700,
      letterSpacing: "-0.2",
      lineHeightRatio: 1.2,
      wrapWidth: 24,
      opacity: "1"
    };
  }

  if(currentStyle === "elegant"){
    return {
      fontFamily: "'Cormorant Garamond', serif",
      fontWeight: 700,
      letterSpacing: ".2",
      lineHeightRatio: 1.5,
      wrapWidth: 20,
      opacity: "0.85"
    };
  }

  return {
    fontFamily: "'Playfair Display', serif",
    fontWeight: 500,
    letterSpacing: "0.4",
    lineHeightRatio: 1.4,
    wrapWidth: 22,
    opacity: "0.9"
  };
}

/* -------------------------
   SVG GENERATOR
------------------------- */
function generateSVG(text, ref){

  const width = 1080;
  const height = 1080;
  const t = getTypography();
  const theme = themes[currentStyle];

  /* -------------------------
     BACKGROUND (FLAT ONLY)
  ------------------------- */
let bg = "";

if(currentStyle === "calm"){

bg = `
<rect width="100%" height="100%" fill="${theme.bg}"/>

<circle
 cx="150"
 cy="150"
 r="250"
 fill="${theme.accent}"
 opacity="0.08"
/>

<circle
 cx="950"
 cy="900"
 r="220"
 fill="${theme.accent}"
 opacity="0.06"
/>
`;

}
else if(currentStyle === "elegant"){

bg = `
<rect width="100%" height="100%" fill="${theme.bg}"/>

<circle
 cx="540"
 cy="540"
 r="420"
 fill="${theme.accent}"
 opacity="0.03"
/>

<rect
 x="60"
 y="60"
 width="960"
 height="960"
 rx="40"
 fill="none"
 stroke="${theme.accent}"
 stroke-width="2"
 opacity="0.75"
/>

<rect
 x="90"
 y="90"
 width="900"
 height="900"
 rx="24"
 fill="none"
 stroke="${theme.accent}"
 stroke-width="1"
 opacity="0.25"
/>

<line
 x1="140"
 y1="180"
 x2="940"
 y2="180"
 stroke="${theme.accent}"
 stroke-width="1"
 opacity="0.2"
/>

<line
 x1="140"
 y1="900"
 x2="940"
 y2="900"
 stroke="${theme.accent}"
 stroke-width="1"
 opacity="0.2"
/>
`;

}
else {

bg = `
<defs>

<radialGradient id="glow">

<stop offset="0%" stop-color="${theme.accent}" stop-opacity="0.45"/>

<stop offset="100%" stop-color="${theme.accent}" stop-opacity="0"/>

</radialGradient>

</defs>

<rect width="100%" height="100%" fill="${theme.bg}"/>

<circle
 cx="250"
 cy="250"
 r="350"
 fill="url(#glow)"
/>

<circle
 cx="850"
 cy="850"
 r="300"
 fill="url(#glow)"
/>
`;

}
  /* -------------------------
     TEXT WRAP
  ------------------------- */
  function wrapText(text, maxChars){
    const words = text.split(" ");
    let lines = [], line = "";

    words.forEach(w=>{
      if((line + w).length > maxChars){
        lines.push(line);
        line = w + " ";
      }else{
        line += w + " ";
      }
    });

    lines.push(line);
    return lines;
  }

  let fontSize = 56;
  let lines, lineHeight, totalHeight;
  const maxHeight = height - 300;

  while(true){
    lines = wrapText(text, t.wrapWidth);
    lineHeight = fontSize * t.lineHeightRatio;
    totalHeight = lines.length * lineHeight;

    if(totalHeight <= maxHeight) break;
    fontSize -= 1.2;
    if(fontSize < 34) break;
  }

  let y = 120 + (maxHeight - totalHeight) / 2;

  const textSVG = lines.map(line=>{
    const el = `
<text x="50%" y="${y}" text-anchor="middle"
  font-size="${fontSize}"
  letter-spacing="${t.letterSpacing}"
  fill="${theme.text}"
  style="font-family:${t.fontFamily};"
  font-weight="${t.fontWeight}">
  ${line.trim()}
</text>`;
    y += lineHeight;
    return el;
  }).join("");

  /* -------------------------
     FINAL SVG
  ------------------------- */
  return `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${width} ${height}">

  ${bg}
  ${textSVG}

  <!-- divider -->
  <line x1="32%" x2="68%" y1="${height-220}" y2="${height-220}"
    stroke="${theme.accent}" stroke-width="6"/>

  <!-- reference -->
  <text x="50%" y="${height-140}" text-anchor="middle"
    font-size="64"
    font-family="'Inter', sans-serif"
    font-weight="800"
    fill="${theme.text}"
    letter-spacing="-0.5">
    ${ref || ""}
  </text>

  <!-- brand -->
  <text x="50%" y="${height-80}" text-anchor="middle"
    font-size="26"
    font-family="'Inter', sans-serif"
    fill="${theme.brand}"
    font-weight="600"
    opacity="0.7">
    first7.org
  </text>

</svg>`;
}

/* -------------------------
   UPDATE
------------------------- */
function updatePreview(){
  if(!selectedText) return;
  cachedPngBlob = null;
  cachedPngKey = "";
  cachedPngPromise = null;
  const svg = generateSVG(selectedText, selectedRef);
  card.innerHTML = svg;
  warmPngCache();
}

/* -------------------------
   PNG EXPORT
------------------------- */
function setDownloadLoading(isLoading){
  if(!downloadBtn) return;
  downloadBtn.disabled = isLoading;
  downloadBtn.textContent = isLoading ? "Generating..." : "Download";
}

function svgToPngBlob(svg){
  return new Promise((resolve, reject)=>{
    const canvas = document.createElement("canvas");
    canvas.width = 1080;
    canvas.height = 1080;

    const ctx = canvas.getContext("2d", { alpha: false });
    if(!ctx){
      reject(new Error("Canvas is not supported."));
      return;
    }

    const img = new Image();
    const svgBlob = new Blob([svg], { type: "image/svg+xml;charset=utf-8" });
    const svgUrl = URL.createObjectURL(svgBlob);

    const cleanup = ()=>{
      URL.revokeObjectURL(svgUrl);
      img.onload = null;
      img.onerror = null;
    };

    img.onload = ()=>{
      try{
        ctx.drawImage(img, 0, 0, 1080, 1080);
        canvas.toBlob(blob=>{
          cleanup();
          blob ? resolve(blob) : reject(new Error("PNG generation failed."));
        }, "image/png");
      }catch(error){
        cleanup();
        reject(error);
      }
    };

    img.onerror = ()=>{
      cleanup();
      reject(new Error("Image generation failed."));
    };

    img.src = svgUrl;
  });
}

async function getPngBlob(){
  const key = `${currentStyle}|${selectedRef}|${selectedText}`;
  if(cachedPngBlob && cachedPngKey === key) return cachedPngBlob;
  if(cachedPngPromise && cachedPngKey === key) return cachedPngPromise;

  const svg = generateSVG(selectedText, selectedRef);
  cachedPngKey = key;

  cachedPngPromise = (async ()=>{
    if(document.fonts?.ready){
      await document.fonts.ready;
    }

    const blob = await svgToPngBlob(svg);

    if(cachedPngKey === key){
      cachedPngBlob = blob;
    }

    return blob;
  })().catch(error=>{
    if(cachedPngKey === key){
      cachedPngBlob = null;
      cachedPngKey = "";
      cachedPngPromise = null;
    }

    throw error;
  }).finally(()=>{
    if(cachedPngKey === key){
      cachedPngPromise = null;
    }
  });

  return cachedPngPromise;
}

function warmPngCache(){
  getPngBlob().catch(()=>{});
}

async function shareVerse(){
  const text = `${selectedText} — ${selectedRef}`;
  const caption = selectedRef ? `${selectedRef} • first7.org` : "first7.org";

  try{
    const blob = await getPngBlob();
    const file = new File([blob], "verse.png", { type: "image/png" });

    if(navigator.canShare?.({ files: [file] })){
      await navigator.share({ files: [file], text: caption });
      return;
    }
  }catch(error){
    console.warn("Image sharing failed, falling back to text share.", error);
  }

  navigator.share?.({ text });
}

/* -------------------------
   PRELOAD FIRST VERSE
------------------------- */
function preloadFirstVerse(){
  const first = container.querySelector("blockquote");
  if(!first) return;

  const text = first.innerText.trim();

  // ✅ RELIABLE SOURCE
  const ref = first.getAttribute("data-ref") || "";

  selectedText = text;
  selectedRef = ref;

const firstButton =
  document.querySelector("#verse-picker button");

firstButton?.classList.add(
  "bg-[var(--color-bg-soft)]"
);

updatePreview();
}

/* -------------------------
   CLICK HANDLER
------------------------- */
container.addEventListener("click",(e)=>{
  const block = e.target?.closest?.("blockquote");
  if(!block) return;

  const text = block.innerText.trim();

  // ✅ RELIABLE SOURCE
  const ref = block.getAttribute("data-ref") || "";

  selectedText = text;
  selectedRef = ref;

  updatePreview();
});

/* -------------------------
   STYLE SWITCH
------------------------- */
styleButtons.forEach(btn=>{

  btn.addEventListener("click",()=>{

    currentStyle = btn.dataset.style;

    updatePreview();

  });

});

/* -------------------------
   SIMPLE ACTIONS
------------------------- */
downloadBtn?.addEventListener("click", async ()=>{
  if(!selectedText) return;
  setDownloadLoading(true);

  try{
    const blob = await getPngBlob();
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "verse.png";
    a.click();
    setTimeout(()=>URL.revokeObjectURL(url), 1000);
  }finally{
    setDownloadLoading(false);
  }
});

shareBtn?.addEventListener("click", ()=>{
  if(!selectedText) return;
  shareVerse();
});

waBtn?.addEventListener("click", ()=>{
  if(!selectedText) return;
  const text = `${selectedText} — ${selectedRef}`;
  window.open(`https://wa.me/?text=${encodeURIComponent(text)}`);
});

copyBtn?.addEventListener("click", ()=>{
  if(!selectedText) return;
  navigator.clipboard.writeText(`${selectedText} — ${selectedRef}`);
});

function buildVerseLibrary(){

  const picker =
    document.getElementById("verse-picker");

  if(!picker) return;

  const verses =
    container.querySelectorAll("blockquote");

  picker.innerHTML = "";

  verses.forEach((block)=>{

    const text =
      block.innerText.trim();

    const ref =
      block.getAttribute("data-ref") || "";

    const btn =
      document.createElement("button");

    btn.className =
      "w-full text-left p-4 hover:bg-[var(--color-bg-soft)] transition";

    btn.innerHTML = `
      <div class="font-semibold text-sm">
       ${ref}
     </div>

    <div class="text-xs opacity-70 mt-2 line-clamp-3">
      ${text}
    </div>
    `;

    btn.addEventListener("click",()=>{

  picker.querySelectorAll("button")
    .forEach(el=>{
      el.classList.remove("bg-[var(--color-bg-soft)]");
    });

  btn.classList.add("bg-[var(--color-bg-soft)]");

  selectedText = text;
  selectedRef = ref;

  updatePreview();

});

    picker.appendChild(btn);

  });

}

/* -------------------------
   INIT
------------------------- */
buildVerseLibrary();
preloadFirstVerse();

}

document.addEventListener("DOMContentLoaded", initVerseCard);
</script>
