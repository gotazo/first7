---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type VerseEntry = CollectionEntry<'verses'>;

export async function getStaticPaths() {
  const entries = await getCollection('verses');

  return entries.map((entry: VerseEntry) => ({
    params: { slug: entry.data.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props as { entry: VerseEntry };
const { Content } = await render(entry);

const allVerses = await getCollection('verses');

// 🔍 Extract keywords
function extractKeywords(slug: string) {
  return slug
    .replace("bible-verses-for-", "")
    .replace("bible-verses-about-", "")
    .split("-")
    .filter(Boolean);
}

const currentKeywords = extractKeywords(entry.data.slug);

// 🔗 Related (FIXED)
const related = allVerses
  .filter(v => v.id !== entry.id)
  .map(v => {
    const keywords = extractKeywords(v.data.slug);
    const score = keywords.filter(k => currentKeywords.includes(k)).length;
    return { ...v, score };
  })
  .filter(v => v.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 4);
---

<BaseLayout title={entry.data.title} full={true}>

  <div class="mx-auto w-[90%] max-w-[1400px] px-4">

    <div class="grid lg:grid-cols-[minmax(0,1fr)_280px] gap-12">

      <!-- MAIN -->
      <article class="max-w-2xl mx-auto py-12">

        <!-- HEADER -->
        <header class="mb-10 space-y-4">

          <p class="text-sm uppercase tracking-wide text-[var(--color-primary)]">
            Bible Verses
          </p>

          <h1 class="text-3xl md:text-5xl font-semibold leading-tight">
            {entry.data.title}
          </h1>

          <p class="text-[var(--color-muted)]">
            {entry.data.description}
          </p>

        </header>

        <!-- 🔥 INSTRUCTION -->
        <div class="mb-8 p-6 rounded-2xl bg-[var(--color-primary)]/5 border border-[var(--color-border)] text-center">
          <p class="text-sm text-[var(--color-muted)]">
            ✨ Tap any verse below to create a shareable card
          </p>
        </div>

        <!-- CONTENT -->
        <div id="verse-content" class="prose prose-neutral dark:prose-invert">
          <Content />
        </div>

        <!-- 🔗 RELATED -->
        <div class="mt-12 space-y-4">

          <h2 class="text-lg font-semibold">
            Related verses
          </h2>

          <div class="grid sm:grid-cols-2 gap-4">

            {related.map((v) => (
              <a
                href={`/verses/${v.data.slug}`}
                class="p-4 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)] transition"
              >
                <p class="font-medium">{v.data.title}</p>
                <p class="text-sm text-[var(--color-muted)] mt-1">
                  {v.data.description}
                </p>
              </a>
            ))}

          </div>

        </div>

        <!-- 🔥 CARD GENERATOR -->
        <div class="mt-16 max-w-lg mx-auto space-y-6">

          <div class="text-center">
            <p class="text-sm text-[var(--color-muted)]">Create a verse card</p>
          </div>

          <!-- SELECTS -->
          <div class="flex gap-3 justify-center flex-wrap">

            <select id="style-select" class="px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm">
              <option value="dark">Dark Minimal</option>
              <option value="light">Light Clean</option>
              <option value="gradient">Gradient Glow</option>
              <option value="auto">Auto Style</option>
            </select>

            <select id="format-select" class="px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm">
  <option value="square">Instagram Post</option>
  <option value="shorts">YouTube Shorts</option>
  <option value="pinterest">Pinterest</option>
</select>
<select id="layout-select" class="px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm">
  <option value="signature">First7 Signature</option>
  <option value="hero">Hero Word</option>
  <option value="minimal">Minimal Luxury</option>
  <option value="top">Top Social</option>
</select>

          </div>

          <!-- PREVIEW -->
          <div id="verse-card"
  class="rounded-2xl overflow-hidden border border-[var(--color-border)] 
  mx-auto w-full max-w-[420px] bg-black [&>svg]:w-full [&>svg]:h-full"
  style="aspect-ratio: 1 / 1;">


            <p id="card-text" class="text-lg leading-relaxed font-medium">
              Click a verse above to generate a card
            </p>

            <p id="card-ref" class="text-sm text-[var(--color-muted)]">—</p>

            <p class="text-xs text-[var(--color-muted)]">first7.org</p>

          </div>

          <!-- ACTIONS -->
          <div class="flex gap-3 justify-center">
            <button id="copy-btn" class="px-4 py-2 rounded-lg bg-[var(--color-primary)] text-white">
              Copy
            </button>

            <button id="download-btn" class="px-4 py-2 rounded-lg border border-[var(--color-border)]">
              Download
            </button>
          </div>
          <div class="flex gap-3 justify-center flex-wrap">
  <button id="wa-btn" class="px-4 py-2 rounded-lg bg-green-500 text-white">
    WhatsApp
  </button>

  <button id="pin-btn" class="px-4 py-2 rounded-lg bg-red-500 text-white">
    Pinterest
  </button>

  <button id="ig-btn" class="px-4 py-2 rounded-lg border">
    Instagram
  </button>
</div>

        </div>

      </article>

      <!-- SIDEBAR -->
      <aside class="hidden lg:block py-12">

        <div class="sticky top-24 space-y-6">

          <div class="rounded-2xl border border-[var(--color-border)] p-5 space-y-3">

            <p class="font-medium">More topics</p>

            <div class="space-y-2 text-sm">

              {allVerses
                .filter(v => v.id !== entry.id)
                .slice(0, 5)
                .map((v) => (
                  <a href={`/verses/${v.data.slug}`} class="block hover:underline">
                    {v.data.title}
                  </a>
                ))}

            </div>

          </div>

        </div>

      </aside>

    </div>

  </div>

</BaseLayout>

<!-- 🔥 SCRIPT -->
<script is:inline>
function initVerseCard() {
  const container = document.getElementById("verse-content");
  const card = document.getElementById("verse-card");

  const styleSelect = document.getElementById("style-select");
  const formatSelect = document.getElementById("format-select");
  const layoutSelect = document.getElementById("layout-select");

  const downloadBtn = document.getElementById("download-btn");

  if (!container || !card) return;

  let selectedText = "";
  let selectedRef = "";

  function escapeXML(str = "") {
    return str.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
  }

  function wrapText(text, maxChars = 22) {
    const words = text.split(" ");
    let lines = [];
    let line = "";

    words.forEach(w => {
      if ((line + w).length > maxChars) {
        lines.push(line);
        line = w + " ";
      } else {
        line += w + " ";
      }
    });

    lines.push(line);
    return lines;
  }

  function getStyle(style) {
    if (style === "light") {
      return { bg:"#ffffff", text:"#0f172a", sub:"#64748b", accent:"#2563eb" };
    }
    if (style === "gradient") {
      return { bg:"url(#grad)", text:"#ffffff", sub:"#cbd5f5", accent:"#22c55e" };
    }
    return { bg:"#020617", text:"#e2e8f0", sub:"#94a3b8", accent:"#38bdf8" };
  }

  function generateSVG(text, ref, style, format, layout) {
    const s = getStyle(style);

    const width = 1080;
    const height =
      format === "shorts" ? 1920 :
      format === "pinterest" ? 1620 :
      1080;

    const maxChars =
      format === "shorts" ? 18 :
      format === "pinterest" ? 20 :
      22;

    const lines = wrapText(text, maxChars);

    let fontSize = 44;
    if (lines.length > 8) fontSize = 38;
    if (lines.length > 12) fontSize = 32;

    const lineHeight = fontSize + 18;

    let textSVG = "";

    // ✅ SIGNATURE (fixed)
    if (layout === "signature") {
      const centerX = 540;

      let y = height / 2 - (lines.length * (lineHeight / 2));

      textSVG = lines.map(line => {
        const el = `
          <text x="${centerX}" y="${y}" text-anchor="middle"
            font-size="${fontSize}"
            font-family="Georgia, serif"
            letter-spacing="0.4"
            fill="${s.text}">
            ${escapeXML(line.trim())}
          </text>
        `;
        y += lineHeight;
        return el;
      }).join("");

      const dividerY = y + 10;

      return `
      <svg xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 ${width} ${height}"
        style="width:100%;height:100%">

        <rect width="100%" height="100%" fill="${s.bg}" />

        <circle cx="540" cy="${dividerY - 80}" r="3" fill="${s.accent}" opacity="0.6"/>

        ${textSVG}

        <line x1="420" x2="660" y1="${dividerY}" y2="${dividerY}"
          stroke="${s.accent}" stroke-width="1.5" opacity="0.5"/>

        <text x="50%" y="${dividerY + 40}" text-anchor="middle"
          font-size="20"
          font-family="system-ui, Arial"
          fill="${s.sub}"
          letter-spacing="1">
          — ${escapeXML(ref)}
        </text>

        <text x="50%" y="${height - 60}" text-anchor="middle"
          font-size="18"
          font-family="system-ui, Arial"
          fill="${s.sub}"
          opacity="0.7">
          first7.org
        </text>

      </svg>`;
    }

    // HERO
    if (layout === "hero") {
      let y = height / 2 - (lines.length * (lineHeight/2));

      textSVG = lines.map(line => {
        const el = `
          <text x="50%" y="${y}" text-anchor="middle"
            font-size="${fontSize}"
            font-family="Georgia, serif"
            letter-spacing="0.6"
            fill="${s.text}">
            ${escapeXML(line.trim())}
          </text>
        `;
        y += lineHeight;
        return el;
      }).join("");

      textSVG += `
        <line x1="35%" x2="65%" y1="${y+10}" y2="${y+10}"
          stroke="${s.accent}" stroke-width="2" opacity="0.6"/>
      `;

      textSVG += `
        <text x="50%" y="${y+50}" text-anchor="middle"
          font-size="24"
          fill="${s.sub}">
          — ${escapeXML(ref)}
        </text>
      `;
    }

    // MINIMAL
    else if (layout === "minimal") {
      let y = height / 2 - (lines.length * (lineHeight/2));

      textSVG = lines.map(line => {
        const el = `
          <text x="50%" y="${y}" text-anchor="middle"
            font-size="${fontSize}"
            font-family="Georgia, serif"
            fill="${s.text}">
            ${escapeXML(line.trim())}
          </text>
        `;
        y += lineHeight;
        return el;
      }).join("");

      textSVG += `
        <text x="50%" y="${y+30}" text-anchor="middle"
          font-size="22"
          fill="${s.sub}">
          — ${escapeXML(ref)}
        </text>
      `;
    }

    // TOP
    else {
      let y = 260;

      textSVG = lines.map(line => {
        const el = `
          <text x="50%" y="${y}" text-anchor="middle"
            font-size="${fontSize}"
            font-family="Georgia, serif"
            fill="${s.text}">
            ${escapeXML(line.trim())}
          </text>
        `;
        y += lineHeight;
        return el;
      }).join("");

      textSVG += `
        <text x="50%" y="${y+40}" text-anchor="middle"
          font-size="24"
          fill="${s.sub}">
          — ${escapeXML(ref)}
        </text>
      `;
    }

    const gradient = style === "gradient" ? `
      <defs>
        <linearGradient id="grad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#0f172a"/>
          <stop offset="100%" stop-color="#065f46"/>
        </linearGradient>
      </defs>` : "";

    return `
    <svg xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 ${width} ${height}"
      style="width:100%;height:100%">
      ${gradient}
      <rect width="100%" height="100%" fill="${s.bg}" />
      ${textSVG}
      <text x="50%" y="${height-60}" text-anchor="middle"
        font-size="20" fill="${s.sub}">
        first7.org
      </text>
    </svg>`;
  }

  function updatePreview() {
    if (!selectedText) return;

    const svg = generateSVG(
      selectedText,
      selectedRef,
      styleSelect?.value || "dark",
      formatSelect?.value || "square",
      layoutSelect?.value || "minimal"
    );

    card.innerHTML = svg;

    if (formatSelect.value === "shorts") card.style.aspectRatio = "9 / 16";
    else if (formatSelect.value === "pinterest") card.style.aspectRatio = "2 / 3";
    else card.style.aspectRatio = "1 / 1";
  }

  // click verse
  container.addEventListener("click", (e) => {
    const block = e.target.closest("blockquote");
    if (!block) return;

    selectedText = block.innerText.trim();
    selectedRef = block.getAttribute("data-ref") || "";

    updatePreview();
  });

  // auto load
  let tries = 0;
  const interval = setInterval(() => {
    const first = container.querySelector("blockquote");

    if (first) {
      selectedText = first.innerText.trim();
      selectedRef = first.getAttribute("data-ref") || "";
      updatePreview();
      clearInterval(interval);
    }

    tries++;
    if (tries > 10) clearInterval(interval);
  }, 200);

  // listeners
  styleSelect?.addEventListener("change", updatePreview);
  formatSelect?.addEventListener("change", updatePreview);
  layoutSelect?.addEventListener("change", updatePreview);

  // download
  downloadBtn?.addEventListener("click", () => {
    if (!selectedText) return;

    const svg = generateSVG(
      selectedText,
      selectedRef,
      styleSelect.value,
      formatSelect.value,
      layoutSelect.value
    );

    const blob = new Blob([svg], { type: "image/svg+xml" });
    const url = URL.createObjectURL(blob);

    const a = document.createElement("a");
    a.href = url;
    a.download = "verse-card.svg";
    a.click();
  });
}

if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", initVerseCard);
} else {
  initVerseCard();
}
</script>