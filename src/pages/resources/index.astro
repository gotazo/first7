---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type Resource = CollectionEntry<'resources'>;

const resources: Resource[] = await getCollection('resources');
---

<BaseLayout title="Resources">

  <section class="max-w-4xl mx-auto px-5 py-16 space-y-12">

    <!-- HEADER -->
    <div class="text-center space-y-3">
      <h1 class="text-4xl font-semibold">
        Resources
      </h1>

      <p class="text-[var(--color-muted)]">
        Simple tools to help you slow down, reflect, and grow
      </p>
    </div>

    <!-- LIST -->
    <div class="space-y-6">

      {resources.map((r: Resource) => (
        <a
          href={`/resources/${r.id}`}
          class="block rounded-2xl border border-[var(--color-border)] p-6 hover:bg-[var(--color-primary)]/5 transition"
        >
          <h2 class="text-lg font-medium">
            {r.data.title}
          </h2>

          <p class="mt-2 text-sm text-[var(--color-muted)]">
            {r.data.description}
          </p>
        </a>
      ))}

    </div>

  </section>

</BaseLayout>