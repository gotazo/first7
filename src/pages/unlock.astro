---
const file = Astro.url.searchParams.get("file");
---

<div class="max-w-md mx-auto px-4 py-20 text-center">

  <h1 class="text-2xl font-semibold">
    Unlock Your Journal
  </h1>

  <p class="mt-3 text-sm text-gray-500">
    Enter your email to access this 7-day guide.
  </p>

  <!-- Replace with Beehiiv embed -->
  <form action="#" method="POST" class="mt-6 space-y-4">
    <input
      type="email"
      required
      placeholder="Your email"
      class="w-full px-4 py-3 border rounded-xl"
    />

    <button class="w-full px-4 py-3 bg-black text-white rounded-xl">
      Unlock →
    </button>
  </form>

  {file && (
    <div class="mt-8">
      <a
        href={file}
        download
        class="inline-block px-5 py-3 rounded-xl bg-[var(--color-primary)] text-white"
      >
        Download Now →
      </a>
    </div>
  )}

</div>