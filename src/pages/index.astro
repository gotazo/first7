---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getStartPlanSummaries } from '../lib/start-plans';

const planSummaries = await getStartPlanSummaries();
const plans = planSummaries.map((summary) => summary.plan);

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<style>
  .hero {
    content-visibility: auto;
    contain-intrinsic-size: 500px;
    position: relative;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 20%,
      rgba(0, 255, 159, 0.08),
      transparent 60%
    );
    pointer-events: none;
  }

  .divider {
    height: 1px;
    width: 100%;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-border),
      transparent
    );
  }

  .card {
    display: block;
    padding: 1.25rem;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    background: rgba(0, 255, 159, 0.05);
    text-align: center;
    transition: all 0.2s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: var(--color-primary);
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
</style>

<BaseLayout title="Bible Verses, Plans & Daily Faith | First7">

  <!-- HERO -->
  <section class="hero max-w-2xl mx-auto text-center py-28 px-5">

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-semibold leading-tight tracking-tight">
      Bible verses for anxiety, fear, and daily faith
    </h1>

    <p class="mt-6 text-base sm:text-lg text-[var(--color-muted)] max-w-xl mx-auto">
      Find comfort, strength, and guidance through Scripture. 
      Explore Bible verses, 7-day plans, and reflections for real life.
    </p>

    <p class="mt-2 text-sm sm:text-base text-[var(--color-muted)]">
      Start where you are — and grow one day at a time.
    </p>

    <div class="mt-10 flex justify-center gap-4 flex-wrap">

      <a
        href="/verses/bible-verses-for-anxiety"
        class="px-6 py-3 rounded-xl bg-[var(--color-primary)] text-white font-medium shadow-sm hover:opacity-90 transition"
      >
        Find verses for anxiety →
      </a>

      <a
        href="/plans"
        class="px-6 py-3 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition"
      >
        Start a 7-day plan →
      </a>

    </div>

  </section>

  <!-- DIVIDER -->
  <div class="divider"></div>

  <!-- SEO ENTRY POINTS -->
  <section class="max-w-5xl mx-auto px-4 py-16">

    <h2 class="text-2xl md:text-3xl font-semibold text-center">
      Bible verses for every situation
    </h2>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6 mt-10">

      <a href="/verses/bible-verses-for-anxiety" class="card">Anxiety</a>
<a href="/verses/bible-verses-for-fear" class="card">Fear</a>
<a href="/verses/bible-verses-for-strength" class="card">Strength</a>
<a href="/verses/bible-verses-for-depression" class="card">Depression</a>
<a href="/verses/bible-verses-for-love" class="card">Love</a>
<a href="/verses/bible-verses-for-healing" class="card">Healing</a>

    </div>

  </section>

  <!-- DIVIDER -->
  <div class="divider"></div>

  <!-- HOW IT WORKS -->
  <section class="max-w-5xl mx-auto px-4 py-24">

    <div class="grid md:grid-cols-3 gap-8">

      {[
        { icon: "📖", title: "Read", text: "Read Bible verses that speak to your situation" },
        { icon: "✍️", title: "Reflect", text: "Pause and reflect on what God is saying" },
        { icon: "🔁", title: "Apply", text: "Take one small step forward in faith" }
      ].map((item) => (
        <div class="group p-6 rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 transition hover:-translate-y-1 hover:shadow-lg hover:border-[var(--color-primary)]">

          <p class="text-2xl text-center">{item.icon}</p>

          <p class="mt-3 font-medium text-center group-hover:text-[var(--color-primary)] transition">
            {item.title}
          </p>

          <p class="mt-2 text-sm text-[var(--color-muted)] text-center">
            {item.text}
          </p>

        </div>
      ))}

    </div>

  </section>

  <!-- DIVIDER -->
  <div class="divider"></div>

  <!-- PLANS -->
  <section class="max-w-5xl mx-auto px-4 py-24 space-y-10">

    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-center">
      7-day Bible plans for real life
    </h2>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">

      {plans.map((plan) => (
        <a
          href={`/plans/${plan}`}
          class="group block rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 p-6 transition hover:-translate-y-1 hover:shadow-lg hover:border-[var(--color-primary)]"
        >
          <h3 class="font-semibold capitalize group-hover:text-[var(--color-primary)] transition">
            {plan.replace(/-/g, " ")}
          </h3>

          <p class="mt-2 text-sm text-[var(--color-muted)]">
            7-day Bible plan for {plan.replace(/-/g, " ")}
          </p>
        </a>
      ))}

    </div>

  </section>

  <!-- DIVIDER -->
  <div class="divider"></div>

  <!-- BLOG -->
  <section class="max-w-5xl mx-auto px-4 py-24 space-y-10">

    <div class="flex justify-between items-center">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
        Faith, testimonies, and reflections
      </h2>

      <a href="/blog" class="text-sm text-[var(--color-primary)] hover:underline">
        View all →
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-3">

      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="group block rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 p-5 transition hover:-translate-y-1 hover:shadow-lg hover:border-[var(--color-primary)]"
        >
          <h3 class="font-medium group-hover:text-[var(--color-primary)] transition">
            {post.data.title}
          </h3>

          <p class="mt-2 text-sm text-[var(--color-muted)] line-clamp-3">
            {post.data.excerpt}
          </p>

          <div class="mt-3 text-xs text-[var(--color-muted)]">
            {post.data.date.toLocaleDateString()}
          </div>
        </a>
      ))}

    </div>

  </section>

</BaseLayout>