---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Get plans
const entries = await getCollection('start');
const plans = [...new Set(entries.map((e) => e.data.plan))];

// Get blog posts
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="First7">

  <section class="max-w-5xl mx-auto px-4 py-20 space-y-24">

    <!-- HERO -->
    <div class="text-center max-w-2xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-6xl font-semibold leading-tight">
        Walk with God, one day at a time
      </h1>

      <p class="text-lg text-[var(--color-muted)]">
        You don’t need to have everything figured out.
        Just show up as you are.
      </p>

      <p class="text-[var(--color-muted)]">
        Read, reflect, and take one step forward — with God.
      </p>

      <div class="flex justify-center gap-4 pt-4">
        <a
          href="/start"
          class="px-6 py-3 rounded-xl bg-[var(--color-primary)] text-white font-medium hover:opacity-90 transition"
        >
          Begin your journey →
        </a>

        <a
          href="/reflections"
          class="px-6 py-3 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)] transition"
        >
          Explore reflections
        </a>
      </div>
    </div>

    <!-- HOW IT WORKS -->
    <div class="grid md:grid-cols-3 gap-8 md:gap-10">

      <!-- READ -->
      <div class="p-6 md:p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 text-center space-y-4 transition hover:shadow-md hover:-translate-y-1">
        <p class="text-2xl">📖</p>
        <p class="font-medium text-lg">Read</p>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">
          Spend a few quiet minutes in Scripture and guided words
        </p>
      </div>

      <!-- REFLECT -->
      <div class="p-6 md:p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 text-center space-y-4 transition hover:shadow-md hover:-translate-y-1">
        <p class="text-2xl">✍️</p>
        <p class="font-medium text-lg">Reflect</p>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">
          Notice what stands out and what God is gently showing you
        </p>
      </div>

      <!-- STEP -->
      <div class="p-6 md:p-8 rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 text-center space-y-4 transition hover:shadow-md hover:-translate-y-1">
        <p class="text-2xl">🔁</p>
        <p class="font-medium text-lg">Take a step</p>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">
          Take one simple step forward in your day
        </p>
      </div>

    </div>

    <!-- PLANS -->
    <div class="space-y-8">

      <div class="text-center space-y-2">
        <h2 class="text-3xl font-semibold">
          Start where you need it
        </h2>

        <p class="text-[var(--color-muted)]">
          Start where you are — not where you think you should be
        </p>
      </div>

      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">

        {plans.map((plan) => (
          <a
            href={`/plans/${plan}`}
            class="group block rounded-2xl border border-[var(--color-border)] p-6 transition hover:-translate-y-1 hover:shadow-md hover:border-[var(--color-primary)]"
          >
            <h3 class="text-lg font-semibold capitalize group-hover:text-[var(--color-primary)] transition">
              {plan.replace(/-/g, " ")}
            </h3>

            <p class="mt-2 text-sm text-[var(--color-muted)]">
              A quiet 7-day space to walk through this
            </p>

            <div class="mt-4 text-sm text-[var(--color-muted)] group-hover:translate-x-1 transition">
              Enter →
            </div>
          </a>
        ))}

      </div>

    </div>

    <!-- BLOG -->
    <div class="space-y-8">

      <div class="flex justify-between items-center">
        <h2 class="text-3xl font-semibold">
          From the journey
        </h2>

        <a
          href="/blog"
          class="text-sm text-[var(--color-primary)] font-medium"
        >
          View all →
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">

        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group block rounded-2xl border border-[var(--color-border)] p-5 transition hover:-translate-y-1 hover:shadow-md hover:border-[var(--color-primary)]"
          >
            <h3 class="font-medium group-hover:text-[var(--color-primary)] transition">
              {post.data.title}
            </h3>

            <p class="mt-2 text-sm text-[var(--color-muted)] line-clamp-3">
              {post.data.excerpt}
            </p>

            <div class="mt-3 text-xs text-[var(--color-muted)]">
              {post.data.date.toLocaleDateString()}
            </div>
          </a>
        ))}

      </div>

    </div>

    <!-- FINAL CTA -->
    <div class="text-center space-y-4 pt-10">

      <p class="text-[var(--color-muted)] text-lg">
        You don’t need to do everything.
        Just take the next step.
      </p>

      <a
        href={`/plans/${plans[0]}/day-1`}
        class="inline-block px-6 py-3 rounded-xl text-white font-medium text-lg hover:opacity-90 transition"
        style="background-color: var(--color-primary);"
      >
        Start today →
      </a>

    </div>

  </section>

</BaseLayout>