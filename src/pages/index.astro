---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getStartPlanSummaries } from '../lib/start-plans';

const planSummaries = await getStartPlanSummaries();
const plans = planSummaries.map((summary) => summary.plan);

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<style>
  .hero {
    content-visibility: auto;
    contain-intrinsic-size: 500px;
    position: relative;
  }

  /* ✨ soft glow */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 20%,
      rgba(0, 255, 159, 0.08),
      transparent 60%
    );
    pointer-events: none;
  }

  /* ✨ divider */
  .divider {
    height: 1px;
    width: 100%;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-border),
      transparent
    );
  }
</style>

<BaseLayout title="First7">

  <!-- HERO -->
  <section class="hero max-w-2xl mx-auto text-center py-28 px-5">

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-semibold leading-tight tracking-tight">
      Walk with God,<br />
      <span class="text-[var(--color-primary)]">one day at a time</span>
    </h1>

    <p class="mt-6 text-base sm:text-lg text-[var(--color-muted)] max-w-xl mx-auto">
      You don’t need to have everything figured out.
      Just show up as you are.
    </p>

    <p class="mt-2 text-sm sm:text-base text-[var(--color-muted)]">
      Read, reflect, and take one step forward — with God.
    </p>

    <div class="mt-10 flex justify-center gap-4 flex-wrap">

      <a
        href="/start"
        class="px-6 py-3 rounded-xl bg-[var(--color-primary)] text-white font-medium shadow-sm hover:opacity-90 transition"
      >
        Begin your journey →
      </a>

      <a
        href="/reflections"
        class="px-6 py-3 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition"
      >
        Explore reflections
      </a>

    </div>

  </section>

  <!-- DIVIDER -->
  <div class="divider"></div>

  <!-- HOW IT WORKS -->
  <section class="max-w-5xl mx-auto px-4 py-24">

    <div class="grid md:grid-cols-3 gap-8">

      {[
        { icon: "📖", title: "Read", text: "Spend a few quiet minutes in Scripture" },
        { icon: "✍️", title: "Reflect", text: "Notice what stands out" },
        { icon: "🔁", title: "Take a step", text: "Take one simple step forward" }
      ].map((item) => (
        <div class="group p-6 rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 transition hover:-translate-y-1 hover:shadow-lg hover:border-[var(--color-primary)]">

          <p class="text-2xl text-center">{item.icon}</p>

          <p class="mt-3 font-medium text-center group-hover:text-[var(--color-primary)] transition">
            {item.title}
          </p>

          <p class="mt-2 text-sm text-[var(--color-muted)] text-center">
            {item.text}
          </p>

        </div>
      ))}

    </div>

  </section>

  <!-- DIVIDER -->
  <div class="divider"></div>

  <!-- PLANS -->
  <section class="max-w-5xl mx-auto px-4 py-24 space-y-10">

    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-center">
      Start where you need it
    </h2>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">

      {plans.map((plan) => (
        <a
          href={`/plans/${plan}`}
          class="group block rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 p-6 transition hover:-translate-y-1 hover:shadow-lg hover:border-[var(--color-primary)]"
        >
          <h3 class="font-semibold capitalize group-hover:text-[var(--color-primary)] transition">
            {plan.replace(/-/g, " ")}
          </h3>

          <p class="mt-2 text-sm text-[var(--color-muted)]">
            A quiet 7-day space
          </p>
        </a>
      ))}

    </div>

  </section>

  <!-- DIVIDER -->
  <div class="divider"></div>

  <!-- BLOG -->
  <section class="max-w-5xl mx-auto px-4 py-24 space-y-10">

    <div class="flex justify-between items-center">
      <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
        From the journey
      </h2>

      <a href="/blog" class="text-sm text-[var(--color-primary)] hover:underline">
        View all →
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-3">

      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="group block rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 p-5 transition hover:-translate-y-1 hover:shadow-lg hover:border-[var(--color-primary)]"
        >
          <h3 class="font-medium group-hover:text-[var(--color-primary)] transition">
            {post.data.title}
          </h3>

          <p class="mt-2 text-sm text-[var(--color-muted)] line-clamp-3">
            {post.data.excerpt}
          </p>

          <div class="mt-3 text-xs text-[var(--color-muted)]">
            {post.data.date.toLocaleDateString()}
          </div>
        </a>
      ))}

    </div>

  </section>

</BaseLayout>