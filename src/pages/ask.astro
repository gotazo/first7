---
import { getCollection } from "astro:content";
import AskLayout from "../layouts/AskLayout.astro";

const teachings = await getCollection("teachings");

const searchData = teachings.map((teaching) => ({
  id: teaching.id,
  title: teaching.data.title,
  summary: teaching.data.summary,
  topics: teaching.data.topics || [],
  keywords: teaching.data.keywords || [],
}));
---

<AskLayout
  title="Ask & Grow"
  description="Search teachings by spiritual questions, emotions, and life situations."
>

  <div class="max-w-3xl mx-auto space-y-10">

    <!-- HERO -->
    <section class="space-y-4 text-center">

      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight">
        Ask & Grow
      </h1>

      <p class="text-[var(--color-muted)] max-w-2xl mx-auto">
        Search teachings by spiritual questions,
        emotions, seasons, and life situations.
      </p>

    </section>

    <!-- SEARCH -->
    <section>

      <form
        id="ask-search-form"
        class="space-y-5"
      >

        <input
          id="ask-search-input"
          type="text"
          name="q"
          placeholder="Ask anything..."
          class="w-full rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] px-5 py-4 outline-none focus:border-[var(--color-primary)] transition"
        />

        <!-- QUICK PROMPTS -->
        <div class="flex flex-wrap gap-2">

          <button
            type="button"
            class="quick-btn"
            data-query="anxious"
          >
            I feel anxious
          </button>

          <button
            type="button"
            class="quick-btn"
            data-query="direction"
          >
            I need direction
          </button>

          <button
            type="button"
            class="quick-btn"
            data-query="trust"
          >
            Help me trust God
          </button>

          <button
            type="button"
            class="quick-btn"
            data-query="waiting"
          >
            Why am I waiting?
          </button>

        </div>

        <button
          type="submit"
          class="btn px-5 py-3 rounded-xl font-medium"
        >
          Search
        </button>

      </form>

    </section>

    <!-- RESULTS -->
    <section
      id="ask-results-section"
      class="hidden space-y-6"
    >

      <div class="flex items-center justify-between gap-4">

        <h2
          id="ask-results-title"
          class="text-xl font-medium"
        ></h2>

        <p
          id="ask-results-count"
          class="text-sm text-[var(--color-muted)]"
        ></p>

      </div>

      <div
        id="ask-results"
        class="space-y-4"
      ></div>

    </section>

  </div>

  <script type="application/json" id="teachings-search-data" set:html={JSON.stringify(searchData)} />

  <script>
    type TeachingSearchItem = {
      id: string;
      title: string;
      summary: string;
      topics: string[];
      keywords: string[];
    };

    const dataEl = document.getElementById("teachings-search-data");
    const teachings = JSON.parse(dataEl?.textContent || "[]") as TeachingSearchItem[];

    const form = document.getElementById("ask-search-form") as HTMLFormElement | null;
    const input = document.getElementById("ask-search-input") as HTMLInputElement | null;
    const section = document.getElementById("ask-results-section");
    const title = document.getElementById("ask-results-title");
    const count = document.getElementById("ask-results-count");
    const resultsEl = document.getElementById("ask-results");

    const synonyms: Record<string, string[]> = {
      anxious: ["worry", "fear", "stress", "overthinking"],
      worry: ["anxious", "fear"],
      stuck: ["delay", "waiting", "blocked"],
      lost: ["direction", "confused", "purpose"],
      sad: ["down", "heavy", "depressed"],
      fear: ["afraid", "anxious"],
      pray: ["prayer", "seek", "worship", "communion"],
      prayer: ["pray", "seeking", "worship"],
      trust: ["faith", "belief", "confidence"],
      waiting: ["delay", "patience", "process"],
      direction: ["guidance", "purpose", "calling"],
      purpose: ["calling", "assignment", "direction"],
    };

    const stopWords = new Set([
      "how",
      "to",
      "the",
      "a",
      "an",
      "and",
      "or",
      "why",
      "what",
      "is",
      "are",
      "i",
      "me",
      "my",
      "of",
      "in",
      "on",
      "for",
    ]);

    function getWords(query: string) {
      const words = query
        .toLowerCase()
        .replace(/[^\w\s]/g, "")
        .split(" ")
        .filter(Boolean)
        .filter((word) => !stopWords.has(word));

      const expandedWords = new Set<string>();

      words.forEach((word) => {
        expandedWords.add(word);

        Object.entries(synonyms).forEach(([key, values]) => {
          if (word === key || values.includes(word)) {
            expandedWords.add(key);
            values.forEach((value) => expandedWords.add(value));
          }
        });
      });

      return Array.from(expandedWords);
    }

    function scoreTeaching(teaching: TeachingSearchItem, words: string[]) {
      let score = 0;
      const title = teaching.title.toLowerCase();
      const summary = teaching.summary.toLowerCase();
      const topics = teaching.topics.map((topic) => topic.toLowerCase());
      const keywords = teaching.keywords.map((keyword) => keyword.toLowerCase());

      words.forEach((word) => {
        if (topics.includes(word)) score += 4;
        if (keywords.includes(word)) score += 3;
        if (title.includes(word)) score += 2;
        if (summary.includes(word)) score += 1;
      });

      return score;
    }

    function renderEmpty(query: string) {
      if (!section || !title || !count || !resultsEl) return;

      section.classList.remove("hidden");
      title.textContent = `Results for "${query}"`;
      count.textContent = "0 found";
      resultsEl.innerHTML = `
        <div class="rounded-2xl border border-[var(--color-border)] p-6">
          <h3 class="font-medium">No teachings found</h3>
          <p class="mt-2 text-sm text-[var(--color-muted)]">
            Try different keywords, emotions, or spiritual topics.
          </p>
        </div>
      `;
    }

    function renderResults(query: string) {
      if (!section || !title || !count || !resultsEl) return;

      const trimmedQuery = query.trim();

      if (!trimmedQuery) {
        section.classList.add("hidden");
        resultsEl.replaceChildren();
        return;
      }

      const words = getWords(trimmedQuery);
      const results = teachings
        .map((teaching) => ({
          teaching,
          score: scoreTeaching(teaching, words),
        }))
        .filter((result) => result.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 8)
        .map((result) => result.teaching);

      if (results.length === 0) {
        renderEmpty(trimmedQuery);
        return;
      }

      section.classList.remove("hidden");
      title.textContent = `Results for "${trimmedQuery}"`;
      count.textContent = `${results.length} found`;
      resultsEl.replaceChildren();

      results.forEach((result) => {
        const link = document.createElement("a");
        link.href = `/teachings/${result.id}`;
        link.className =
          "block rounded-2xl border border-[var(--color-border)] p-5 transition hover:bg-[var(--color-primary)]/5 hover:-translate-y-[2px]";

        const heading = document.createElement("h3");
        heading.className = "text-lg font-medium";
        heading.textContent = result.title;

        const summary = document.createElement("p");
        summary.className = "mt-2 text-sm text-[var(--color-muted)]";
        summary.textContent = result.summary;

        link.append(heading, summary);

        if (result.topics.length > 0) {
          const topics = document.createElement("div");
          topics.className = "flex flex-wrap gap-2 mt-4";

          result.topics.forEach((topic) => {
            const tag = document.createElement("span");
            tag.className = "text-xs rounded-full border px-2 py-1 text-[var(--color-muted)]";
            tag.textContent = topic;
            topics.append(tag);
          });

          link.append(topics);
        }

        resultsEl.append(link);
      });
    }

    function runSearch(query: string, updateUrl = true) {
      if (input) input.value = query;
      renderResults(query);

      if (updateUrl) {
        const url = new URL(window.location.href);

        if (query.trim()) {
          url.searchParams.set("q", query.trim());
        } else {
          url.searchParams.delete("q");
        }

        window.history.replaceState({}, "", url);
      }
    }

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      runSearch(input?.value || "");
    });

    document.querySelectorAll<HTMLButtonElement>("[data-query]").forEach((button) => {
      button.addEventListener("click", () => {
        runSearch(button.dataset.query || "");
      });
    });

    runSearch(new URLSearchParams(window.location.search).get("q") || "", false);
  </script>

  <style>

    .quick-btn {
      border: 1px solid var(--color-border);
      padding: 0.45rem 0.9rem;
      border-radius: 9999px;
      font-size: 0.875rem;
      transition: 160ms ease;
    }

    .quick-btn:hover {
      background: color-mix(
        in srgb,
        var(--color-primary) 10%,
        transparent
      );

      transform: translateY(-1px);
    }

  </style>

</AskLayout>
