---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import StudyHero from "../../components/shared/StudyHero.astro";

import { getCollection } from "astro:content";

const terms = (
  await getCollection("dictionary")
).sort((a, b) =>
  a.data.term.localeCompare(
    b.data.term
  )
);

/**
 * Group terms by first letter
 */
const groupedTerms = terms.reduce(
  (groups, term) => {

    const letter =
      term.data.term
        .charAt(0)
        .toUpperCase();

    if (!groups[letter]) {
      groups[letter] = [];
    }

    groups[letter].push(term);

    return groups;

  },
  {} as Record<string, typeof terms>
);

const letters =
  Object.keys(groupedTerms).sort();
---

<BaseLayout
  title="Bible Dictionary"
  description="Explore biblical words, places, people, doctrines, and prophetic terms through Scripture."
>

  <main
    class="
      mx-auto
      max-w-6xl
      px-4
      py-16
      sm:px-6
    "
  >

    <StudyHero
      section="Bible Dictionary"
      title="Bible Dictionary"
      description="Explore biblical words, places, people, doctrines, and prophetic terms through Scripture."
    />

    <!-- Intro -->
    <section
      class="
        mx-auto
        mt-8
        max-w-3xl
        text-center
      "
    >

      <p
        class="
          text-base
          leading-relaxed
          text-[var(--color-muted)]
        "
      >
        The First7 Bible Dictionary contains
        biblical words, places, people,
        doctrines, and prophetic terms
        explained through Scripture.
        Browse definitions alphabetically
        from A to Z.
      </p>

      <p
        class="
          mt-4
          text-sm
          text-[var(--color-muted)]
        "
      >
        {terms.length} Terms
      </p>

    </section>

    <!-- A-Z Navigation -->
    <section
      class="
        mt-10
        flex
        flex-wrap
        justify-center
        gap-2
      "
    >

      {letters.map((letter) => (

        <a
          href={`#${letter}`}
          class="
            rounded-lg
            border
            border-[var(--color-border)]
            px-3
            py-2
            text-sm
            transition
            hover:border-[var(--color-primary)]
          "
        >
          {letter}
        </a>

      ))}

    </section>

    <!-- Dictionary Groups -->
    <section class="mt-16 space-y-16">

      {letters.map((letter) => (

        <section
          id={letter}
          class="space-y-6"
        >

          <div
            class="
              flex
              items-center
              gap-4
            "
          >

            <h2
              class="
                text-4xl
                font-bold
              "
            >
              {letter}
            </h2>

            <div
              class="
                h-px
                flex-1
                bg-[var(--color-border)]
              "
            />

          </div>

          <div
            class="
              grid
              gap-4
              md:grid-cols-2
              lg:grid-cols-3
            "
          >

            {groupedTerms[letter].map(
              (term) => (

                <a
                  href={`/dictionary/${term.id}`}
                  class="
                    rounded-2xl
                    border
                    border-[var(--color-border)]
                    p-5
                    transition
                    hover:border-[var(--color-primary)]
                    hover:-translate-y-0.5
                  "
                >

                  <div class="space-y-3">

                    <h3
                      class="
                        text-lg
                        font-semibold
                      "
                    >
                      {term.data.title}
                    </h3>

                    <p
                      class="
                        text-sm
                        leading-relaxed
                        text-[var(--color-muted)]
                      "
                    >
                      {term.data.shortMeaning}
                    </p>

                    {term.data.scriptures?.length > 0 && (

                      <p
                        class="
                          text-xs
                          text-[var(--color-muted)]
                        "
                      >
                        {term.data.scriptures
                          .slice(0, 3)
                          .join(" • ")}
                      </p>

                    )}

                  </div>

                </a>

              )
            )}

          </div>

        </section>

      ))}

    </section>

  </main>

</BaseLayout>