---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";

import DictionaryLayout
  from "../../components/tools/dictionary/DictionaryLayout.astro";

import {
  getCollection,
  render,
} from "astro:content";

export async function getStaticPaths() {

  const entries =
    await getCollection("dictionary");

  return entries.map((entry) => ({

    params: {
      slug: entry.id,
    },

    props: {
      entry,
    },

  }));

}

const { entry } = Astro.props;

/**
 * Render Markdown
 */
const { Content } =
  await render(entry);

/**
 * Collections
 */
const allDictionary =
  await getCollection("dictionary");

const allTeachings =
  await getCollection("teachings");

const allProphecy =
  await getCollection("prophecy");

const allNumbers =
  await getCollection("numbers");
---

<BaseLayout
  title={`${entry.data.title} Meaning`}
  description={entry.data.shortMeaning}
>

<DictionaryLayout
  entry={entry}
  collections={{
    dictionary: allDictionary,
    teachings: allTeachings,
    prophecy: allProphecy,
    numbers: allNumbers,
  }}
>

    <Content />

  </DictionaryLayout>

</BaseLayout>