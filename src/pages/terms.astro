<BaseLayout title="Terms of Use">

  <div class="max-w-3xl mx-auto space-y-6 text-sm">

    <h1 class="text-3xl font-semibold">Terms of Use</h1>

    <p>
      By using this website, you agree to use it for lawful purposes only.
    </p>

    <h2 class="text-xl font-medium">Content</h2>

    <p>
      All content is provided for spiritual encouragement and informational purposes only.
    </p>

    <h2 class="text-xl font-medium">No Guarantees</h2>

    <p>
      We make no guarantees about outcomes or results from using this content.
    </p>

    <h2 class="text-xl font-medium">Changes</h2>

    <p>
      These terms may be updated at any time.
    </p>

  </div>

</BaseLayout>