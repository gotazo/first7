---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Support the Mission">

  <section class="max-w-3xl mx-auto px-5 py-16 space-y-16">

    <!-- HERO -->
    <div class="text-center space-y-4">
      <h1 class="text-4xl md:text-5xl font-semibold leading-tight">
        Support the <span class="text-[var(--color-primary)]">mission</span>
      </h1>

      <p class="text-lg text-[var(--color-muted)]">
        Helping people walk with God,
        <span class="text-[var(--color-primary)] font-medium">
          one day at a time
        </span>.
      </p>
    </div>

    <!-- WHY -->
    <div class="space-y-4 text-lg leading-relaxed">
      <p>First7 was created to make spiritual growth simple.</p>

      <p>
        No pressure. No noise. Just a clear path to spend time with God each day.
      </p>

      <p>
        Everything here is designed to be accessible to anyone,
        whether you're just starting or growing deeper in your faith.
      </p>
    </div>

    <!-- PRINCIPLE -->
    <div class="rounded-2xl border border-[var(--color-border)] p-6 bg-[var(--color-primary)]/5 space-y-3">
      <p class="font-medium">
        This will always be free.
      </p>

      <p class="text-[var(--color-muted)]">
        You can go through every plan, read every article, and use this system
        without ever paying.
      </p>

      <p class="text-[var(--color-muted)]">
        If this has helped you, and you feel led to support it,
        you can do that below.
      </p>
    </div>

    <!-- SUPPORT OPTIONS -->
    <div class="space-y-10">

      <div class="text-center space-y-2">
        <h2 class="text-2xl font-semibold">
          Ways to support
        </h2>

        <p class="text-[var(--color-muted)]">
          Only if you want to
        </p>
      </div>

      <!-- INDIA -->
      <div class="rounded-2xl border border-[var(--color-border)] p-6 space-y-4 text-center">
        <p class="font-medium">
          🇮🇳 In India
        </p>

        <p class="text-sm text-[var(--color-muted)]">
          Scan to support instantly via UPI
        </p>

        <div class="flex justify-center">
          <img src="/upi-qr.png" alt="UPI QR" class="w-40 h-40 object-contain" />
        </div>

        <p class="text-xs text-[var(--color-muted)]">
          UPI ID: gotazo2025@okicici
        </p>
      </div>

      <!-- GLOBAL -->
      <div class="rounded-2xl border border-[var(--color-border)] p-6 space-y-4 text-center">
        <p class="font-medium">
          🌍 International
        </p>

        <p class="text-sm text-[var(--color-muted)]">
          Support through Ko-fi
        </p>

        <a
          href="https://ko-fi.com/first7"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-5 py-2.5 rounded-lg bg-[var(--color-primary)] text-white hover:opacity-90 transition"
        >
          Support on Ko-fi →
        </a>
      </div>

      <!-- SHARE -->
      <div class="rounded-2xl border border-[var(--color-border)] p-6 space-y-4 text-center">

        <p class="font-medium">
          Share
        </p>

        <p class="text-sm text-[var(--color-muted)]">
          Send this to someone who might need it.
        </p>

        <div class="flex justify-center gap-4 mt-3 flex-wrap">

          <!-- WhatsApp -->
          <a
            href="https://wa.me/?text=Walking%20with%20God%20one%20day%20at%20a%20time%20https://first7.org"
            target="_blank"
            rel="noopener noreferrer"
            class="px-4 py-2 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:bg-[var(--color-primary)]/5 transition"
          >
            WhatsApp
          </a>

          <!-- X (Twitter) -->
          <a
            href="https://twitter.com/intent/tweet?text=Walking%20with%20God%20one%20day%20at%20a%20time%20https://first7.org"
            target="_blank"
            rel="noopener noreferrer"
            class="px-4 py-2 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:bg-[var(--color-primary)]/5 transition"
          >
            X
          </a>

          <!-- Copy Link -->
          <button
            onclick="
              navigator.clipboard.writeText('https://first7.org');
              alert('Link copied');
            "
            class="px-4 py-2 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:bg-[var(--color-primary)]/5 transition"
          >
            Copy link
          </button>

        </div>

      </div>

    </div>

    <!-- FINAL NOTE -->
    <div class="text-center space-y-3">
      <p class="text-[var(--color-muted)]">
        Whether you support or not,
      </p>

      <p class="text-xl font-medium">
        keep showing up daily.
      </p>
    </div>

  </section>

</BaseLayout>
