---
import BaseLayout from "../layouts/BaseLayout.astro";

import SearchBox from "../components/search/SearchBox.astro";
import SearchFilters from "../components/search/SearchFilters.astro";
import SearchResults from "../components/search/SearchResults.astro";
---

<BaseLayout
  title="Search the First7 Library"
  description="Search teachings, Bible verses, dictionary terms, plans, resources, and more."
>

  <section class="mx-auto max-w-6xl px-6 py-16">

    <header class="mx-auto max-w-3xl text-center">

      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--color-primary)]">
        First7 Library
      </p>

      <h1 class="mt-4 font-serif text-4xl md:text-5xl">
        Search the First7 Library
      </h1>

      <p class="mt-6 text-lg text-[var(--color-muted)]">
        Search teachings, dictionary terms,
        verse cards, plans, guides, resources, reflections, and more.
      </p>

    </header>

    <div class="mx-auto mt-12 max-w-3xl">

      <SearchBox />

      <div class="mt-8">
        <SearchFilters />
      </div>

    </div>

    <div class="mt-14">
      <SearchResults />
    </div>

  </section>

  <script>
    import { initSearch } from "../lib/search/ui/app";

    document.addEventListener("DOMContentLoaded", () => {
      void initSearch();
    });
  </script>

</BaseLayout>