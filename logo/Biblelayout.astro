---
import BaseLayout from "./BaseLayout.astro";
import { getCollection } from "astro:content";

const { currentBook, currentChapter } = Astro.props as {
  currentBook: string;
  currentChapter: number;
};

const entries = await getCollection("bible");

// ✅ Proper typing
const books: Record<string, number[]> = {};

// Group chapters by book
for (const entry of entries) {
  const book = entry.data.book;
  books[book] ??= [];
  books[book].push(entry.data.chapter);
}

// Sort chapters
for (const book in books) {
  books[book].sort((a: number, b: number) => a - b);
}

// Navigation logic
const chapters = books[currentBook] ?? [];
const index = chapters.indexOf(currentChapter);

const prev = index > 0 ? chapters[index - 1] : null;
const next = index < chapters.length - 1 ? chapters[index + 1] : null;
---

<BaseLayout title={`${currentBook} ${currentChapter}`}>

  <!-- 🔍 SEARCH + MOBILE MENU -->
  <div class="mb-6 flex items-center gap-3">

    <button id="menu-btn" class="md:hidden px-3 py-2 border rounded text-sm">
      ☰ Bible
    </button>

    <input
      id="bible-search"
      type="text"
      placeholder="Search (e.g. John 3)"
      class="w-full md:w-80 px-3 py-2 rounded border border-[var(--color-border)] bg-transparent text-sm focus:outline-none"
    />

  </div>

  <div class="flex gap-8">

    <!-- 📚 SIDEBAR -->
    <aside
      id="sidebar"
      class="fixed md:static top-0 left-0 z-50 h-full w-64 -translate-x-full md:translate-x-0 bg-[var(--color-bg)] border-r border-[var(--color-border)] p-4 overflow-y-auto transition-transform duration-300"
    >

      <p class="text-xs uppercase text-[var(--color-muted)] mb-4">Bible</p>

      <div class="space-y-6">

        {Object.entries(books).map(([book, chapters]: [string, number[]]) => (
          <div>
            <p class="font-medium capitalize mb-2">{book}</p>

            <div class="flex flex-wrap gap-2">
              {chapters.map((c: number) => (
                <a
                  href={`/bible/${book}/${c}`}
                  class={`px-2 py-1 text-sm rounded border ${
                    book === currentBook && c === currentChapter
                      ? "bg-[var(--color-primary)] text-white"
                      : "border-[var(--color-border)] hover:bg-[var(--color-primary)]/10"
                  }`}
                >
                  {c}
                </a>
              ))}
            </div>
          </div>
        ))}

      </div>

    </aside>

    <!-- 🌫️ OVERLAY (mobile) -->
    <div id="overlay" class="fixed inset-0 bg-black/40 hidden md:hidden"></div>

    <!-- 📖 MAIN READER -->
    <div class="flex-1 max-w-2xl mx-auto">

      <!-- HEADER -->
      <div class="sticky top-16 bg-[var(--color-bg)] z-20 pb-4 mb-6 border-b border-[var(--color-border)]">
        <h1 class="text-2xl font-semibold capitalize">
          {currentBook} {currentChapter}
        </h1>
      </div>

      <!-- CONTENT -->
      <div class="space-y-4 text-lg leading-relaxed">
        <slot />
      </div>

      <!-- NAVIGATION -->
      <div class="mt-12 flex justify-between text-sm text-[var(--color-muted)]">

        {prev ? (
          <a href={`/bible/${currentBook}/${prev}`}>
            ← {currentBook} {prev}
          </a>
        ) : <span />}

        {next ? (
          <a href={`/bible/${currentBook}/${next}`}>
            {currentBook} {next} →
          </a>
        ) : <span />}

      </div>

    </div>

  </div>

  <!-- ⚡ SCRIPT -->
 <script is:inline>
  // =============================
  // 📚 SIDEBAR
  // =============================
  const sidebar = document.getElementById("sidebar");
  const menuBtn = document.getElementById("menu-btn");
  const overlay = document.getElementById("overlay");

  const openSidebar = () => {
    if (sidebar) sidebar.classList.remove("-translate-x-full");
    if (overlay) overlay.classList.remove("hidden");
  };

  const closeSidebar = () => {
    if (sidebar) sidebar.classList.add("-translate-x-full");
    if (overlay) overlay.classList.add("hidden");
  };

  if (menuBtn) menuBtn.addEventListener("click", openSidebar);
  if (overlay) overlay.addEventListener("click", closeSidebar);

  // =============================
  // 🔍 SEARCH
  // =============================
  const input = document.getElementById("bible-search");

  const normalize = (str) => String(str).toLowerCase().trim();

  const handleSearch = () => {
    if (!(input instanceof HTMLInputElement)) return;

    const value = normalize(input.value);
    if (!value) return;

    const parts = value.split(" ");

    const lastPart = parts.length > 0 ? parts[parts.length - 1] : "";
    const chapter = parseInt(lastPart) || 1;

    const book = parts.slice(0, -1).join(" ").trim();
    if (!book) return;

    window.location.href = `/bible/${book}/${chapter}`;
  };

  if (input) {
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") handleSearch();
    });
  }

  // =============================
  // ✨ VERSE SYSTEM
  // =============================
  const STORAGE_KEY = "bible-bookmarks";

  const getBookmarks = () => {
    try {
      const data = localStorage.getItem(STORAGE_KEY);
      return data ? JSON.parse(data) : [];
    } catch {
      return [];
    }
  };

  const saveBookmarks = (data) => {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  };

  const toggleBookmark = (id) => {
    let bookmarks = getBookmarks();

    if (bookmarks.includes(id)) {
      bookmarks = bookmarks.filter((b) => b !== id);
    } else {
      bookmarks.push(id);
    }

    saveBookmarks(bookmarks);
    renderBookmarks();
  };

  const renderBookmarks = () => {
    const bookmarks = getBookmarks();

    document.querySelectorAll(".bible-verse").forEach((verse) => {
      const id = verse.id;

      if (!id) return;

      if (bookmarks.includes(id)) {
        verse.classList.add("ring-2", "ring-[var(--color-primary)]");
      } else {
        verse.classList.remove("ring-2", "ring-[var(--color-primary)]");
      }
    });
  };

  // =============================
  // 👆 CLICK INTERACTION
  // =============================
  document.querySelectorAll(".bible-verse").forEach((verse) => {
    verse.addEventListener("click", () => {
      const id = verse.id;
      if (!id) return;

      // Remove previous highlight
      document.querySelectorAll(".bible-verse").forEach((v) => {
        v.classList.remove("bg-[var(--color-primary)]/10");
      });

      // Highlight
      verse.classList.add("bg-[var(--color-primary)]/10");

      // Update URL
      window.history.replaceState(null, "", `#${id}`);

      // Copy link (safe)
      if (navigator.clipboard) {
        navigator.clipboard.writeText(window.location.href).catch(() => {});
      }

      // Bookmark toggle
      toggleBookmark(id);
    });
  });

  // =============================
  // 🔗 LOAD HASH
  // =============================
  const hash = window.location.hash;

  if (hash) {
    const target = document.querySelector(hash);
    if (target) {
      target.classList.add("bg-[var(--color-primary)]/10");
    }
  }

  // =============================
  // 🚀 INIT
  // =============================
  renderBookmarks();
</script>
</BaseLayout>